// ── Start game (host only) ───────────────────────────────────────
async function pokerStartGame() {
    if(!pokerIsHost || !pokerState) return;
    const players = Object.keys(pokerState.players || {});
    if(players.length < 2) return alert('Need at least 2 players.');
    pokerStartOfflineWatch();
    await pokerDealNewRound();
}

async function pokerDealNewRound() {
    let players = Object.keys(pokerState.players || {});
    // Randomize player order on first round
    if(!pokerState.round) {
        for(let i = players.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [players[i], players[j]] = [players[j], players[i]];
        }
    }
    const blind = pokerState.blind || 50;
    const deck = pokerNewDeck();
    // Deal 2 cards to each player
    const hands = {};
    players.forEach(p => { hands[p] = [deck.pop(), deck.pop()]; });
    // Reset player states for new round
    const playerUpdates = {};
    players.forEach(p => {
        playerUpdates[p] = {
            chips: pokerState.players[p].chips,
            bet: 0, folded: false, allIn: false,
            lastSeen: pokerState.players[p].lastSeen || Date.now(),
            playAgain: null
        };
    });
    // Small + big blind
    const sbIdx = (pokerState.round||0) % players.length;
    const bbIdx = (sbIdx + 1) % players.length;
    const sb = players[sbIdx], bb = players[bbIdx];
    playerUpdates[sb].bet = Math.min(blind/2, playerUpdates[sb].chips);
    playerUpdates[sb].chips -= playerUpdates[sb].bet;
    playerUpdates[bb].bet = Math.min(blind, playerUpdates[bb].chips);
    playerUpdates[bb].chips -= playerUpdates[bb].bet;
    const pot = playerUpdates[sb].bet + playerUpdates[bb].bet;
    const actionIdx = (bbIdx + 1) % players.length;

    await pokerRef.set({
        host: pokerState.host,
        phase: 'preflop',
        pot, blind,
        currentBet: blind,
        round: (pokerState.round||0)+1,
        community: [],
        deck: deck,
        hands,
        players: playerUpdates,
        order: players,
        actionOn: players[actionIdx],
        lastRaiser: bb,
        created: pokerState.created,
        meta: pokerState.meta
    });
}

