async function executeTrade(action) {
    const snap=await db.ref(`trades/${pendingTradeId}`).once('value');
    const t=snap.val(); if(!t||t.status!=='pending') return closeM('modal-trade-view');
    if(action==='accept'){
        const fromSnap=await db.ref(`users/${t.from}`).once('value'); const fromData=fromSnap.val();
        const mySnap=await db.ref(`users/${user}`).once('value'); const myData=mySnap.val();
        if(t.fromOffer.points>(fromData.points||0)){alert("Sender no longer has enough points!");return;}
        if(t.toRequest.points>(myData.points||0)){alert("You don't have enough points for this trade!");return;}
        for(const item of (t.fromOffer.items||[])){const q=item.qty||1;const folderName=item.type==='lootbox'?'lootboxes':item.type+'s';await db.ref(`users/${t.from}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(-q));await db.ref(`users/${user}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(q));}
        if(t.fromOffer.points>0){await db.ref(`users/${t.from}/points`).set(firebase.database.ServerValue.increment(-t.fromOffer.points));await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(t.fromOffer.points));}
        for(const item of (t.toRequest.items||[])){const q=item.qty||1;const folderName=item.type==='lootbox'?'lootboxes':item.type+'s';await db.ref(`users/${user}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(-q));await db.ref(`users/${t.from}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(q));}
        if(t.toRequest.points>0){await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-t.toRequest.points));await db.ref(`users/${t.from}/points`).set(firebase.database.ServerValue.increment(t.toRequest.points));}
        await db.ref(`trades/${pendingTradeId}/status`).set('accepted');
        alert("Trade accepted! Items transferred.");
    } else { await db.ref(`trades/${pendingTradeId}/status`).set('declined'); }
    closeM('modal-trade-view'); loadTrades();
}

async function cancelTrade(tradeId) {
    if(!confirm("Cancel this trade?")) return;
    await db.ref(`trades/${tradeId}/status`).set('declined'); loadTrades();
}

