// ── Render everything based on state ────────────────────────────
function pokerRender() {
    if(!pokerState) return;
    const phase = pokerState.phase;
    pokerUpdateBadge();

    if(phase === 'waiting') {
        pokerRenderWaiting();
    } else if(phase === 'dealing') {
        // Transitional phase — show a brief loading state
        document.getElementById('poker-waiting').classList.add('hidden');
        document.getElementById('poker-table').classList.add('hidden');
        document.getElementById('poker-round-end').classList.remove('hidden');
        document.getElementById('poker-winner-msg').textContent = '🔄 Starting new round...';
    } else if(['preflop','flop','turn','river'].includes(phase)) {
        pokerShowWaiting(); // hide lobby
        document.getElementById('poker-waiting').classList.add('hidden');
        document.getElementById('poker-table').classList.remove('hidden');
        document.getElementById('poker-round-end').classList.add('hidden');
        pokerRenderTable();
    } else if(phase === 'showdown') {
        document.getElementById('poker-waiting').classList.add('hidden');
        document.getElementById('poker-table').classList.add('hidden');
        document.getElementById('poker-round-end').classList.remove('hidden');
        pokerRenderShowdown();
    }
}

