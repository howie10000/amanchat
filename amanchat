<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aman Chat - Deluxe Edition</title>
    <style>
        /* Dynamic theme styles injected by JS */
        :root {
            --primary: #00d4ff; --bg: #0b0b0b; 
            --panel: rgba(22, 22, 22, 0.85); --sidebar: rgba(17, 17, 17, 0.85);
            --text: #f0f0f0; --admin: #ff3e3e; 
            --msg-bg: rgba(34, 34, 34, 0.85); --msg-me: rgba(0, 75, 90, 0.85);
        }

        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: var(--sidebar); }
        ::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { filter: brightness(1.2); }

        @keyframes shimmer { 0%,100%{opacity:.7} 50%{opacity:1} }
        @keyframes legendaryGlow { 0%,100%{text-shadow:0 0 8px #ffd700, 0 0 16px #ffd700} 50%{text-shadow:0 0 20px #ffd700, 0 0 40px #ff9900} }
        @keyframes epicGlow { 0%,100%{text-shadow:0 0 8px #b366ff} 50%{text-shadow:0 0 20px #b366ff, 0 0 35px #9900ff} }
        @keyframes rareGlow { 0%,100%{text-shadow:0 0 6px #4d94ff} 50%{text-shadow:0 0 15px #4d94ff} }
        
        /* ENHANCED MYTHIC GLOW */
        @keyframes mythicGlow { 
            0%,100%{text-shadow:0 0 15px #ff00aa, 0 0 30px #ff00aa, 0 0 40px #00ffff; filter: brightness(1.2) drop-shadow(0 0 10px rgba(255,0,170,0.8));} 
            50%{text-shadow:0 0 35px #00ffff, 0 0 60px #ff00aa, 0 0 80px #00ffff; filter: brightness(1.5) drop-shadow(0 0 20px rgba(0,255,255,1));} 
        }
        @keyframes mythicBurst { 0% { opacity: 1; transform: scale(0); } 100% { opacity: 0; transform: scale(3) translate(var(--dx), var(--dy)); } }

        @keyframes boxShake { 0%,100%{transform:translateX(0)} 10%{transform:translateX(-12px) rotate(-5deg)} 20%{transform:translateX(14px) rotate(5deg)} 30%{transform:translateX(-10px) rotate(-3deg)} 40%{transform:translateX(10px) rotate(3deg)} 50%{transform:translateX(-6px) rotate(-2deg)} 60%{transform:translateX(6px) rotate(2deg)} 70%{transform:translateX(0)} 100%{transform:translateX(0)} }
        @keyframes revealItem { 0%{opacity:0;transform:scale(0.2) translateY(30px)} 60%{transform:scale(1.2) translateY(-10px)} 100%{opacity:1;transform:scale(1) translateY(0)} }
        
        @keyframes gradientBG { 0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%} }

        body { font-family:'Segoe UI',sans-serif; background: var(--bg); color: var(--text); margin: 0; width:100vw; height:100vh; overflow:hidden; display:flex; transition:0.3s; }
        #mythic-canvas { position:fixed; inset:0; z-index:0; pointer-events:none; }
        #app-container { width:100%; height:100%; display:flex; flex-direction:column; background: var(--panel); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); position:relative; z-index:1; }
        .hidden { display:none !important; }
        nav { display:flex; background:rgba(0,0,0,0.8); padding:5px; gap:4px; border-bottom:1px solid rgba(255,255,255,0.1); flex-shrink:0; flex-wrap:wrap; }
        nav button { flex:1; padding:10px 6px; background:transparent; border:none; color:#888; cursor:pointer; border-radius:6px; font-weight:bold; transition:0.2s; position:relative; font-size:0.8em; }
        nav button.active { background: var(--primary); color:#000; }
        #main-view-area { flex:1; display:flex; overflow:hidden; position:relative; min-height:0; }
        .tab-pane { display:flex; flex:1; width:100%; height:100%; overflow:hidden; }
        .sidebar { width:250px; min-width:180px; border-right:1px solid rgba(255,255,255,0.05); display:flex; flex-direction:column; background:var(--sidebar); overflow-y:auto; flex-shrink:0; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); }
        .chat-content { flex:1; display:flex; flex-direction:column; background:transparent; position:relative; min-width:0; }
        .right-sidebar { width:220px; border-left:1px solid rgba(255,255,255,0.05); background:var(--sidebar); padding:10px; overflow-y:auto; flex-shrink:0; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); }
        .list-header { padding:15px 10px 5px; font-size:0.75em; color:#777; text-transform:uppercase; font-weight:bold; letter-spacing:1px; }
        .list-item { padding:12px 10px; cursor:pointer; border-bottom:1px solid rgba(255,255,255,0.05); display:flex; justify-content:space-between; align-items:center; position:relative; }
        .list-item:hover { background:rgba(255,255,255,0.1); color:var(--primary); }
        .status-dot { width:10px; height:10px; border-radius:50%; background:#444; display:inline-block; margin-right:5px; }
        .status-online { background:#00ff00; box-shadow:0 0 5px #00ff00; }
        .unread-dot { width:10px; height:10px; border-radius:50%; background:yellow; box-shadow:0 0 8px yellow; position:absolute; right:10px; top:50%; transform:translateY(-50%); }
        #msg-history { flex:1; overflow-y:auto; padding:20px; display:flex; flex-direction:column; gap:15px; min-height:0; }
        .msg { background:var(--msg-bg); padding:10px 14px; border-radius:10px; width:fit-content; max-width:80%; position:relative; word-wrap:break-word; border:1px solid rgba(255,255,255,0.05); box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .msg.me { align-self:flex-end; background:var(--msg-me); }
        .msg-info { font-size:0.85em; color:var(--primary); margin-bottom:5px; font-weight:bold; cursor:pointer; display:flex; justify-content:space-between; align-items:center; gap:10px; }
        .msg-ts { font-size:0.75em; color:#aaa; font-weight:normal; }
        .msg img { max-width:250px; border-radius:8px; margin-top:5px; cursor:pointer; border:1px solid #444; background:white; }
        .del-msg { color:red; cursor:pointer; display:none; margin-left:10px; font-size:1.2em; }
        .msg:hover .del-msg { display:inline-block; }
        .input-area { padding:15px; background:rgba(0,0,0,0.4); display:flex; flex-direction:column; gap:5px; border-top:1px solid rgba(255,255,255,0.05); flex-shrink:0; backdrop-filter: blur(10px); }
        .input-row { display:flex; gap:10px; }
        input, textarea, select { flex:1; background:rgba(0,0,0,0.5); border:1px solid #444; color:var(--text); padding:12px; border-radius:8px; outline:none; }
        .btn { padding:10px 18px; border-radius:8px; border:none; font-weight:bold; cursor:pointer; transition:0.2s; display:flex; align-items:center; justify-content:center; text-align:center; }
        .primary { background:var(--primary); color:#000; box-shadow: 0 0 10px rgba(0,212,255,0.2); }
        .modal { position:fixed; inset:0; background:rgba(0,0,0,0.9); display:flex; align-items:center; justify-content:center; z-index:9999; }
        .modal-card { background:var(--panel); padding:25px; border-radius:15px; width:360px; max-width:92vw; text-align:center; border:1px solid var(--primary); max-height:90vh; overflow-y:auto; position:relative; overflow:hidden; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }

        /* Loading screen */
        #loading-screen { position:fixed; inset:0; background:#0b0b0b; display:flex; flex-direction:column; align-items:center; justify-content:center; z-index:99999; }
        #loading-screen h1 { color:#00d4ff; font-size:2.5em; letter-spacing:5px; margin-bottom:20px; }
        .loading-bar { width:300px; height:4px; background:#222; border-radius:2px; overflow:hidden; }
        .loading-fill { height:100%; background:#00d4ff; border-radius:2px; animation:loadFill 2s ease forwards; }
        @keyframes loadFill { from{width:0%} to{width:100%} }

        /* Rarity classes */
        .rc { color:#aaa; } .rr { color:#4d94ff; animation:rareGlow 2s infinite; } .re { color:#b366ff; animation:epicGlow 2s infinite; } .rl { color:#ffd700; animation:legendaryGlow 2s infinite; } .rm { color:#ff00aa; animation:mythicGlow 3s infinite; font-weight:bold; } .rcr { color:#ff6666; } .rev { color:#ff9900; }
        .rarity-badge { font-size:0.7em; padding:2px 8px; border-radius:10px; font-weight:bold; text-transform:uppercase; letter-spacing:1px; }
        .rb-common { background:rgba(170,170,170,0.2); color:#aaa; border:1px solid #aaa; }
        .rb-rare { background:rgba(77,148,255,0.2); color:#4d94ff; border:1px solid #4d94ff; }
        .rb-epic { background:rgba(179,102,255,0.2); color:#b366ff; border:1px solid #b366ff; }
        .rb-legendary { background:rgba(255,215,0,0.2); color:#ffd700; border:1px solid #ffd700; }
        .rb-mythic { background:rgba(255,0,170,0.2); color:#ff00aa; border:1px solid #ff00aa; }
        .rb-ceremonial { background:rgba(255,102,102,0.2); color:#ff6666; border:1px solid #ff6666; }
        .rb-event { background:rgba(255,153,0,0.2); color:#ff9900; border:1px solid #ff9900; }
        .rb-free { background:rgba(100,100,100,0.2); color:#aaa; border:1px solid #666; }
        .item-card { background:rgba(0,0,0,0.4); border-radius:10px; padding:12px; display:flex; flex-direction:column; align-items:center; gap:8px; cursor:pointer; transition:0.2s; border:1px solid transparent; }
        .item-card:hover { border-color: var(--primary); background:rgba(255,255,255,0.05); }
        .item-card.selected { border-color: var(--primary) !important; background:rgba(0,212,255,0.1) !important; }
        .item-card.ic-common { border-color:rgba(170,170,170,0.3); }
        .item-card.ic-rare { border-color:rgba(77,148,255,0.3); }
        .item-card.ic-epic { border-color:rgba(179,102,255,0.3); }
        .item-card.ic-legendary { border-color:rgba(255,215,0,0.4); box-shadow:0 0 8px rgba(255,215,0,0.15); }
        .item-card.ic-mythic { border-color:rgba(255,0,170,0.5); box-shadow:0 0 10px rgba(255,0,170,0.2); }
        .active-title { font-size:0.85em; padding:3px 10px; border-radius:10px; font-weight:bold; display:inline-block; margin-bottom:6px; }
        .msg-title { font-size:0.72em; color:#aaa; font-weight:normal; font-style:italic; margin-left:6px; }
        .lootbox-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:20px; width:100%; max-width:1000px; }
        .lb-card { background:rgba(0,0,0,0.5); border-radius:15px; padding:20px; text-align:center; cursor:pointer; transition:0.25s; position:relative; overflow:hidden; backdrop-filter: blur(5px); }
        .lb-card:hover { transform:translateY(-4px); }
        .lb-card-1 { border:2px solid #aaa; }
        .lb-card-2 { border:2px solid #4d94ff; box-shadow:0 0 15px rgba(77,148,255,0.2); }
        .lb-card-3 { border:2px solid #b366ff; box-shadow:0 0 20px rgba(179,102,255,0.3); }
        .lb-card-4 { border:2px solid #ffd700; box-shadow:0 0 25px rgba(255,215,0,0.35); animation:shimmer 2s infinite; }
        .lb-card-5 { border:2px solid #ff00aa; box-shadow:0 0 35px rgba(255,0,170,0.4); animation:mythicGlow 2s infinite; }
        .lb-icon { font-size:4em; margin-bottom:10px; display:block; }
        .lb-odds { font-size:0.78em; color:#aaa; margin-top:10px; text-align:left; background:rgba(0,0,0,0.3); border-radius:8px; padding:10px; }
        .lb-odd-row { display:flex; justify-content:space-between; margin:2px 0; }
        #lootbox-open-modal .modal-card { min-height:350px; position:relative; }
        .lb-open-box { font-size:5em; display:block; margin:20px auto; width:fit-content; transition:1s; }
        .lb-open-box.shaking { animation:boxShake 0.8s ease; }
        .lb-result-item { animation:revealItem 0.6s ease forwards; opacity:0; position:relative; }

        .inv-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:12px; width:100%; max-width:900px; }
        .inv-item { background:rgba(0,0,0,0.4); border-radius:10px; padding:12px; text-align:center; position:relative; backdrop-filter: blur(5px); }
        .inv-badge { position:absolute; top:-5px; right:-5px; background:var(--primary); color:#000; border-radius:50%; width:22px; height:22px; display:flex; align-items:center; justify-content:center; font-size:0.75em; font-weight:bold; }
        .theme-swatch { width:45px; height:45px; border-radius:50%; margin:0 auto 8px; border:2px solid rgba(255,255,255,0.3); }
        .trade-card { background:rgba(0,0,0,0.35); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:15px; margin-bottom:10px; backdrop-filter: blur(5px); }
        .trade-card.pending { border-color:rgba(0,212,255,0.5); }
        .trade-card.accepted { border-color:rgba(0,255,100,0.5); }
        .trade-card.declined { border-color:rgba(255,80,80,0.4); opacity:0.7; }
        .trade-side { background:rgba(0,0,0,0.25); border-radius:8px; padding:10px; flex:1; }
        .trade-item-chip { display:inline-flex; align-items:center; gap:4px; background:rgba(255,255,255,0.1); border-radius:8px; padding:3px 8px; font-size:0.8em; margin:2px; }
        
        /* Games CSS */
        .game-card { background:rgba(0,0,0,0.5); border:1px solid var(--primary); border-radius:15px; padding:20px; text-align:center; margin-bottom:20px; backdrop-filter: blur(5px); }
        
        .plinko-board { display:flex; flex-direction:column; align-items:center; margin:20px auto; position:relative; width: 100%; max-width: 600px; height: 360px; background: rgba(0,0,0,0.3); border-radius: 10px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); will-change: transform; }
        .plinko-ball { width: 12px; height: 12px; background: #fff; border-radius: 50%; position: absolute; top: 0; left: 50%; transform: translate(-50%, -20px); box-shadow: 0 0 10px #fff; z-index: 10; will-change: transform; }
        .plinko-pegs { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: space-evenly; align-items: center; padding: 20px 0; pointer-events:none; }
        .plinko-row { display: flex; justify-content: center; gap: 20px; }
        .plinko-peg { width: 6px; height: 6px; background: #555; border-radius: 50%; box-shadow: inset -1px -1px 3px rgba(0,0,0,0.8); }
        .plinko-bins { position: absolute; bottom: 0; left: 0; right: 0; display: flex; height: 28px; z-index: 5; }
        .plinko-bin { flex: 1; border-right: 1px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; font-size: 0.5em; font-weight: bold; color: #fff; background: rgba(0,0,0,0.85); min-width: 0; overflow: hidden; padding: 0 1px; line-height: 1; text-shadow: 0 1px 2px rgba(0,0,0,0.9); }
        .plinko-bin:last-child { border-right: none; }
        .plinko-bin.active-bin { background: rgba(0,212,255,0.4) !important; color: #00d4ff !important; }
        
        /* Roulette CSS */
        .roulette-board { display:grid; grid-template-columns: 60px repeat(12, 1fr); grid-template-rows: repeat(3, 40px); gap:2px; max-width:800px; margin: 20px auto; background: #222; padding:5px; border-radius:10px; }
        .rl-spot { display:flex; align-items:center; justify-content:center; font-weight:bold; cursor:pointer; position:relative; background:#0b0b0b; color:white; border:1px solid #444; transition: 0.1s; }
        .rl-spot:hover { filter: brightness(1.3); }
        .rl-zero { grid-row: 1 / 4; background:#008800; border-radius:8px 0 0 8px; font-size:1.5em; }
        .rl-red { background:#cc0000; }
        .rl-black { background:#111; }
        .rl-outside { grid-column: 2 / 14; display:flex; gap:2px; margin-top:5px; }
        .rl-out-btn { flex:1; height:40px; background:#333; color:white; border:1px solid #555; display:flex; align-items:center; justify-content:center; font-weight:bold; cursor:pointer; }
        .rl-chip { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:24px; height:24px; border-radius:50%; background:var(--primary); color:black; font-size:0.6em; display:flex; align-items:center; justify-content:center; font-weight:bold; border:2px dashed black; z-index:10; pointer-events:none; }
        
        /* Physical Wheel Architecture */
        .rl-wheel-container { width:220px; height:220px; border-radius:50%; border:8px solid #333; margin:0 auto 20px; position:relative; overflow:hidden; background:#222; box-shadow: 0 5px 25px rgba(0,0,0,0.7), inset 0 0 15px rgba(0,0,0,0.8); }
        .rl-wheel-pointer { width:0; height:0; border-left:12px solid transparent; border-right:12px solid transparent; border-top:20px solid #fff; position:absolute; top:-2px; left:50%; transform:translateX(-50%); z-index:20; filter:drop-shadow(0 4px 4px rgba(0,0,0,0.7)); }
        #rl-wheel { width:100%; height:100%; position:relative; border-radius:50%; overflow:hidden; transition: transform 4s cubic-bezier(0.15, 0.85, 0.1, 1); }
        .rl-wedge { position:absolute; top:0; right:50%; width:50%; height:50%; transform-origin:100% 100%; display:flex; align-items:center; justify-content:center; overflow:hidden; border: 1px solid rgba(0,0,0,0.25); box-sizing: border-box; }
        .rl-wedge span { position:absolute; left:4px; top:14px; font-size: 0.55em; font-weight:bold; color:white; text-shadow: 0 0 3px rgba(0,0,0,0.9), 0 1px 2px rgba(0,0,0,1); white-space:nowrap; pointer-events:none; }

        .rps-btn { font-size: 3em; background: rgba(0,0,0,0.4); border: 2px solid #555; border-radius: 15px; padding: 10px 20px; cursor: pointer; transition: 0.2s; }
        .rps-btn:hover { border-color: var(--primary); background: rgba(255,255,255,0.1); transform: scale(1.1); }
        .bj-card { display: inline-block; background: white; color: black; border-radius: 5px; padding: 10px; margin: 5px; font-size: 1.2em; font-weight: bold; width: 40px; text-align: center; box-shadow: 0 2px 5px rgba(0,0,0,0.5); }
        .bj-card.red { color: red; }
        
        .admin-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; width:100%; max-width:1100px; }
        .admin-box { background:rgba(0,0,0,0.3); padding:20px; border-radius:10px; border:1px solid var(--admin); max-height:400px; overflow-y:auto; backdrop-filter: blur(10px); }
        .admin-box.full { grid-column:span 2; max-height:none; }
        .profile-points-badge { background:rgba(0,0,0,0.5); border:2px solid var(--primary); border-radius:15px; padding:10px 20px; margin:10px 0; font-size:1.2em; color:var(--primary); font-weight:bold; backdrop-filter: blur(5px); }
        
        /* High-Pop Gradient Overrides */
        body.gradient-active #app-container { background: rgba(10, 10, 10, 0.25) !important; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
        body.gradient-active .sidebar, body.gradient-active .right-sidebar { background: rgba(0, 0, 0, 0.2) !important; border-color: rgba(255,255,255,0.1) !important; }
        body.gradient-active .msg { background: rgba(0, 0, 0, 0.45) !important; border-color: rgba(255,255,255,0.15) !important; box-shadow: 0 8px 16px rgba(0,0,0,0.2) !important; }
        body.gradient-active .input-area, body.gradient-active nav, body.gradient-active #chat-header { background: rgba(0, 0, 0, 0.3) !important; border-color: rgba(255,255,255,0.1) !important; }
        body.gradient-active .modal-card { backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px); border-color: rgba(255,255,255,0.2) !important; }

        /* Preview Modal Specifics */
        .preview-pane { background: var(--prev-bg); padding: 20px; border-radius: 10px; display: flex; gap: 10px; border: 1px solid #fff; }
        .prev-sidebar { background: var(--prev-sidebar); width: 100px; border-radius: 5px; padding: 10px; color: var(--prev-text); font-size: 0.8em; }
        .prev-chat { background: var(--prev-panel); flex: 1; border-radius: 5px; padding: 10px; display: flex; flex-direction: column; gap: 10px; }
        .prev-msg { background: var(--prev-msg-bg); color: var(--prev-text); padding: 8px; border-radius: 8px; width: fit-content; font-size: 0.8em; }
        .prev-msg.me { background: var(--prev-msg-me); align-self: flex-end; }
        .prev-input { background: rgba(0,0,0,0.5); border: 1px solid var(--prev-primary); border-radius: 5px; padding: 8px; margin-top: 10px; color: var(--prev-text); }
    </style>
</head>
<body>

<canvas id="mythic-canvas"></canvas>

<!-- Loading Screen -->
<div id="loading-screen">
    <h1>AMAN CHAT</h1>
    <p style="color:#666; margin-bottom:20px; letter-spacing:2px;">Loading database config...</p>
    <div class="loading-bar"><div class="loading-fill"></div></div>
</div>

<div id="app-container">
    <!-- Modals -->
    <div id="modal-delete-srv" class="modal hidden">
        <div class="modal-card">
            <h3 style="color:red; font-size:1.5em; margin-top:0;">🗑️ Delete Server</h3>
            <p style="color:#ddd; margin-bottom:20px;">Are you absolutely sure you want to delete this server? This action <strong>cannot be undone</strong> and all chat history will be lost forever.</p>
            <div style="display:flex; gap:10px;">
                <button class="btn" style="flex:1; background:red; color:white; box-shadow:0 0 10px rgba(255,0,0,0.5);" onclick="confirmDeleteServer()">Yes, Delete</button>
                <button class="btn" style="flex:1; background:rgba(255,255,255,0.1); color:white;" onclick="closeM('modal-delete-srv')">Cancel</button>
            </div>
        </div>
    </div>

    <!-- Theme Preview Modal -->
    <div id="modal-theme-preview" class="modal hidden">
        <div class="modal-card" style="width: 600px;">
            <h3 style="color:var(--primary); margin-top:0;">🎨 Live Theme Preview</h3>
            <div id="preview-container" class="preview-pane">
                <div class="prev-sidebar"># general<br># rules<br><br>Users Online: 2</div>
                <div class="prev-chat">
                    <div class="prev-msg"><strong style="color:var(--prev-primary)">@Howard</strong><br>Check out this new theme!</div>
                    <div class="prev-msg me"><strong style="color:var(--prev-primary)">@You</strong><br>Looks awesome!</div>
                    <div class="prev-input">Type message...</div>
                </div>
            </div>
            <button class="btn primary" style="width:100%; margin-top:15px;" onclick="closeM('modal-theme-preview')">Close Preview</button>
        </div>
    </div>

    <div id="modal-profile" class="modal hidden" onclick="closeM('modal-profile')">
        <div class="modal-card" onclick="event.stopPropagation()">
