async function submitMarketOffer() {
    const givePoints = parseInt(document.getElementById('mkt-give-points').value)||0;
    const wantPoints = parseInt(document.getElementById('mkt-want-points').value)||0;
    if(mktGiveSelected.length===0 && givePoints===0) return alert("You must offer something.");
    if(givePoints > myPoints) return alert("Not enough points to offer.");

    // Validate you own all the give items
    for(const item of mktGiveSelected) {
        const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
        const owned = (myInventory[folderName]||{})[item.id] || 0;
