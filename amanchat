// --- PLINKO (QUADRATIC BEZIER) ---
const PLINKO_ROWS = 16;
const PLINKO_MULTS = [100, 40, 10, 5, 3, 1.5, 1, 0.4, 0.2, 0.4, 1, 1.5, 3, 5, 10, 40, 100];

function buildPlinkoPegs() {
    const cont = document.getElementById('plinko-pegs');
    cont.innerHTML = '';
    for(let i=1; i<=PLINKO_ROWS; i++) {
        const row = document.createElement('div'); row.className = 'plinko-row';
        for(let j=0; j<=i; j++) { row.innerHTML += `<div class="plinko-peg"></div>`; }
        cont.appendChild(row);
    }
}

async function playPlinko() {
    const bet = parseInt(document.getElementById('plinko-bet').value);
    if (!bet || bet < 1 || bet > 50000) return alert("Enter bet between 1 and 50,000.");
    if (myPoints < bet) return alert("Not enough points.");

    document.getElementById('plinko-btn').disabled = true;
    await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-bet));

    const board = document.getElementById('plinko-board');
    const ball = document.createElement('div');
    ball.className = 'plinko-ball';
    board.appendChild(ball);

    // Clear any previously active bin highlight
    board.querySelectorAll('.plinko-bin.active-bin').forEach(b => b.classList.remove('active-bin'));

    // Dynamically calculate stepX based on actual board width so ball reaches all bins
    const boardWidth = board.getBoundingClientRect().width || 600;
    const numBins = PLINKO_MULTS.length; // 17
    const binWidth = boardWidth / numBins;
    const stepX = binWidth / 2; // Each peg decision = half a bin width
    const boardHeight = 360;
    const binHeight = 28;
    const stepY = (boardHeight - binHeight - 10) / PLINKO_ROWS;

    // Simulate 50/50 path — strictly Math.random() < 0.5 for left, >= 0.5 for right
    let curX = 0, binIndex = 0;
    const path = [{x: 0, y: 0}];
    for(let r = 1; r <= PLINKO_ROWS; r++) {
        if(Math.random() >= 0.5) { binIndex++; curX += stepX; }
        else { curX -= stepX; }
        path.push({x: curX, y: r * stepY});
    }

    // Single unified rAF loop — eliminates stutter from chained Promises
    const dropDuration = 120; // ms per segment
    const totalDuration = dropDuration * (path.length - 1);

    await new Promise(resolve => {
        const startT = performance.now();
        function step(now) {
            const elapsed = now - startT;
            const globalT = Math.min(elapsed / totalDuration, 1);
            const rawSeg = globalT * (path.length - 1);
            const segIndex = Math.min(Math.floor(rawSeg), path.length - 2);
            const segT = rawSeg - segIndex;

            const p1 = path[segIndex], p2 = path[segIndex + 1];
            // Slight arc via quadratic bezier — control point dips up between pegs
            const cpX = (p1.x + p2.x) / 2;
            const cpY = p1.y - 8;
            const t = segT;
            const x = (1-t)*(1-t)*p1.x + 2*(1-t)*t*cpX + t*t*p2.x;
            const y = (1-t)*(1-t)*p1.y + 2*(1-t)*t*cpY + t*t*p2.y;

            ball.style.transform = `translate(calc(-50% + ${x}px), ${y}px)`;

            if(globalT < 1) requestAnimationFrame(step);
            else resolve();
        }
        requestAnimationFrame(step);
    });

    // Snap ball into the bin
    const finalX = path[path.length - 1].x;
    ball.style.transform = `translate(calc(-50% + ${finalX}px), ${boardHeight - binHeight - 6}px)`;
    await new Promise(r => setTimeout(r, 250));
    ball.remove();

    // Highlight winning bin
    const bins = board.querySelectorAll('.plinko-bin');
    if(bins[binIndex]) bins[binIndex].classList.add('active-bin');

    const multiplier = PLINKO_MULTS[binIndex];
    const win = Math.floor(bet * multiplier);

    const status = document.getElementById('plinko-status');
    status.innerText = `Bin ${binIndex + 1} → ${multiplier}x! Payout: ${win} pts`;
    status.style.color = win > bet ? "#55ff55" : (win === bet ? "#fff" : "#ff5555");

