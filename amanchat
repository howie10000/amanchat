let ctx,drawing=false;
function initCanvas(){
    const c=document.getElementById('pfp-canvas'); ctx=c.getContext('2d');
    ctx.lineWidth=4; ctx.lineCap='round';
    const getP=e=>{const r=c.getBoundingClientRect();return{x:(e.touches?e.touches[0].clientX:e.clientX)-r.left,y:(e.touches?e.touches[0].clientY:e.clientY)-r.top};};
    c.onmousedown=c.ontouchstart=e=>{drawing=true;ctx.strokeStyle=document.getElementById('draw-color').value;ctx.beginPath();const p=getP(e);ctx.moveTo(p.x,p.y);};
    c.onmousemove=c.ontouchmove=e=>{if(drawing){const p=getP(e);ctx.lineTo(p.x,p.y);ctx.stroke();e.preventDefault();}};
    window.onmouseup=c.ontouchend=()=>drawing=false;
    db.ref('users/'+user).once('value', s=>{
        document.getElementById('bio-in').value=s.val().bio||"";
        document.getElementById('opt-in-find').checked=s.val().optIn||false;
        if(s.val().pfp){const img=new Image();img.onload=()=>ctx.drawImage(img,0,0);img.src=s.val().pfp;}
    });
}
function clearDraw(){ctx.clearRect(0,0,180,180);}
function saveProf(){db.ref('users/'+user).update({pfp:document.getElementById('pfp-canvas').toDataURL(),bio:document.getElementById('bio-in').value,optIn:document.getElementById('opt-in-find').checked});alert("Saved!");}

async function viewProf(u) {
    currentViewUser=u;
    const s=await db.ref('users/'+u).once('value'); const uData=s.val();
    
    const profCard = document.querySelector('#modal-profile .modal-card');
    const targetTheme = uData.theme || 'dark';
    const themeData = ALL_THEMES[targetTheme];
    
    if (themeData) {
        profCard.style.setProperty('--primary', themeData.primary || '#00d4ff');
        profCard.style.setProperty('--panel', themeData.panel || 'rgba(22, 22, 22, 0.85)');
        profCard.style.setProperty('--text', themeData.text || '#f0f0f0');
        profCard.style.setProperty('--admin', themeData.admin || '#ff3e3e');

        const bg = themeData.bg || '#0b0b0b';
        if (bg.includes('gradient') || bg.includes('radial')) {
            profCard.style.background = bg;
            if (themeData.animate_bg && !targetTheme.startsWith('mythic_')) {
                profCard.style.backgroundSize = '400% 400%';
                profCard.style.animation = 'gradientBG 15s ease infinite';
            } else {
                profCard.style.backgroundSize = 'auto';
                profCard.style.animation = 'none';
            }
        } else {
            profCard.style.background = 'var(--panel)';
            profCard.style.backgroundSize = 'auto';
            profCard.style.animation = 'none';
        }
    } else {
        profCard.style.background = '';
        profCard.style.animation = '';
        profCard.style.removeProperty('--primary');
        profCard.style.removeProperty('--panel');
        profCard.style.removeProperty('--text');
        profCard.style.removeProperty('--admin');
    }

    const titleId=uData.activeTitle;
    const titleEl=document.getElementById('view-title-display');
    if(titleId&&ALL_TITLES[titleId]){
        const td=ALL_TITLES[titleId];
        titleEl.innerHTML=`<span class="${RARITY_CLASS[td.rarity]||'rc'}">[${td.name}]</span> <span class="rarity-badge ${RARITY_BADGE[td.rarity]||'rb-common'}">${td.rarity}</span>`;
    } else {
        const cerSnap=await db.ref(`users/${u}/ceremonialTitles`).once('value');
        const cer=cerSnap.val()||{}; const cerKeys=Object.keys(cer);
        if(cerKeys.length>0){const td=ALL_TITLES[cerKeys[0]];titleEl.innerHTML=td?`<span class="rcr">[${td.name}]</span> <span class="rarity-badge rb-ceremonial">ceremonial</span>`:'';}
        else titleEl.innerHTML='';
    }
    document.getElementById('view-user').innerText="@"+u;
    document.getElementById('view-bio').innerText=uData.bio||"No bio.";
    document.getElementById('view-pfp').src=uData.pfp||"";
    let rankStr=uData.role.toUpperCase(); if(uData.server_creator) rankStr+=" | CREATOR";
    document.getElementById('view-rank').innerText=rankStr;
    document.getElementById('view-points-display').innerText=`⭐ ${uData.points||0} points earned`;
    const fSnap=await db.ref(`users/${user}/friends/${u}`).once('value');
    const req1=await db.ref(`users/${user}/reqs/${u}`).once('value');
    const req2=await db.ref(`users/${u}/reqs/${user}`).once('value');
    document.getElementById('prof-btn-add').classList.toggle('hidden',(u===user||fSnap.exists()||req1.exists()||req2.exists()));
    document.getElementById('prof-btn-report').classList.toggle('hidden',u===user);
    document.getElementById('prof-btn-trade').classList.toggle('hidden',u===user||!fSnap.exists());
    document.getElementById('modal-profile').classList.remove('hidden');
}
