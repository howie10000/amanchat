            spark.style.animation = `mythicBurst 1s cubic-bezier(0.1, 0.8, 0.2, 1) forwards`;
            spark.style.animationDelay = `${Math.random() * 0.2}s`;
            sparkContainer.appendChild(spark);
        }
    }
}

