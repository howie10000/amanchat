function populateAdminItemList() {
    const type=document.getElementById('adm-give-type').value;
    const sel=document.getElementById('adm-give-item'); sel.innerHTML='';
    const dict=type==='theme'?ALL_THEMES:ALL_TITLES;
    for(const [id,item] of Object.entries(dict)){
        if(type==='theme'&&['free'].includes(item.rarity)) continue;
        const opt=document.createElement('option'); opt.value=id; opt.innerText=`${item.name} (${item.rarity})`;
        sel.appendChild(opt);
    }
}

async function adminGiveItem() {
    const targetUser=document.getElementById('adm-give-user').value.trim(); if(!targetUser) return alert("Enter username.");
    const type=document.getElementById('adm-give-type').value;
    const itemId=document.getElementById('adm-give-item').value; if(!itemId) return alert("Select an item.");
    const isCeremonial=(type==='title'&&ALL_TITLES[itemId]?.rarity==='ceremonial');
    const name=type==='theme'?ALL_THEMES[itemId]?.name:ALL_TITLES[itemId]?.name;
    if(targetUser.toLowerCase()==='all'){
        const usersSnap=await db.ref('users').once('value');
        const updates={};
        usersSnap.forEach(u=>{
            if(isCeremonial) updates[`users/${u.key}/ceremonialTitles/${itemId}`]=true;
            else db.ref(`users/${u.key}/inventory/${type}s/${itemId}`).set(firebase.database.ServerValue.increment(1));
        });
        if(isCeremonial) await db.ref().update(updates);
        return alert(`✅ Gave "${name}" to ALL users!`);
    }
    const exists=(await db.ref('users/'+targetUser).once('value')).exists(); if(!exists) return alert("User not found.");
    if(isCeremonial) await db.ref(`users/${targetUser}/ceremonialTitles/${itemId}`).set(true);
    else await db.ref(`users/${targetUser}/inventory/${type}s/${itemId}`).set(firebase.database.ServerValue.increment(1));
    alert(`✅ Gave "${name}" to @${targetUser}!`);
}

