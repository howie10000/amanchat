async function sendTradeRequest() {
    const partner=document.getElementById('trade-partner-sel').value; if(!partner) return alert("Select a partner.");
    const myPoints_=parseInt(document.getElementById('trade-my-points').value)||0;
    const theirPoints_=parseInt(document.getElementById('trade-their-points').value)||0;
    if(myPoints_>myPoints) return alert("Not enough points!");
    if(tradeMySelected.length===0&&myPoints_===0&&tradeTheirSelected.length===0&&theirPoints_===0) return alert("Trade must include something.");
    const tradeData={from:user,to:partner,fromOffer:{points:myPoints_,items:tradeMySelected},toRequest:{points:theirPoints_,items:tradeTheirSelected},status:'pending',ts:Date.now()};
    const ref=db.ref('trades').push(); await ref.set(tradeData);
    await db.ref(`users/${user}/myTrades/${ref.key}`).set(true);
    await db.ref(`users/${partner}/myTrades/${ref.key}`).set(true);
    closeM('modal-trade-create'); alert("Trade request sent!"); loadTrades();
}

function loadTrades() {
    const activeList=document.getElementById('trade-active-list'); const histList=document.getElementById('trade-history-list');
    activeList.innerHTML=''; histList.innerHTML='';
    db.ref(`users/${user}/myTrades`).once('value', snap=>{
        if(!snap.exists()){activeList.innerHTML='<div style="color:#555;font-size:0.9em;">No active trades.</div>';return;}
        const keys=Object.keys(snap.val()||{});
        if(keys.length===0){activeList.innerHTML='<div style="color:#555;font-size:0.9em;">No active trades.</div>';return;}
        let activeCount=0,histCount=0;
        keys.forEach(async key=>{
            const tSnap=await db.ref(`trades/${key}`).once('value'); if(!tSnap.exists()) return;
            const t=tSnap.val(); const isIncoming=(t.to===user&&t.status==='pending');
            const dateStr=new Date(t.ts).toLocaleDateString();
            const fromOffer=renderTradeItems(t.fromOffer); const toReq=renderTradeItems(t.toRequest);
            if(t.status==='pending'){
                activeCount++;
                const card=document.createElement('div'); card.className='trade-card pending';
                card.innerHTML=`<div style="font-size:0.85em;color:#aaa;margin-bottom:8px;">${isIncoming?`📨 From <strong>@${t.from}</strong>`:`📤 To <strong>@${t.to}</strong>`} · ${dateStr}</div>
                    <div style="display:flex;gap:10px;margin-bottom:10px;"><div class="trade-side"><div style="font-size:0.8em;color:#ff9900;margin-bottom:4px;">They Offer:</div>${fromOffer}</div><div class="trade-side"><div style="font-size:0.8em;color:var(--primary);margin-bottom:4px;">They Want:</div>${toReq}</div></div>
                    ${isIncoming?`<div style="display:flex;gap:8px;"><button class="btn primary" style="flex:1;padding:6px;" onclick="viewTradeModal('${key}')">View Trade</button></div>`:`<div style="font-size:0.8em;color:#aaa;">Awaiting response...</div><button class="btn" style="margin-top:6px;padding:5px 10px;background:rgba(0,0,0,0.5);color:var(--admin);font-size:0.8em;" onclick="cancelTrade('${key}')">Cancel</button>`}`;
                activeList.appendChild(card);
            } else {
                histCount++;
                const statusColor=t.status==='accepted'?'#00ff88':'#ff5555';
                const card=document.createElement('div'); card.className=`trade-card ${t.status}`;
                card.innerHTML=`<div style="font-size:0.82em;color:#aaa;margin-bottom:5px;">With @${t.from===user?t.to:t.from} · ${dateStr} · <span style="color:${statusColor};font-weight:bold;">${t.status.toUpperCase()}</span></div><div style="display:flex;gap:8px;flex-wrap:wrap;">${fromOffer}${toReq}</div>`;
                histList.appendChild(card);
            }
        });
        setTimeout(()=>{if(activeCount===0)activeList.innerHTML='<div style="color:#555;font-size:0.9em;">No active trades.</div>';if(histCount===0)histList.innerHTML='<div style="color:#555;font-size:0.9em;">No trade history.</div>';},500);
    });
}

function renderTradeItems(offer) {
    if(!offer) return '<span style="color:#555;font-size:0.8em;">Nothing</span>';
    let html='';
    if(offer.points>0) html+=`<span class="trade-item-chip">✨ ${offer.points} pts</span>`;
    (offer.items||[]).forEach(item=>{
        let data;
        if(item.type==='theme') data=ALL_THEMES[item.id];
        else if(item.type==='lootbox') { const lb=LOOTBOXES.find(x=>x.id===item.id); data=lb?{name:lb.name,rarity:'common'}:null; }
        else data=ALL_TITLES[item.id];
        const icon=item.type==='theme'?'🎨':item.type==='lootbox'?'📦':'🏷️';
        if(data) html+=`<span class="trade-item-chip ${RARITY_CLASS[data.rarity]||'rc'}">${icon} ${data.name}</span>`;
    });
    return html||'<span style="color:#555;font-size:0.8em;">Nothing</span>';
}

