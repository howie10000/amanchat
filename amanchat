function getThemeSwatch(id, data) {
    const sw = data.swatch || data.primary || '#333';
    return sw.includes('gradient') ? (data.primary || '#333') : sw;
}

function renderInvThemes(themes) {
    const grid=document.getElementById('inv-themes-grid'); grid.innerHTML='';
    const ownedIds = new Set(Object.keys(themes));

    for(const [id,count] of Object.entries(themes)) {
        const td=ALL_THEMES[id]; if(!td) continue;
        const isActive=myActiveTheme===id;
        const sw=getThemeSwatch(id,td);
        const div=document.createElement('div');
        div.className=`inv-item ic-${td.rarity}`;
        div.style.border=`2px solid ${isActive?'var(--primary)':'rgba(255,255,255,0.1)'}`;
        div.innerHTML=`<div class="theme-swatch" style="background:${sw};"></div>
            ${count>1?`<div class="inv-badge">${count}</div>`:''}
            <div style="font-size:0.85em; font-weight:bold; margin-bottom:4px; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${td.name}</div>
            <div class="rarity-badge ${RARITY_BADGE[td.rarity]||'rb-common'}" style="margin-bottom:8px;">${td.rarity}</div>
            ${isActive?`<button class="btn" style="width:100%; padding:5px; background:rgba(0,0,0,0.5); font-size:0.75em;" disabled>Equipped</button>`
                      :`<button class="btn primary" style="width:100%; padding:5px; font-size:0.75em;" onclick="setTheme('${id}'); loadInventory();">Equip</button>`}`;
        grid.appendChild(div);
    }

    ['dark','light'].forEach(id => {
        if(!ownedIds.has(id)) {
            const td=ALL_THEMES[id]; if(!td) return;
            const sw=getThemeSwatch(id,td);
            const div=document.createElement('div');
            div.className='inv-item'; div.style.border='2px solid rgba(255,255,255,0.1)';
            div.innerHTML=`<div class="theme-swatch" style="background:${sw};"></div>
                <div style="font-size:0.85em; font-weight:bold; margin-bottom:4px; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${td.name}</div>
                <div class="rarity-badge rb-free" style="margin-bottom:8px;">Free</div>
                <button class="btn primary" style="width:100%; padding:5px; font-size:0.75em;" onclick="setTheme('${id}'); loadInventory();">Equip</button>`;
            grid.appendChild(div);
        }
    });

    if(grid.children.length===0) grid.innerHTML='<p style="color:#555;">No themes in inventory. Open lootboxes!</p>';
}

