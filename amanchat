function renderInvLootboxes(boxes) {
    const grid = document.getElementById('inv-lootboxes-grid'); grid.innerHTML = '';
    let count = 0;
    for(const [id, qty] of Object.entries(boxes)) {
        if(qty < 1) continue;
        count++;
        const lbData = LOOTBOXES.find(x => x.id === id);
        if(!lbData) continue;
        const div = document.createElement('div');
        div.className = `inv-item ${lbData.card}`;
        div.innerHTML = `
            <div class="inv-badge">${qty}</div>
            <div style="font-size:3em; margin-bottom:5px;">${lbData.icon}</div>
            <div style="font-size:0.85em; font-weight:bold;">${lbData.name}</div>
