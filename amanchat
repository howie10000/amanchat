async function revealLootResult() {
    const lb=LOOTBOXES[pendingLootboxIndex];
    if (openingFromInventory) {
        await db.ref(`users/${user}/inventory/lootboxes/${lb.id}`).set(firebase.database.ServerValue.increment(-1));
    } else {
        await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-lb.cost));
    }

    const r=Math.random(); let rarity;
    
    if(r < lb.rates.mythic || 0) rarity = 'mythic';
    else if(r < (lb.rates.mythic||0) + lb.rates.legendary) rarity = 'legendary';
    else if(r < (lb.rates.mythic||0) + lb.rates.legendary + lb.rates.epic) rarity = 'epic';
    else if(r < (lb.rates.mythic||0) + lb.rates.legendary + lb.rates.epic + lb.rates.rare) rarity = 'rare';
    else rarity = 'common';

    const pool=LOOT_POOL[rarity];
    if(!pool||pool.length===0) { alert(`No items in ${rarity} pool yet!`); closeM('lootbox-open-modal'); return; }
    
    const item=pool[Math.floor(Math.random()*pool.length)];
    pendingLootResult=item;
    let isDupe=false;
    
    if(item.type==='theme') { 
        const existing=(myInventory.themes&&myInventory.themes[item.id])||0; 
        isDupe=existing>0; 
        await db.ref(`users/${user}/inventory/themes/${item.id}`).set(firebase.database.ServerValue.increment(1)); 
    } else { 
        const existing=(myInventory.titles&&myInventory.titles[item.id])||0; 
        isDupe=existing>0; 
        await db.ref(`users/${user}/inventory/titles/${item.id}`).set(firebase.database.ServerValue.increment(1)); 
    }
    
    const icons={common:'⬜',rare:'🔷',epic:'🟣',legendary:'🌟',mythic:'🔮'};
    document.getElementById('lb-opening-phase').classList.add('hidden');
    document.getElementById('lb-result-phase').classList.remove('hidden');
    document.getElementById('lb-result-icon').innerText=item.type==='theme'?'🎨':'🏷️';
    document.getElementById('lb-result-rarity').innerHTML=`<span class="rarity-badge ${RARITY_BADGE[rarity]}">${icons[rarity]} ${rarity.toUpperCase()}</span>`;
    document.getElementById('lb-result-name').innerHTML=`<span class="${RARITY_CLASS[rarity]}">${item.name}</span>`;
    document.getElementById('lb-result-type').innerText=item.type==='theme'?'🎨 Theme':'🏷️ Title';
    document.getElementById('lb-dupe-notice').classList.toggle('hidden',!isDupe);
    document.getElementById('lb-open-title').innerText=`You got a ${rarity.toUpperCase()} item!`;
    document.getElementById('lb-tap-btn').disabled=false;

    const sparkContainer = document.getElementById('lb-sparkle-container');
    sparkContainer.innerHTML = '';
    if (rarity === 'mythic') {
        for(let i=0; i<40; i++) {
            const spark = document.createElement('div');
