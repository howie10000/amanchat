function applyThemePreviewVars() {
    const primary = document.getElementById('adm-th-primary').value.trim() || '#00d4ff';
    const bg      = document.getElementById('adm-th-bg').value.trim()      || '#0b0b0b';
    const panel   = document.getElementById('adm-th-panel').value.trim()   || 'rgba(22,22,22,0.85)';
    const sidebar = document.getElementById('adm-th-sidebar').value.trim() || 'rgba(17,17,17,0.85)';
    const text    = document.getElementById('adm-th-text').value            || '#f0f0f0';
    const msgBg   = document.getElementById('adm-th-msg').value.trim()     || 'rgba(34,34,34,0.85)';
    const msgMe   = document.getElementById('adm-th-msgme').value.trim()   || 'rgba(0,75,90,0.85)';

    const container = document.getElementById('preview-container');
    container.style.setProperty('--prev-primary', primary);
    container.style.setProperty('--prev-bg',      bg);
    container.style.setProperty('--prev-panel',   panel);
    container.style.setProperty('--prev-sidebar', sidebar);
    container.style.setProperty('--prev-text',    text);
    container.style.setProperty('--prev-msg-bg',  msgBg);
    container.style.setProperty('--prev-msg-me',  msgMe);
}

function livePreviewTheme() {
    // Only update live if the preview modal is already open
    const modal = document.getElementById('modal-theme-preview');
    if(!modal.classList.contains('hidden')) applyThemePreviewVars();
}

function previewAdminTheme() {
    applyThemePreviewVars();
    document.getElementById('modal-theme-preview').classList.remove('hidden');
}

async function adminCreateTheme() {
    const id = document.getElementById('adm-new-th-id').value.trim();
    if(!id) return alert("Requires an ID");

    let finalBg = document.getElementById('adm-th-bg').value.trim();
    if (finalBg.includes(',') && !finalBg.includes('gradient')) {
        finalBg = `linear-gradient(45deg, ${finalBg})`;
    }
    
    let finalSwatch = document.getElementById('adm-th-swatch').value.trim();
    if (finalSwatch.includes(',') && !finalSwatch.includes('gradient')) {
        finalSwatch = `linear-gradient(45deg, ${finalSwatch})`;
    }
    
    const themeData = {
        name: document.getElementById('adm-new-th-name').value.trim() || id,
        rarity: document.getElementById('adm-new-th-rarity').value,
        primary: document.getElementById('adm-th-primary').value,
        bg: finalBg,
        panel: document.getElementById('adm-th-panel').value,
        sidebar: document.getElementById('adm-th-sidebar').value,
        text: document.getElementById('adm-th-text').value,
        msg_bg: document.getElementById('adm-th-msg').value,
        msg_me: document.getElementById('adm-th-msgme').value,
        swatch: finalSwatch,
        expired: false,
        animate_bg: document.getElementById('adm-th-anim').checked
    };
    
    await db.ref(`config/themes/${id}`).set(themeData);
    alert(`Theme ${id} pushed to Database! It is instantly live in the lootbox pool.`);
    
    document.getElementById('adm-new-th-id').value = '';
    document.getElementById('adm-new-th-name').value = '';
}

async function adminCreateTitle() {
    const id = document.getElementById('adm-new-ti-id').value.trim();
    if(!id) return alert("Requires an ID");
    
    const titleData = {
        name: document.getElementById('adm-new-ti-name').value.trim() || id,
        rarity: document.getElementById('adm-new-ti-rarity').value,
        tradeable: document.getElementById('adm-new-ti-trade').value === 'true'
    };
    
    await db.ref(`config/titles/${id}`).set(titleData);
    alert(`Title ${id} created and live!`);
    
    document.getElementById('adm-new-ti-id').value = '';
    document.getElementById('adm-new-ti-name').value = '';
}

async function adminLaunchEvent() {
    const id = document.getElementById('adm-ev-id').value.trim();
    if(!id) return alert("Requires Event ID");
    
    const evData = {
        name: document.getElementById('adm-ev-name').value.trim(),
        description: document.getElementById('adm-ev-desc').value.trim(),
        rewardType: document.getElementById('adm-ev-type').value,
        rewardId: document.getElementById('adm-ev-reward-id').value.trim(),
        isActive: true,
        color: '#ff4500' 
    };
    
    await db.ref(`system/events/${id}`).set(evData);
    alert(`Event ${id} is now live globally!`);
    
    document.getElementById('adm-ev-id').value = '';
    document.getElementById('adm-ev-name').value = '';
    document.getElementById('adm-ev-desc').value = '';
    document.getElementById('adm-ev-reward-id').value = '';
}
