function dismissLoadingScreen(msg) {
    const ls = document.getElementById('loading-screen');
    if(!ls) return;
    // Already dismissed — don't flicker
    if(ls.dataset.dismissed === '1') return;
    ls.dataset.dismissed = '1';
    if(msg) {
        const p = document.getElementById('loading-msg') || ls.querySelector('p');
        if(p) { p.innerText = msg; p.style.color = '#aaa'; }
    }
    ls.style.transition = 'opacity 0.4s ease';
    ls.style.opacity = '0';
    setTimeout(() => {
        ls.style.display = 'none';
        ls.style.pointerEvents = 'none';
    }, 420);
}

window.addEventListener('load', () => {
    // Safety net fires first — NOTHING can prevent this from running
    const hardCap = setTimeout(() => dismissLoadingScreen('Ready (offline mode)'), 4000);

    // Wrap game builders — a crash here must not block startup
    try { buildPlinkoBoard(); } catch(e) { console.warn('buildPlinkoBoard:', e); }
    try { buildRouletteBoard(); } catch(e) { console.warn('buildRouletteBoard:', e); }

    // Load DB config fully in background — UI is never blocked on this
    loadDBConfig()
        .then(() => {
            clearTimeout(hardCap);
            dismissLoadingScreen();
        })
        .catch(e => {
            clearTimeout(hardCap);
            console.warn('DB config load failed:', e);
            dismissLoadingScreen('Loaded (limited connectivity)');
        });
