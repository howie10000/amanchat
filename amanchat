async function withTimeout(promise, ms) {
    return Promise.race([
        promise,
        new Promise((_, reject) => setTimeout(() => reject(new Error('DB timeout')), ms))
    ]);
}

async function loadDBConfig() {
    try {
        const [themesSnap, titlesSnap] = await withTimeout(
            Promise.all([
                db.ref('config/themes').once('value'),
                db.ref('config/titles').once('value')
            ]),
            6000
        );
        ALL_THEMES = themesSnap.val() || {};
        ALL_TITLES = titlesSnap.val() || {};
    } catch(e) {
        console.warn('loadDBConfig: DB fetch failed or timed out:', e.message);
        ALL_THEMES = {}; ALL_TITLES = {};
    }

    try { await seedMythics(); } catch(e) { console.warn('seedMythics failed:', e.message); }

    for(const [id, data] of Object.entries(ALL_THEMES)) {
        try { injectThemeCSS(id, data); } catch(e) {}
    }

    buildLootPool();
    configLoaded = true;

    // Real-time listeners — failures here are non-fatal
    try {
        db.ref('config/themes').on('child_added', snap => { ALL_THEMES[snap.key] = snap.val(); injectThemeCSS(snap.key, snap.val()); buildLootPool(); });
        db.ref('config/themes').on('child_changed', snap => { ALL_THEMES[snap.key] = snap.val(); const oldStyle = document.getElementById(`theme-style-${snap.key}`); if(oldStyle) oldStyle.remove(); injectThemeCSS(snap.key, snap.val()); buildLootPool(); });
        db.ref('config/titles').on('child_added', snap => { ALL_TITLES[snap.key] = snap.val(); buildLootPool(); });
        db.ref('config/titles').on('child_changed', snap => { ALL_TITLES[snap.key] = snap.val(); buildLootPool(); });
    } catch(e) { console.warn('Realtime listeners failed:', e.message); }
}

