// --- ROULETTE (MATH DOM GENERATION) ---
let rlCurrentChip = 10;
let rlBets = {}; 
let rlSpinning = false;
const ROULETTE_ORDER = [0, 32, 15, 19, 4, 21, 2, 25, 17, 34, 6, 27, 13, 36, 11, 30, 8, 23, 10, 5, 24, 16, 33, 1, 20, 14, 31, 9, 22, 18, 29, 7, 28, 12, 35, 3, 26];
const RL_REDS = [1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36];

function buildRouletteBoard() {
    const wheel = document.getElementById('rl-wheel');
    const anglePerWedge = 360 / 37;
    
    ROULETTE_ORDER.forEach((num, idx) => {
        const wedge = document.createElement('div');
        const isRed = RL_REDS.includes(num);
        const color = num === 0 ? '#008800' : (isRed ? '#cc0000' : '#111');
        
        wedge.className = 'rl-wedge';
        wedge.style.transform = `rotate(${idx * anglePerWedge}deg) skewY(${-(90 - anglePerWedge)}deg)`;
        wedge.style.backgroundColor = color;
        
        const textWrapper = document.createElement('span');
        textWrapper.innerText = num;
        // Un-skew the text, then rotate it to face outward from wheel center, then nudge into readable position
        const unskew = 90 - anglePerWedge;
        const centerAngle = anglePerWedge / 2;
        textWrapper.style.transform = `skewY(${unskew}deg) rotate(${centerAngle}deg) translate(6px, 5px)`;
        
        wedge.appendChild(textWrapper);
        wheel.appendChild(wedge);
    });

    const board = document.getElementById('rl-board');
    let html = '';
    for(let i=1; i<=36; i++) {
        const isRed = RL_REDS.includes(i);
        const col = isRed ? 'rl-red' : 'rl-black';
        const r = ((i-1) % 3) + 1;
        const c = Math.floor((i-1) / 3) + 2; 
        html += `<div class="rl-spot ${col}" style="grid-row:${r}; grid-column:${c};" onclick="placeRlBet('${i}')">${i}<div class="rl-chip hidden" id="rl-chip-${i}"></div></div>`;
    }
    const outsideHTML = document.querySelector('.rl-outside').outerHTML;
    document.querySelector('.rl-outside').remove();
    board.innerHTML += html + outsideHTML;
}

function setRlChip(val) { rlCurrentChip = val; document.getElementById('rl-current-chip').innerText = val; }

function placeRlBet(spot) {
    if(rlSpinning) return;
    const totalBet = Object.values(rlBets).reduce((a,b)=>a+b, 0) + rlCurrentChip;
    if(totalBet > myPoints) return alert("Not enough points to place this bet.");
    if(totalBet > 50000) return alert("Table max bet is 50,000.");
    
    rlBets[spot] = (rlBets[spot] || 0) + rlCurrentChip;
    const chipEl = document.getElementById(`rl-chip-${spot}`);
    chipEl.innerText = rlBets[spot] > 999 ? (rlBets[spot]/1000).toFixed(1)+'k' : rlBets[spot];
    chipEl.classList.remove('hidden');
    
    document.getElementById('rl-status').innerText = `Total Bet: ${totalBet}`;
    document.getElementById('rl-status').style.color = '#fff';
}

function clearRlBets() {
    if(rlSpinning) return;
    rlBets = {};
    document.querySelectorAll('.rl-chip').forEach(el => { el.classList.add('hidden'); el.innerText=''; });
    document.getElementById('rl-status').innerText = `Total Bet: 0`;
}

async function spinRoulette() {
    if(rlSpinning) return;
    const totalBet = Object.values(rlBets).reduce((a,b)=>a+b, 0);
    if(totalBet === 0) return alert("Place a bet first!");
    if(totalBet > myPoints) { clearRlBets(); return alert("You don't have enough points for these bets."); }

    rlSpinning = true;
    document.getElementById('rl-spin-btn').disabled = true;
    await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-totalBet));

    document.getElementById('rl-status').innerText = "Spinning...";

    const resultNum = Math.floor(Math.random() * 37); 
    const targetIndex = ROULETTE_ORDER.indexOf(resultNum);
    const anglePerWedge = 360 / 37;
    
    const baseAngle = 360 - (targetIndex * anglePerWedge) - (anglePerWedge/2); 
    const extraSpins = 5 * 360; 
    const finalRot = extraSpins + baseAngle;

    const wheel = document.getElementById('rl-wheel');
    wheel.style.transform = `rotate(${finalRot}deg)`;

    await new Promise(r => setTimeout(r, 4000));
    
    wheel.style.transition = 'none';
    wheel.style.transform = `rotate(${baseAngle}deg)`;
    void wheel.offsetWidth;
    wheel.style.transition = 'transform 4s cubic-bezier(0.15, 0.85, 0.1, 1)';

    let totalWin = 0;
    for(const [spot, amount] of Object.entries(rlBets)) {
        if(spot === String(resultNum)) totalWin += amount * 36;
        else if (resultNum !== 0) {
            const isRed = RL_REDS.includes(resultNum);
            const isEven = resultNum % 2 === 0;
            if(spot === 'red' && isRed) totalWin += amount * 2;
            if(spot === 'black' && !isRed) totalWin += amount * 2;
            if(spot === 'even' && isEven) totalWin += amount * 2;
            if(spot === 'odd' && !isEven) totalWin += amount * 2;
        }
    }

    const isRedResult = resultNum !== 0 && RL_REDS.includes(resultNum);
    const colorStr = resultNum === 0 ? '🟢 Green' : (isRedResult ? '🔴 Red' : '⚫ Black');

    const status = document.getElementById('rl-status');
    const payoutStr = totalWin > 0 ? `Payout: ${totalWin} pts` : `Lost: ${totalBet} pts`;
    if(totalWin > 0) {
        status.innerHTML = `<span style="font-size:1.2em;">🎉 Result: <strong>${resultNum}</strong> ${colorStr} — ${payoutStr}</span>`;
        status.style.color = '#55ff55';
        await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(totalWin));
    } else {
        status.innerHTML = `<span style="font-size:1.2em;">Result: <strong>${resultNum}</strong> ${colorStr} — ${payoutStr}</span>`;
        status.style.color = '#ff5555';
    }

    // Hold result for 3 seconds before allowing a new spin
    await new Promise(r => setTimeout(r, 3000));

    rlSpinning = false;
    document.getElementById('rl-spin-btn').disabled = false;
    clearRlBets();
    status.style.fontSize = '';
}

