async function openChat(type,id,name,owner) {
    if(aId) db.ref(getPath()+'/msgs').off();
    if(aType==='srv') db.ref(`servers/${aId}/typing`).off();
    aId=id; aType=type; aSrvOwner=owner; markRead(type,id);
    
    if (type === 'none') return; 

    document.getElementById('header-text').innerText=type==='dm'?"@"+name:name;
    document.getElementById('show-code-btn').classList.add('hidden');
    document.getElementById('srv-mod-btn').classList.add('hidden');
    document.getElementById('del-srv-btn').classList.add('hidden');
    document.getElementById('readonly-overlay').classList.add('hidden');
    document.getElementById('chat-controls').classList.remove('hidden');
    
    if(type==='srv') {
        const isBanned=(await db.ref(`servers/${id}/banned/${user}`).once('value')).exists();
        if(isBanned){alert("You have been banned from this server.");tab('chat');return;}
        
        document.getElementById('channel-controls').classList.remove('hidden');
        document.getElementById('member-sidebar').classList.remove('hidden');
        
        const sInfo=await db.ref(`servers/${id}`).once('value'); const sData=sInfo.val();
        aMyRole=(await db.ref(`servers/${id}/roles/${user}`).once('value')).val()||'user';
        
        const isOwner = (aMyRole==='owner' || user===aSrvOwner);
        const isSuperAdmin = (user === 'Howard');
        
        document.getElementById('add-chan-btn').classList.toggle('hidden',!isOwner);
        document.getElementById('srv-mod-btn').classList.toggle('hidden',!isOwner);
        document.getElementById('del-srv-btn').classList.toggle('hidden', !((isOwner || isSuperAdmin) && !sData.isOfficial)); 
        
        aIsAnnouncements=sData.isAnnouncements;
        if(aIsAnnouncements&&user!=='Howard'&&user!=='Aman'){document.getElementById('chat-controls').classList.add('hidden');document.getElementById('readonly-overlay').classList.remove('hidden');}
        
        aChan=sData.isOfficial?(aIsAnnouncements?'announcements':'chat-1'):'general';
        
        if(sData.priv&&aSrvOwner===user){const codeBtn=document.getElementById('show-code-btn');codeBtn.classList.remove('hidden');codeBtn.onclick=()=>openCodeModal(sData.code);}
        
        loadChannels(); trackSrvMembers();
        db.ref(`servers/${id}/typing`).on('value', s=>{const arr=[];s.forEach(c=>{if(c.val()&&c.key!==user)arr.push(c.key);});document.getElementById('typing-indicator').innerText=arr.length?arr.join(', ')+" is typing...":"";});
    } else {
        aChan='general'; aIsAnnouncements=false;
        document.getElementById('channel-controls').classList.add('hidden');
        document.getElementById('member-sidebar').classList.add('hidden');
        document.getElementById('typing-indicator').innerText="";
    }
    loadMessages();
}
function openCodeModal(code){document.getElementById('display-code-val').innerText=code;document.getElementById('modal-code').classList.remove('hidden');}
function loadChannels() {
    const sel=document.getElementById('channel-select');
    db.ref(`servers/${aId}/channels`).on('value', s=>{
        sel.innerHTML=""; if(!s.exists()){sel.innerHTML="<option value='general'>#general</option>";return;}
        s.forEach(c=>{const opt=document.createElement('option');opt.value=c.key;opt.innerText="#"+c.key;if(c.key===aChan)opt.selected=true;sel.appendChild(opt);});
    });
}
function switchChannel(c){db.ref(getPath()+'/msgs').off();aChan=c;loadMessages();markRead(aType,aId);}
function openAddChannel(){document.getElementById('chan-name-in').value="";document.getElementById('modal-add-chan').classList.remove('hidden');}
function executeAddChannel() {
    const n=document.getElementById('chan-name-in').value.trim();
    if(n&&/^[a-zA-Z0-9\-]+$/.test(n)){db.ref(`servers/${aId}/channels/${n}/created`).set(true);closeM('modal-add-chan');switchChannel(n);}
    else alert("Invalid name.");
}

