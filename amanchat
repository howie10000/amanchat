function loadMessages() {
    document.getElementById('msg-history').innerHTML="";
    db.ref(getPath()+'/msgs').limitToLast(50).on('child_added', s=>{
        const m=s.val(); const msgId=s.key;
        const div=document.createElement('div');
        div.id=`msg-${msgId}`; div.className=`msg ${m.u===user?'me':''}`;
        const timeStr=new Date(m.ts).toLocaleString([],{hour:'2-digit',minute:'2-digit',month:'numeric',day:'numeric'});
        let delBtn='';
        if(m.u===user||aMyRole==='owner'||aMyRole==='mod'||role==='admin') delBtn=`<span class="del-msg" onclick="delMsg('${msgId}')">×</span>`;
        let content=m.type==='image'?`<img src="${m.t}" onclick="window.open('${m.t}')">` : `<span>${m.t}</span>`;
        div.innerHTML=`<div class="msg-info"><span onclick="viewProf('${m.u}')">@${m.u}<span class="msg-title" id="msgtitle-${msgId}"></span></span><span style="display:flex;align-items:center;gap:5px;"><span class="msg-ts">${timeStr}</span>${delBtn}</span></div>${content}`;
        document.getElementById('msg-history').appendChild(div);
        document.getElementById('msg-history').scrollTop=document.getElementById('msg-history').scrollHeight;
        if(m.u!==user) markRead(aType,aId);
        loadMsgUserTitle(m.u,msgId);
    });
    db.ref(getPath()+'/msgs').on('child_removed', s=>{const el=document.getElementById(`msg-${s.key}`);if(el)el.remove();});
}

async function loadMsgUserTitle(u,msgId) {
    const titleEl=document.getElementById(`msgtitle-${msgId}`); if(!titleEl) return;
    const snap=await db.ref(`users/${u}/activeTitle`).once('value');
    const titleId=snap.val();
    if(titleId){const td=ALL_TITLES[titleId];if(td)titleEl.innerHTML=` <span class="${RARITY_CLASS[td.rarity]||'rc'}" style="font-size:0.72em;">[${td.name}]</span>`;}
}

async function send() {
    const i=document.getElementById('msg-in'); const t=i.value.trim(); if(!t) return;
    const meSnap=await db.ref('users/'+user).once('value');
    if(meSnap.val().mutedUntil&&meSnap.val().mutedUntil>Date.now()) return alert(`Globally muted for ${Math.ceil((meSnap.val().mutedUntil-Date.now())/(1000*60*60))} more hours.`);
    if(aType==='srv'){const srvMute=await db.ref(`servers/${aId}/muted/${user}`).once('value');if(srvMute.exists()&&srvMute.val()>Date.now()) return alert(`Muted in this server.`);}
    if(t.startsWith('/mod ')&&aMyRole==='owner'){db.ref(`servers/${aId}/roles/${t.split(' ')[1]}`).set('mod');i.value="";return alert("Promoted!");}
    db.ref(getPath()+'/msgs').push({u:user,t:t,type:'text',ts:Date.now()});
    addMessagePoint();
    if(aType==='dm') db.ref(`users/${aId}/unread/dms/${user}`).set(true);
    if(aType==='srv'){db.ref(`servers/${aId}/active`).once('value',active=>{active.forEach(u=>{if(u.key!==user)db.ref(`users/${u.key}/unread/servers/${aId}`).set(true);});});}
    i.value=""; if(aType==='srv') db.ref(`servers/${aId}/typing/${user}`).remove();
}
function markTyping(){if(aType!=='srv')return;db.ref(`servers/${aId}/typing/${user}`).set(true);clearTimeout(typingTimeout);typingTimeout=setTimeout(()=>db.ref(`servers/${aId}/typing/${user}`).remove(),2000);}
function delMsg(mid){db.ref(`${getPath()}/msgs/${mid}`).remove();}

function trackSrvMembers() {
    db.ref(`servers/${aId}/active/${user}`).set(true); db.ref(`servers/${aId}/active/${user}`).onDisconnect().remove();
    db.ref(`servers/${aId}/active`).on('value', s=>{
        const l=document.getElementById('member-list'); l.innerHTML="";
        s.forEach(u=>{
            db.ref(`servers/${aId}/roles/${u.key}`).once('value', rs=>{
                const r=rs.val()||'User';
                l.innerHTML+=`<div class="list-item" onclick="viewProf('${u.key}')" style="font-size:0.9em;padding:8px;"><span><span class="status-dot status-online"></span>${u.key}</span><small style="color:var(--primary);">[${r.toUpperCase()}]</small></div>`;
            });
        });
    });
}

