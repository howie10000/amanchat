// ── Hand evaluator ───────────────────────────────────────────────
function pokerEvalHand(cards) {
    // Get best 5-card hand from up to 7 cards
    const combos = getCombinations(cards, 5);
    let best = null;
    combos.forEach(c => {
        const ev = evalFive(c);
        if(!best || pokerCompare(ev,best)>0) best=ev;
    });
    return best || {score:0,name:'High Card',tiebreak:[]};
}

function getCombinations(arr, k) {
    if(k===arr.length) return [arr];
    if(k===1) return arr.map(e=>[e]);
    const result=[];
    for(let i=0;i<=arr.length-k;i++) {
        getCombinations(arr.slice(i+1),k-1).forEach(c=>result.push([arr[i],...c]));
    }
    return result;
}

function evalFive(cards) {
    const vals = cards.map(c=>RANK_VAL[c.r]||parseInt(c.r)).sort((a,b)=>b-a);
    const suits = cards.map(c=>c.s);
    const flush = suits.every(s=>s===suits[0]);
    const straight = vals.every((v,i)=>i===0||vals[i-1]-v===1) ||
                     (vals[0]===14&&vals[1]===5&&vals[2]===4&&vals[3]===3&&vals[4]===2); // A-2-3-4-5
    const counts = {};
    vals.forEach(v=>{counts[v]=(counts[v]||0)+1;});
    const groups = Object.values(counts).sort((a,b)=>b-a);

    let score, name;
    if(flush&&straight&&vals[0]===14&&vals[1]===13)   { score=9; name='Royal Flush'; }
    else if(flush&&straight)                           { score=8; name='Straight Flush'; }
    else if(groups[0]===4)                             { score=7; name='Four of a Kind'; }
    else if(groups[0]===3&&groups[1]===2)              { score=6; name='Full House'; }
    else if(flush)                                     { score=5; name='Flush'; }
    else if(straight)                                  { score=4; name='Straight'; }
    else if(groups[0]===3)                             { score=3; name='Three of a Kind'; }
    else if(groups[0]===2&&groups[1]===2)              { score=2; name='Two Pair'; }
    else if(groups[0]===2)                             { score=1; name='One Pair'; }
    else                                               { score=0; name='High Card'; }
    return {score, name, tiebreak:vals};
}

function pokerCompare(a,b) {
    if(a.score!==b.score) return a.score-b.score;
    for(let i=0;i<Math.max(a.tiebreak.length,b.tiebreak.length);i++) {
        const diff=(a.tiebreak[i]||0)-(b.tiebreak[i]||0);
        if(diff!==0) return diff;
    }
    return 0;
}

