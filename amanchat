const PLINKO_MULTS = [100,40,10,5,3,1.5,1,0.4,0.2,0.4,1,1.5,3,5,10,40,100];

function buildPlinkoBoard() {
    buildPlinkoPegs();
    const binsEl = document.querySelector('.plinko-bins');
    if (!binsEl) return;
    binsEl.innerHTML = '';
    const mid = Math.floor(PLINKO_MULTS.length / 2);
    PLINKO_MULTS.forEach((m, i) => {
        const d = document.createElement('div');
        d.className = 'plinko-bin';
        const dist = Math.abs(i - mid);
        if (dist >= 7)      d.style.background = 'rgba(255,180,0,0.35)';
        else if (dist >= 5) d.style.background = 'rgba(255,120,0,0.25)';
        else if (dist >= 3) d.style.background = 'rgba(180,60,0,0.2)';
        else if (dist === 0) d.style.background = 'rgba(220,0,0,0.35)';
        d.textContent = m >= 1 ? `${m}x` : `${m}x`;
        binsEl.appendChild(d);
    });
}

function buildPlinkoPegs() {
    const cont = document.getElementById('plinko-pegs');
    cont.innerHTML = '';
    for (let i = 1; i <= PLINKO_ROWS; i++) {
        const row = document.createElement('div');
        row.className = 'plinko-row';
        for (let j = 0; j <= i; j++) {
            row.innerHTML += `<div class="plinko-peg"></div>`;
        }
        cont.appendChild(row);
    }
}

function buildPlinkoPath(boardWidth) {
    // A Galton board: PLINKO_ROWS rows of pegs → PLINKO_ROWS+1 = 17 slots
    // Slot 0 = far left, slot 16 = far right, slot 8 = center
    // Ball starts at center (slot 8) and deflects left or right at each peg

    const numBins   = PLINKO_MULTS.length; // 17
    const binWidth  = boardWidth / numBins;
    const boardH    = 520;
    const binH      = 22;
    const usableH   = boardH - binH - 16;
    const stepY     = usableH / PLINKO_ROWS;

    // slot tracks which gap between pegs the ball is in (0..numBins-1)
    let slot = Math.floor(numBins / 2); // start center = 8

    // path stores {x, y} where x is ABSOLUTE pixels from left edge of board
    const path = [];
    path.push({ x: slot * binWidth + binWidth / 2, y: 0 });

    for (let row = 0; row < PLINKO_ROWS; row++) {
        if (Math.random() < 0.5) {
            slot += 1; // deflect right
        }
        // deflect left = slot stays same
        // After row deflections, slot ranges from 0..row+1
        // Clamp to valid range just in case
        slot = Math.max(0, Math.min(slot, numBins - 1));
        const x = slot * binWidth + binWidth / 2;
        const y = (row + 1) * stepY;
        path.push({ x, y });
    }

    // Final bin is wherever slot ended up
    const binIndex = Math.max(0, Math.min(slot, numBins - 1));
    path.push({ x: binIndex * binWidth + binWidth / 2, y: usableH });

    return { path, binIndex, boardH, binH };
}

function animatePlinkoBall(board, path, binIndex, boardH, binH) {
    return new Promise(resolve => {
        const ball = document.createElement('div');
        ball.className = 'plinko-ball';
        board.appendChild(ball);

        const boardWidth = board.getBoundingClientRect().width || 600;
        const totalSteps = path.length - 1;
        const stepDuration = 100; // ms per peg row
        const totalDuration = stepDuration * totalSteps;
        let startT = null;

        function step(now) {
            if (startT === null) startT = now;
            const elapsed = now - startT;
            const globalT = Math.min(elapsed / totalDuration, 1);
            const rawSeg = globalT * totalSteps;
            const segIndex = Math.min(Math.floor(rawSeg), totalSteps - 1);
            const segT = rawSeg - segIndex;

            const p1 = path[segIndex];
            const p2 = path[segIndex + 1] || path[totalSteps];

            // Quadratic bezier: control point arcs slightly upward
            const cpX = (p1.x + p2.x) / 2;
            const cpY = Math.min(p1.y, p2.y) - 10;
            const t = segT;
            const x = (1-t)*(1-t)*p1.x + 2*(1-t)*t*cpX + t*t*p2.x;
            const y = (1-t)*(1-t)*p1.y + 2*(1-t)*t*cpY + t*t*p2.y;

            // Position ball: x is absolute from left of board, center ball on it
            ball.style.left = `${x - 6}px`;
            ball.style.top  = `${y}px`;
            ball.style.transform = 'none'; // override default transform

            if (globalT < 1) {
                requestAnimationFrame(step);
            } else {
                ball.style.top = `${boardH - binH - 14}px`;
                setTimeout(() => { ball.remove(); resolve(binIndex); }, 300);
            }
        }
        requestAnimationFrame(step);
    });
}

async function playPlinko() {
    const bet = parseInt(document.getElementById('plinko-bet').value);
    if (!bet || bet < 1 || bet > 50000) return alert('Enter bet between 1 and 50,000.');
    if (myPoints < bet) return alert(`Need ${bet} pts to drop a ball.`);

    await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-bet));

    const board = document.getElementById('plinko-board');
    const boardWidth = board.getBoundingClientRect().width || 600;
    const { path, binIndex, boardH, binH } = buildPlinkoPath(boardWidth);

    // Fire and forget so button never locks
    (async () => {
        try {
            const landed = await animatePlinkoBall(board, path, binIndex, boardH, binH);
            const mult = PLINKO_MULTS[landed];
            const win  = Math.floor(bet * mult);

            const bins = board.querySelectorAll('.plinko-bin');
            if (bins[landed]) {
                bins[landed].classList.add('active-bin');
                setTimeout(() => bins[landed] && bins[landed].classList.remove('active-bin'), 800);
            }

            const status = document.getElementById('plinko-status');
            status.innerText = `${mult}x → ${win} pts`;
            status.style.color = win > bet ? '#55ff55' : win === bet ? '#fff' : '#ff5555';

            if (win > 0) await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(win));
        } catch(e) {
            console.error('Plinko error:', e);
        }
    })();
}

// --- ROULETTE (MATH DOM GENERATION) ---
let rlCurrentChip = 10;
let rlBets = {}; 
let rlSpinning = false;
const ROULETTE_ORDER = [0, 32, 15, 19, 4, 21, 2, 25, 17, 34, 6, 27, 13, 36, 11, 30, 8, 23, 10, 5, 24, 16, 33, 1, 20, 14, 31, 9, 22, 18, 29, 7, 28, 12, 35, 3, 26];
const RL_REDS = [1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36];

function buildRouletteBoard() {
    const wheel = document.getElementById('rl-wheel');
    const anglePerWedge = 360 / 37;
    
    ROULETTE_ORDER.forEach((num, idx) => {
        const wedge = document.createElement('div');
        const isRed = RL_REDS.includes(num);
        const color = num === 0 ? '#008800' : (isRed ? '#cc0000' : '#111');
        
        wedge.className = 'rl-wedge';
        wedge.style.transform = `rotate(${idx * anglePerWedge}deg) skewY(${-(90 - anglePerWedge)}deg)`;
        wedge.style.backgroundColor = color;
        
        const textWrapper = document.createElement('span');
        textWrapper.innerText = num;
        // Un-skew the text, then rotate it to face outward from wheel center, then nudge into readable position
        const unskew = 90 - anglePerWedge;
        const centerAngle = anglePerWedge / 2;
        textWrapper.style.transform = `skewY(${unskew}deg) rotate(${centerAngle}deg) translate(6px, 5px)`;
        
        wedge.appendChild(textWrapper);
        wheel.appendChild(wedge);
    });

    const board = document.getElementById('rl-board');
    let html = '';
    for(let i=1; i<=36; i++) {
        const isRed = RL_REDS.includes(i);
        const col = isRed ? 'rl-red' : 'rl-black';
        const r = ((i-1) % 3) + 1;
        const c = Math.floor((i-1) / 3) + 2; 
        html += `<div class="rl-spot ${col}" style="grid-row:${r}; grid-column:${c};" onclick="placeRlBet('${i}')">${i}<div class="rl-chip hidden" id="rl-chip-${i}"></div></div>`;
    }
    const outsideEl = document.querySelector('.rl-outside');
    const outsideHTML = outsideEl ? outsideEl.outerHTML : '';
    if(outsideEl) outsideEl.remove();
    board.innerHTML += html + (outsideHTML || '');
}

function setRlChip(val) { rlCurrentChip = val; document.getElementById('rl-current-chip').innerText = val; }

function placeRlBet(spot) {
    if(rlSpinning) return;
    const totalBet = Object.values(rlBets).reduce((a,b)=>a+b, 0) + rlCurrentChip;
    if(totalBet > myPoints) return alert("Not enough points to place this bet.");
    if(totalBet > 50000) return alert("Table max bet is 50,000.");
    
    rlBets[spot] = (rlBets[spot] || 0) + rlCurrentChip;
    const chipEl = document.getElementById(`rl-chip-${spot}`);
    chipEl.innerText = rlBets[spot] > 999 ? (rlBets[spot]/1000).toFixed(1)+'k' : rlBets[spot];
    chipEl.classList.remove('hidden');
    
    document.getElementById('rl-status').innerText = `Total Bet: ${totalBet}`;
    document.getElementById('rl-status').style.color = '#fff';
}

function clearRlBets() {
    if(rlSpinning) return;
    rlBets = {};
    document.querySelectorAll('.rl-chip').forEach(el => { el.classList.add('hidden'); el.innerText=''; });
    document.getElementById('rl-status').innerText = `Total Bet: 0`;
}

async function spinRoulette() {
    if(rlSpinning) return;
    const totalBet = Object.values(rlBets).reduce((a,b)=>a+b, 0);
    if(totalBet === 0) return alert("Place a bet first!");
    if(totalBet > myPoints) { clearRlBets(); return alert("You don't have enough points for these bets."); }

    rlSpinning = true;
    document.getElementById('rl-spin-btn').disabled = true;
    await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-totalBet));

    document.getElementById('rl-status').innerText = "Spinning...";

    const resultNum = Math.floor(Math.random() * 37); 
    const targetIndex = ROULETTE_ORDER.indexOf(resultNum);
    const anglePerWedge = 360 / 37;
    
    const baseAngle = 360 - (targetIndex * anglePerWedge) - (anglePerWedge/2); 
    const extraSpins = 5 * 360; 
    const finalRot = extraSpins + baseAngle;

    const wheel = document.getElementById('rl-wheel');
    wheel.style.transform = `rotate(${finalRot}deg)`;

    await new Promise(r => setTimeout(r, 4000));
    
    wheel.style.transition = 'none';
    wheel.style.transform = `rotate(${baseAngle}deg)`;
    void wheel.offsetWidth;
    wheel.style.transition = 'transform 4s cubic-bezier(0.15, 0.85, 0.1, 1)';

    let totalWin = 0;
    for(const [spot, amount] of Object.entries(rlBets)) {
        if(spot === String(resultNum)) totalWin += amount * 36;
        else if (resultNum !== 0) {
            const isRed = RL_REDS.includes(resultNum);
            const isEven = resultNum % 2 === 0;
            if(spot === 'red' && isRed) totalWin += amount * 2;
            if(spot === 'black' && !isRed) totalWin += amount * 2;
            if(spot === 'even' && isEven) totalWin += amount * 2;
            if(spot === 'odd' && !isEven) totalWin += amount * 2;
        }
    }

    const isRedResult = resultNum !== 0 && RL_REDS.includes(resultNum);
    const colorStr = resultNum === 0 ? '🟢 Green' : (isRedResult ? '🔴 Red' : '⚫ Black');

    const status = document.getElementById('rl-status');
    const payoutStr = totalWin > 0 ? `Payout: ${totalWin} pts` : `Lost: ${totalBet} pts`;
    if(totalWin > 0) {
        status.innerHTML = `<span style="font-size:1.2em;">🎉 Result: <strong>${resultNum}</strong> ${colorStr} — ${payoutStr}</span>`;
        status.style.color = '#55ff55';
        await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(totalWin));
    } else {
        status.innerHTML = `<span style="font-size:1.2em;">Result: <strong>${resultNum}</strong> ${colorStr} — ${payoutStr}</span>`;
        status.style.color = '#ff5555';
    }

    // Hold result for 3 seconds before allowing a new spin
    await new Promise(r => setTimeout(r, 3000));

    rlSpinning = false;
    document.getElementById('rl-spin-btn').disabled = false;
    clearRlBets();
    status.style.fontSize = '';
}

