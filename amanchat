// ── Player actions ───────────────────────────────────────────────
async function pokerFold() {
    if(!pokerState || pokerState.actionOn !== user) return;
    await pokerRef.child(`players/${user}/folded`).set(true);
    await pokerAdvanceAction();
}

async function pokerCheck(event) {
    if(!pokerState || pokerState.actionOn !== user) return;
    // Prevent double-check by disabling button temporarily
    const btn = event.target;
    if(btn) btn.disabled = true;
    await pokerAdvanceAction();
    if(btn) setTimeout(() => btn.disabled = false, 500);
}

async function pokerCall(amt) {
    if(!pokerState || pokerState.actionOn !== user) return;
    const me = pokerState.players[user];
    const actual = Math.min(amt, me.chips);
    await pokerRef.child(`players/${user}/chips`).set(me.chips - actual);
    await pokerRef.child(`players/${user}/bet`).set((me.bet||0) + actual);
    await pokerRef.child('pot').set((pokerState.pot||0) + actual);
    await pokerAdvanceAction();
}

async function pokerConfirmRaise() {
    if(!pokerState || pokerState.actionOn !== user) return;
    const amt = parseInt(document.getElementById('poker-raise-in').value);
    if(!amt || amt < 1) return alert('Enter a raise amount.');
    const me = pokerState.players[user];
    const callAmt = Math.max(0, (pokerState.currentBet||0)-(me.bet||0));
    const total = callAmt + amt;
    if(total > me.chips) return alert(`Not enough chips. You have ${me.chips}.`);
    const newBet = (me.bet||0) + total;
    await pokerRef.child(`players/${user}/chips`).set(me.chips - total);
    await pokerRef.child(`players/${user}/bet`).set(newBet);
    await pokerRef.child('pot').set((pokerState.pot||0) + total);
    await pokerRef.child('currentBet').set(newBet);
    await pokerRef.child('lastRaiser').set(user);
    document.getElementById('poker-raise-row').classList.add('hidden');
    await pokerAdvanceAction();
}

async function pokerAllIn() {
    if(!pokerState || pokerState.actionOn !== user) return;
    const me = pokerState.players[user];
    const chips = me.chips;
    const newBet = (me.bet||0) + chips;
    await pokerRef.child(`players/${user}/chips`).set(0);
    await pokerRef.child(`players/${user}/bet`).set(newBet);
    await pokerRef.child(`players/${user}/allIn`).set(true);
    await pokerRef.child('pot').set((pokerState.pot||0) + chips);
    if(newBet > (pokerState.currentBet||0)) await pokerRef.child('currentBet').set(newBet);
    await pokerAdvanceAction();
}

async function pokerAdvanceAction() {
    // Always re-read state fresh from Firebase to avoid stale data race
    const freshSnap = await pokerRef.once('value');
    const g = freshSnap.val();
    if(!g) return;
    const order = g.order || [];
    const players = g.players || {};
    const curIdx = order.indexOf(g.actionOn);
    // Find next active (not folded, not all-in) player
    let nextIdx = (curIdx+1) % order.length;
    let checked = 0;
    while(checked < order.length) {
        const p = order[nextIdx];
        const pd = players[p]||{};
        if(!pd.folded && !pd.allIn) break;
        nextIdx = (nextIdx+1) % order.length;
        checked++;
    }
    const nextPlayer = order[nextIdx];
    // Check if betting round is over:
    // Round ends only when we would return to the lastRaiser AND all active bets are equal
    const active = order.filter(p=>!(players[p]||{}).folded);
    const allEqual = active.every(p=>(players[p]||{}).bet===(g.currentBet||0)||(players[p]||{}).allIn);
    const backToLastRaiser = nextPlayer === g.lastRaiser && allEqual;
    const onlyOneLeft = active.length === 1;

    if(onlyOneLeft || backToLastRaiser) {
        // Advance phase
        await pokerNextPhaseFromState(g);
    } else {
        await pokerRef.child('actionOn').set(nextPlayer);
    }
}

async function pokerNextPhase() {
    await pokerNextPhaseFromState(pokerState);
}

async function pokerNextPhaseFromState(g) {
    const deck = g.deck || [];
    const comm = g.community || [];
    const players = g.players || {};
    const order = g.order || [];
    const active = order.filter(p=>!(players[p]||{}).folded);

    if(active.length === 1 || g.phase === 'river') {
        await pokerShowdown();
        return;
    }

    // Reset bets for new phase
    const playerUpdates = {};
    order.forEach(p => {
        playerUpdates[`players/${p}/bet`] = 0;
    });

    let nextPhase, newComm = [...comm];
    if(g.phase==='preflop')     { nextPhase='flop';  newComm.push(deck.pop(),deck.pop(),deck.pop()); }
    else if(g.phase==='flop')   { nextPhase='turn';  newComm.push(deck.pop()); }
    else if(g.phase==='turn')   { nextPhase='river'; newComm.push(deck.pop()); }

    // First to act post-flop = first non-folded player after dealer
    const dealerIdx = (g.round-1) % order.length;
    let firstIdx = (dealerIdx+1) % order.length;
    while((players[order[firstIdx]]||{}).folded) firstIdx=(firstIdx+1)%order.length;

    const updates = { phase: nextPhase, community: newComm, deck, currentBet: 0, lastRaiser: order[firstIdx], actionOn: order[firstIdx], ...playerUpdates };
    await pokerRef.update(updates);
}

// ── Showdown ─────────────────────────────────────────────────────
async function pokerShowdown() {
    const g = pokerState;
    const players = g.players || {};
    const order = g.order || [];
    const active = order.filter(p=>!(players[p]||{}).folded);
    const comm = g.community || [];
    const hands = g.hands || {};

    let winnerId;
    if(active.length === 1) {
        winnerId = active[0];
    } else {
        // Evaluate each hand
        let best = null, bestPlayer = null;
        active.forEach(p => {
            const h = [...(hands[p]||[]),...comm];
            const ev = pokerEvalHand(h);
            if(!best || pokerCompare(ev,best)>0) { best=ev; bestPlayer=p; }
        });
        winnerId = bestPlayer;
    }

    // Award pot
    const pot = g.pot || 0;
    const winnerChips = (players[winnerId]||{}).chips || 0;
    const playerUpdates = {};
    order.forEach(p => { playerUpdates[`players/${p}/bet`] = 0; });
    playerUpdates[`players/${winnerId}/chips`] = winnerChips + pot;
    playerUpdates['pot'] = 0;
    playerUpdates['phase'] = 'showdown';
    playerUpdates['winner'] = winnerId;
    playerUpdates['winnerPot'] = pot;
    await pokerRef.update(playerUpdates);
}

// ── Showdown render ──────────────────────────────────────────────
function pokerRenderShowdown() {
    const g = pokerState;
    const players = g.players || {};
    const winner = g.winner || '';
    const pot = g.winnerPot || 0;
    document.getElementById('poker-winner-msg').textContent = `🏆 ${winner} wins ${pot.toLocaleString()} pts!`;

    // Show all hands
    const hands = g.hands || {};
    const comm = g.community || [];
    const order = g.order || [];
    let html = '<div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;">';
    order.forEach(p => {
        const h = hands[p] || [];
        const pd = players[p] || {};
        const rank = h.length>=2 ? pokerEvalHand([...h,...comm]).name : '';
        html += `<div style="padding:10px;background:rgba(0,0,0,0.4);border-radius:10px;text-align:center;border:2px solid ${p===winner?'#ffd700':'rgba(255,255,255,0.1)'};">
            <div style="font-size:0.8em;color:${p===winner?'#ffd700':'#aaa'};margin-bottom:6px;">${p===winner?'👑 ':''}${p}</div>
            <div style="display:flex;gap:4px;justify-content:center;">${h.map(c=>pokerCard(c.r,c.s)).join('')}</div>
            ${pd.folded?'<div style="color:#ff4444;font-size:0.75em;margin-top:4px;">Folded</div>':''}
            ${rank&&!pd.folded?`<div style="color:#ffd700;font-size:0.75em;margin-top:4px;">${rank}</div>`:''}
            <div style="color:#aaa;font-size:0.75em;margin-top:2px;">${(pd.chips||0).toLocaleString()}</div>
        </div>`;
    });
    html += '</div>';
    document.getElementById('poker-showdown-hands').innerHTML = html;

    document.getElementById('poker-play-again-status').textContent = 'Waiting for all players to vote...';

    // Reactively update vote count and trigger new round for host (reuse `order` declared above)
    const voted = order.filter(p=>(g.players[p]||{}).playAgain===true).length;
    if(voted > 0) {
        document.getElementById('poker-play-again-status').textContent = `${voted}/${order.length} voted to play again`;
    }
    // Restore button state if this player already voted
    const myBtn = document.getElementById('poker-play-again-btn');
    if((g.players[user]||{}).playAgain === true && myBtn) {
        myBtn.disabled = true;
        myBtn.textContent = '✔ Voted';
    } else if(myBtn) {
        myBtn.disabled = false;
        myBtn.textContent = '🔄 Play Again';
    }
    // Host auto-starts when all voted
    pokerCheckPlayAgainReady(g);
}

// ── Play again ───────────────────────────────────────────────────
async function pokerPlayAgain() {
    await pokerRef.child(`players/${user}/playAgain`).set(true);
    document.getElementById('poker-play-again-btn').disabled = true;
    document.getElementById('poker-play-again-btn').textContent = '✔ Voted';
    // The reactive listener in pokerRenderShowdown will handle starting the new round
}

// Called by pokerRenderShowdown whenever state updates — host auto-starts when all voted
async function pokerCheckPlayAgainReady(g) {
    if(!pokerIsHost) return;
    const order = g.order || [];
    if(order.length === 0) return;
    const all = order.every(p=>(g.players[p]||{}).playAgain===true);
    if(!all) return;
    // Prevent double-trigger: check phase is still showdown
    if(g.phase !== 'showdown') return;
    // Mark that we're transitioning so the listener doesn't fire twice
    await pokerRef.child('phase').set('dealing');
    const remaining = order.filter(p=>(g.players[p]||{}).chips>0);
    if(remaining.length < 2) { await pokerRef.child('phase').set('waiting'); return; }
    await pokerDealNewRound();
}

// ── Leave game ───────────────────────────────────────────────────
async function pokerLeave() {
    // Sync final chips back to real points
    if(pokerState && pokerState.players && pokerState.players[user]) {
        const finalChips = pokerState.players[user].chips || 0;
        await db.ref(`users/${user}/points`).set(finalChips);
        myPoints = finalChips;
    }
    if(pokerRef) {
        pokerRef.off('value', pokerListener);
        // Remove self from game
        await pokerRef.child(`players/${user}`).remove();
        const snap = await pokerRef.once('value');
        const g = snap.val()||{};
        const remaining = Object.keys(g.players||{});
        if(remaining.length === 0) {
            await pokerRef.remove(); // clean up empty game
        } else if(pokerIsHost && remaining.length > 0) {
            // Transfer host
            await pokerRef.child('host').set(remaining[0]);
        }
    }
    pokerReset();
}

// ── Poker Chat ────────────────────────────────────────────────────
let pokerChatListener = null;

function pokerSubscribeChat() {
    if(!pokerRef) return;
    if(pokerChatListener) pokerRef.child('chat').off('value', pokerChatListener);
    pokerChatListener = pokerRef.child('chat').on('value', snap => {
        const msgs = snap.val() || {};
        const sorted = Object.values(msgs).sort((a,b)=>a.ts-b.ts);
        ['poker-chat-msgs','poker-chat-msgs-table'].forEach(id => {
            const el = document.getElementById(id);
            if(!el) return;
            el.innerHTML = '';
            sorted.forEach(m => {
                const row = document.createElement('div');
                row.style.cssText = 'display:flex;gap:6px;align-items:baseline;font-size:0.82em;';
                const isMe = m.from === user;
                row.innerHTML = `<span style="color:${isMe?'#4ade80':'#60a5fa'};font-weight:bold;flex-shrink:0;">${m.from}</span><span style="color:#ddd;word-break:break-word;">${escapeHtml(m.text)}</span>`;
                el.appendChild(row);
            });
            el.scrollTop = el.scrollHeight;
        });
    });
}

async function pokerSendChat() {
    if(!pokerRef) return;
    // Get text from whichever input is visible
    let input = document.getElementById('poker-chat-input');
    if(!input || !input.offsetParent) input = document.getElementById('poker-chat-input-table');
    if(!input) return;
    const text = (input.value || '').trim();
    if(!text) return;
    input.value = '';
    const key = pokerRef.child('chat').push().key;
    await pokerRef.child(`chat/${key}`).set({ from: user, text, ts: Date.now() });
}

function escapeHtml(s) {
