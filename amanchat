}

function pokerReset() {
    // Unsubscribe chat
    if(pokerChatListener && pokerRef) pokerRef.child('chat').off('value', pokerChatListener);
    pokerChatListener = null;
    pokerCode=null; pokerRef=null; pokerListener=null; pokerState=null; pokerIsHost=false;
