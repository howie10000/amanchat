async function processAuth() {
    const u = document.getElementById('user-in').value.trim();
    const p = document.getElementById('pass-in').value.trim();
    if(!/^[a-zA-Z0-9_]+$/.test(u)) return alert("Invalid username format.");

    const bannedSnap = await db.ref(`banned_usernames/${u}`).once('value');
    if(bannedSnap.exists() && bannedSnap.val() === true) {
        return alert("This username has been banned from Aman Chat.");
    }

    const snap = await db.ref('users/'+u).once('value');
    const isGodMode = (u==='Howard' || u==='Aman');

    if(authMode==='create') {
        if(snap.exists()) return alert("Taken");
        const newRole = isGodMode ? 'admin' : 'user';
        await db.ref('users/'+u).set({ pass:p, role:newRole, server_creator:isGodMode, theme:'dark', optIn:false, points:0, inventory:{ themes:{ dark:1, light:1 }, titles:{}, lootboxes:{} } });
        if(isGodMode) await db.ref(`users/${u}/ceremonialTitles`).set({ admin_t:true });
        await ensureOfficialServers();
        initApp(u,'dark',newRole,isGodMode);
    } else {
        if(snap.exists() && snap.val().pass===p) {
            const uData = snap.val();
            if(uData.banned) return alert("Permanently banned.");
            if(uData.bannedUntil && uData.bannedUntil > Date.now()) return alert(`Temp banned for ${Math.ceil((uData.bannedUntil-Date.now())/(1000*60*60))} more hours.`);
            if(!uData.inventory) {
                const oldThemes = uData.themes || { dark:true, light:true };
                const newInv = { themes:{}, titles:{}, lootboxes:{} };
                for(const t of Object.keys(oldThemes)) newInv.themes[t] = 1;
                await db.ref(`users/${u}/inventory`).set(newInv);
                await db.ref(`users/${u}/themes`).remove();
            }
            await ensureOfficialServers();
            initApp(u, uData.theme||'dark', isGodMode?'admin':uData.role, isGodMode?true:uData.server_creator);
        } else alert("Incorrect credentials.");
    }
}



