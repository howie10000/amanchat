//  CUSTOM CONFIRM MODAL HELPER (replaces browser confirm())
// =========================================================
function showConfirm(icon, title, msg, btnLabel, btnColor) {
    return new Promise((resolve, reject) => {
        document.getElementById('confirm-icon').innerText = icon || '❓';
        document.getElementById('confirm-title').innerText = title || 'Are you sure?';
        document.getElementById('confirm-msg').innerText = msg || '';
        const yesBtn = document.getElementById('confirm-yes-btn');
        yesBtn.innerText = btnLabel || 'Confirm';
        yesBtn.style.background = btnColor || 'var(--primary)';
        yesBtn.style.color = btnColor ? 'white' : '#000';
        // Clean up old listener
        const newBtn = yesBtn.cloneNode(true);
        yesBtn.parentNode.replaceChild(newBtn, yesBtn);
        newBtn.addEventListener('click', () => {
            closeM('modal-confirm');
            window._confirmReject = null;
            resolve(true);
        });
        window._confirmReject = () => { window._confirmReject = null; reject(new Error('cancelled')); };
        document.getElementById('modal-confirm').classList.remove('hidden');
    });
}

async function acceptMarketOffer(offerId) {
    const snap = await db.ref(`market/${offerId}`).once('value');
    const offer = snap.val();
    if(!offer || offer.status !== 'open') return alert("This offer is no longer available.");
    if(offer.from === user) return alert("You cannot accept your own offer.");

    // Check acceptor meets all conditions
    if(offer.wantPoints > 0 && myPoints < offer.wantPoints) return alert(`You need at least ${offer.wantPoints} points.`);
    for(const item of (offer.wantItems||[])) {
        const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
        const owned = (myInventory[folderName]||{})[item.id] || 0;
        if(owned < item.qty) return alert(`You need ${item.qty}x ${item.name} to accept this offer.`);
    }

    // Check offerer still owns their give items
    const offererSnap = await db.ref(`users/${offer.from}/inventory`).once('value');
    const offererInv = offererSnap.val() || {};
    for(const item of (offer.giveItems||[])) {
        const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
        const owned = (offererInv[folderName]||{})[item.id] || 0;
        if(owned < item.qty) return alert(`The offer poster no longer has ${item.name}. The offer will be removed.`);
    }

    try {
        await showConfirm('✅', 'Accept This Offer?', 'Items will be transferred immediately. This cannot be undone.', 'Accept Offer', '#00aa55');
    } catch(e) { return; } // user cancelled

    // Transfer give items: offerer → me
    for(const item of (offer.giveItems||[])) {
        const q = item.qty||1;
        const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
        await db.ref(`users/${offer.from}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(-q));
        await db.ref(`users/${user}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(q));
    }
    if(offer.givePoints > 0) {
        await db.ref(`users/${offer.from}/points`).set(firebase.database.ServerValue.increment(-offer.givePoints));
        await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(offer.givePoints));
    }

    // Transfer want items: me → offerer
    for(const item of (offer.wantItems||[])) {
        const q = item.qty||1;
        const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
        await db.ref(`users/${user}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(-q));
        await db.ref(`users/${offer.from}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(q));
    }
    if(offer.wantPoints > 0) {
        await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-offer.wantPoints));
        await db.ref(`users/${offer.from}/points`).set(firebase.database.ServerValue.increment(offer.wantPoints));
    }

    await db.ref(`market/${offerId}/status`).set('accepted');
    alert("✅ Trade complete! Items have been transferred.");
    loadMarket();
}

async function cancelMarketOffer(offerId) {
    try {
        await showConfirm('🗑️', 'Cancel Your Offer?', 'Remove your offer from the market? Other players will no longer be able to accept it.', 'Remove Offer', '#cc3333');
    } catch(e) { return; } // user cancelled
    await db.ref(`market/${offerId}/status`).set('cancelled');
    loadMarket();
}

