<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aman Chat - Deluxe Edition</title>
    <style>
        /* Dynamic theme styles injected by JS */
        :root {
            --primary: #00d4ff; --bg: #0b0b0b; 
            --panel: rgba(22, 22, 22, 0.85); --sidebar: rgba(17, 17, 17, 0.85);
            --text: #f0f0f0; --admin: #ff3e3e; 
            --msg-bg: rgba(34, 34, 34, 0.85); --msg-me: rgba(0, 75, 90, 0.85);
        }

        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: var(--sidebar); }
        ::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { filter: brightness(1.2); }

        @keyframes shimmer { 0%,100%{opacity:.7} 50%{opacity:1} }
        @keyframes legendaryGlow { 0%,100%{text-shadow:0 0 8px #ffd700, 0 0 16px #ffd700} 50%{text-shadow:0 0 20px #ffd700, 0 0 40px #ff9900} }
        @keyframes epicGlow { 0%,100%{text-shadow:0 0 8px #b366ff} 50%{text-shadow:0 0 20px #b366ff, 0 0 35px #9900ff} }
        @keyframes rareGlow { 0%,100%{text-shadow:0 0 6px #4d94ff} 50%{text-shadow:0 0 15px #4d94ff} }
        
        /* ENHANCED MYTHIC GLOW */
        @keyframes mythicGlow { 
            0%,100%{text-shadow:0 0 15px #ff00aa, 0 0 30px #ff00aa, 0 0 40px #00ffff; filter: brightness(1.2) drop-shadow(0 0 10px rgba(255,0,170,0.8));} 
            50%{text-shadow:0 0 35px #00ffff, 0 0 60px #ff00aa, 0 0 80px #00ffff; filter: brightness(1.5) drop-shadow(0 0 20px rgba(0,255,255,1));} 
        }
        @keyframes mythicBurst { 0% { opacity: 1; transform: scale(0); } 100% { opacity: 0; transform: scale(3) translate(var(--dx), var(--dy)); } }

        @keyframes boxShake { 0%,100%{transform:translateX(0)} 10%{transform:translateX(-12px) rotate(-5deg)} 20%{transform:translateX(14px) rotate(5deg)} 30%{transform:translateX(-10px) rotate(-3deg)} 40%{transform:translateX(10px) rotate(3deg)} 50%{transform:translateX(-6px) rotate(-2deg)} 60%{transform:translateX(6px) rotate(2deg)} 70%{transform:translateX(0)} 100%{transform:translateX(0)} }

        /* Mythic Reveal Animations */
        #mythic-reveal-overlay { position:fixed; inset:0; z-index:100000; pointer-events:none; }
        @keyframes oceanZoomOut { 0% { transform:scale(1); } 100% { transform:scale(3); } }
        @keyframes fishSwim { 0% { transform:translateX(-100px); } 100% { transform:translateX(calc(100vw + 100px)); } }
        @keyframes fishSwimReverse { 0% { transform:translateX(calc(100vw + 100px)); } 100% { transform:translateX(-100px); } }
        @keyframes sharkAppear { 0% { transform:translateX(100vw) scale(0.5); opacity:0; } 50% { transform:translateX(50vw) scale(1.2); opacity:1; } 100% { transform:translateX(30vw) scale(1); opacity:1; } }
        @keyframes whiteFlash { 0% { background:rgba(255,255,255,0); } 10% { background:rgba(255,255,255,1); } 100% { background:rgba(255,255,255,0); } }
        @keyframes biteMarkPop { 0% { transform:translate(-50%,-50%) scale(0) rotate(-15deg); opacity:0; } 50% { transform:translate(-50%,-50%) scale(1.3) rotate(5deg); opacity:1; } 70% { transform:translate(-50%,-50%) scale(0.9) rotate(-3deg); } 100% { transform:translate(-50%,-50%) scale(1) rotate(0deg); opacity:1; } }
        @keyframes rippleExpand { 0% { transform:translate(-50%,-50%) scale(0.5); opacity:0.8; } 100% { transform:translate(-50%,-50%) scale(2); opacity:0; } }
        @keyframes screenShake { 0%,100%{transform:translate(0,0)} 10%{transform:translate(-10px,5px)} 20%{transform:translate(10px,-5px)} 30%{transform:translate(-8px,3px)} 40%{transform:translate(8px,-3px)} 50%{transform:translate(-5px,2px)} 60%{transform:translate(5px,-2px)} 70%{transform:translate(-3px,1px)} 80%{transform:translate(3px,-1px)} 90%{transform:translate(-1px,0)} }
        @keyframes volcanoErupt { 0% { transform:scale(0.8); opacity:0; } 30% { transform:scale(1.1); opacity:1; } 50% { transform:scale(1); } 100% { transform:scale(1); } }
        @keyframes lavaFlow { 0% { height:0; } 100% { height:100%; } }
        @keyframes emberRise { 0% { transform:translateY(0) scale(1); opacity:1; } 100% { transform:translateY(-200px) scale(0); opacity:0; } }
        @keyframes eruption { 0% { transform:translateY(100%); opacity:0; } 50% { transform:translateY(0); opacity:1; } 100% { transform:translateY(-50%); opacity:0; } }
        @keyframes matrixFall { 0% { transform:translateY(-100%); opacity:0; } 10% { opacity:1; } 90% { opacity:1; } 100% { transform:translateY(100vh); opacity:0; } }
        @keyframes blackHoleGrow { 0% { transform:scale(0); opacity:0; } 50% { transform:scale(1); opacity:1; } 100% { transform:scale(3); opacity:0; } }
        @keyframes suckIn { 0% { transform:translate(0,0) scale(1); opacity:1; } 100% { transform:translate(50vw,50vh) scale(0); opacity:0; } }
        @keyframes planetOrbit { 0% { transform:rotate(0deg) translateX(100px) rotate(0deg); } 100% { transform:rotate(360deg) translateX(100px) rotate(-360deg); } }
        @keyframes asteroidOrbit { 0% { transform:rotate(0deg) translateX(var(--orbit-radius)) rotate(0deg) scale(1); } 50% { transform:rotate(180deg) translateX(var(--orbit-radius)) rotate(-180deg) scale(1.1); } 100% { transform:rotate(360deg) translateX(var(--orbit-radius)) rotate(-360deg) scale(1); } }
        @keyframes coinFallFast { 0% { transform:translateY(-100px) rotate(0deg); opacity:1; } 100% { transform:translateY(100vh) rotate(720deg); opacity:1; } }
        @keyframes nebulaSwirl { 0% { transform:translate(0,0) scale(1) rotate(0deg); } 100% { transform:translate(30px,30px) scale(1.2) rotate(45deg); } }
        @keyframes starTwinkle { 0% { opacity:0.3; transform:scale(0.8); } 100% { opacity:1; transform:scale(1.2); } }
        @keyframes starGrowPulse { 0% { transform:translate(-50%,-50%) scale(0.5); opacity:0; } 30% { transform:translate(-50%,-50%) scale(1); opacity:0.5; } 50% { transform:translate(-50%,-50%) scale(2); opacity:0.8; } 70% { transform:translate(-50%,-50%) scale(1.5); opacity:0.6; } 100% { transform:translate(-50%,-50%) scale(4); opacity:1; } }
        @keyframes brightFlash { 0% { background:rgba(255,255,255,0); } 20% { background:rgba(255,255,255,1); } 100% { background:rgba(255,255,255,0); } }
        @keyframes fadeOut { 0% { opacity:1; } 100% { opacity:0; } }

        /* Pre-animation: Star spin-grow from 10% to 50% then glass shatter - 7.5s total */
        @keyframes starSpinGrow {
            0% { width:10vw; height:10vw; opacity:0.6; transform:translate(-50%,-50%) rotate(0deg); }
            25% { transform:translate(-50%,-50%) rotate(360deg); }
            50% { width:35vw; height:35vw; transform:translate(-50%,-50%) rotate(900deg); }
            75% { width:50vw; height:50vw; transform:translate(-50%,-50%) rotate(1350deg); }
            100% { width:55vw; height:55vw; opacity:0; transform:translate(-50%,-50%) rotate(1800deg); }
        }
        @keyframes glassShatter {
            0% { background:rgba(255,255,255,0); backdrop-filter:blur(0); }
            10% { background:rgba(255,255,255,0.1); backdrop-filter:blur(2px); }
            30% { background:rgba(255,255,255,0.3); backdrop-filter:blur(5px); }
            50% { background:rgba(255,255,255,0.6); backdrop-filter:blur(10px); }
            70% { background:rgba(255,255,255,0.8); backdrop-filter:blur(20px); }
            90% { background:rgba(255,255,255,1); backdrop-filter:blur(0); }
            100% { background:rgba(255,255,255,0); backdrop-filter:blur(0); }
        }
        @keyframes glassCrack {
            0% { opacity:0; transform:scale(0.8); }
            50% { opacity:1; transform:scale(1); }
            100% { opacity:0; transform:scale(1.2); }
        }

        @keyframes revealItem { 0%{opacity:0;transform:scale(0.2) translateY(30px)} 60%{transform:scale(1.2) translateY(-10px)} 100%{opacity:1;transform:scale(1) translateY(0)} }
        
        @keyframes gradientBG { 0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%} }

        body { font-family:'Segoe UI',sans-serif; background: var(--bg); color: var(--text); margin: 0; width:100vw; height:100vh; overflow:hidden; display:flex; transition:0.3s; }
        #mythic-canvas { position:fixed; inset:0; z-index:0; pointer-events:none; }
        #app-container { width:100%; height:100%; display:flex; flex-direction:column; background: var(--panel); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); position:relative; z-index:1; }
        .hidden { display:none !important; }
        nav { display:flex; background:rgba(0,0,0,0.8); padding:5px; gap:4px; border-bottom:1px solid rgba(255,255,255,0.1); flex-shrink:0; flex-wrap:wrap; }
        nav button { flex:1; padding:10px 6px; background:transparent; border:none; color:#888; cursor:pointer; border-radius:6px; font-weight:bold; transition:0.2s; position:relative; font-size:0.8em; }
        nav button.active { background: var(--primary); color:#000; }
        #main-view-area { flex:1; display:flex; overflow:hidden; position:relative; min-height:0; }
        .tab-pane { display:flex; flex:1; width:100%; height:100%; overflow:hidden; }
        .sidebar { width:250px; min-width:180px; border-right:1px solid rgba(255,255,255,0.05); display:flex; flex-direction:column; background:var(--sidebar); overflow-y:auto; flex-shrink:0; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); }
        .chat-content { flex:1; display:flex; flex-direction:column; background:transparent; position:relative; min-width:0; }
        .right-sidebar { width:220px; border-left:1px solid rgba(255,255,255,0.05); background:var(--sidebar); padding:10px; overflow-y:auto; flex-shrink:0; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); }
        .list-header { padding:15px 10px 5px; font-size:0.75em; color:#777; text-transform:uppercase; font-weight:bold; letter-spacing:1px; }
        .list-item { padding:12px 10px; cursor:pointer; border-bottom:1px solid rgba(255,255,255,0.05); display:flex; justify-content:space-between; align-items:center; position:relative; }
        .list-item:hover { background:rgba(255,255,255,0.1); color:var(--primary); }
        .status-dot { width:10px; height:10px; border-radius:50%; background:#444; display:inline-block; margin-right:5px; }
        .status-online { background:#00ff00; box-shadow:0 0 5px #00ff00; }
        .unread-dot { width:10px; height:10px; border-radius:50%; background:yellow; box-shadow:0 0 8px yellow; position:absolute; right:10px; top:50%; transform:translateY(-50%); }
        #msg-history { flex:1; overflow-y:auto; padding:20px; display:flex; flex-direction:column; gap:15px; min-height:0; }
        .msg { background:var(--msg-bg); padding:10px 14px; border-radius:10px; width:fit-content; max-width:80%; position:relative; word-wrap:break-word; border:1px solid rgba(255,255,255,0.05); box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .msg.me { align-self:flex-end; background:var(--msg-me); }
        .msg-info { font-size:0.85em; color:var(--primary); margin-bottom:5px; font-weight:bold; cursor:pointer; display:flex; justify-content:space-between; align-items:center; gap:10px; }
        .msg-ts { font-size:0.75em; color:#aaa; font-weight:normal; }
        .msg img { max-width:250px; border-radius:8px; margin-top:5px; cursor:pointer; border:1px solid #444; background:white; }
        .del-msg { color:red; cursor:pointer; display:none; margin-left:10px; font-size:1.2em; }
        .msg:hover .del-msg { display:inline-block; }
        .input-area { padding:15px; background:rgba(0,0,0,0.4); display:flex; flex-direction:column; gap:5px; border-top:1px solid rgba(255,255,255,0.05); flex-shrink:0; backdrop-filter: blur(10px); }
        .input-row { display:flex; gap:10px; }
        input, textarea, select { flex:1; background:rgba(0,0,0,0.5); border:1px solid #444; color:var(--text); padding:12px; border-radius:8px; outline:none; }
        .btn { padding:10px 18px; border-radius:8px; border:none; font-weight:bold; cursor:pointer; transition:0.2s; display:flex; align-items:center; justify-content:center; text-align:center; }
        .primary { background:var(--primary); color:#000; box-shadow: 0 0 10px rgba(0,212,255,0.2); }
        .modal { position:fixed; inset:0; background:rgba(0,0,0,0.9); display:flex; align-items:center; justify-content:center; z-index:9999; }
        .modal-card { background:var(--panel); padding:25px; border-radius:15px; width:360px; max-width:92vw; text-align:center; border:1px solid var(--primary); max-height:90vh; overflow-y:auto; position:relative; overflow:hidden; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }

        /* Loading screen */
        #loading-screen { position:fixed; inset:0; background:#0b0b0b; display:flex; flex-direction:column; align-items:center; justify-content:center; z-index:99999; }
        #loading-screen h1 { color:#00d4ff; font-size:2.5em; letter-spacing:5px; margin-bottom:20px; }
        .loading-bar { width:300px; height:4px; background:#222; border-radius:2px; overflow:hidden; }
        .loading-fill { height:100%; background:#00d4ff; border-radius:2px; animation:loadFill 3.5s ease forwards; }
        @keyframes loadFill { 0%{width:0%} 80%{width:90%} 100%{width:100%} }

        /* Rarity classes */
        .rc { color:#aaa; } .rr { color:#4d94ff; animation:rareGlow 2s infinite; } .re { color:#b366ff; animation:epicGlow 2s infinite; } .rl { color:#ffd700; animation:legendaryGlow 2s infinite; } .rm { color:#ff00aa; animation:mythicGlow 3s infinite; font-weight:bold; } .rcr { color:#ff6666; } .rev { color:#ff9900; }
        .rarity-badge { font-size:0.7em; padding:2px 8px; border-radius:10px; font-weight:bold; text-transform:uppercase; letter-spacing:1px; }
        .rb-common { background:rgba(170,170,170,0.2); color:#aaa; border:1px solid #aaa; }
        .rb-rare { background:rgba(77,148,255,0.2); color:#4d94ff; border:1px solid #4d94ff; }
        .rb-epic { background:rgba(179,102,255,0.2); color:#b366ff; border:1px solid #b366ff; }
        .rb-legendary { background:rgba(255,215,0,0.2); color:#ffd700; border:1px solid #ffd700; }
        .rb-mythic { background:rgba(255,0,170,0.2); color:#ff00aa; border:1px solid #ff00aa; }
        .rb-ceremonial { background:rgba(255,102,102,0.2); color:#ff6666; border:1px solid #ff6666; }
        .rb-event { background:rgba(255,153,0,0.2); color:#ff9900; border:1px solid #ff9900; }
        .rb-free { background:rgba(100,100,100,0.2); color:#aaa; border:1px solid #666; }
        .item-card { background:rgba(0,0,0,0.4); border-radius:10px; padding:12px; display:flex; flex-direction:column; align-items:center; gap:8px; cursor:pointer; transition:0.2s; border:1px solid transparent; }
        .item-card:hover { border-color: var(--primary); background:rgba(255,255,255,0.05); }
        .item-card.selected { border-color: var(--primary) !important; background:rgba(0,212,255,0.1) !important; }
        .item-card.ic-common { border-color:rgba(170,170,170,0.3); }
        .item-card.ic-rare { border-color:rgba(77,148,255,0.3); }
        .item-card.ic-epic { border-color:rgba(179,102,255,0.3); }
        .item-card.ic-legendary { border-color:rgba(255,215,0,0.4); box-shadow:0 0 8px rgba(255,215,0,0.15); }
        .item-card.ic-mythic { border-color:rgba(255,0,170,0.5); box-shadow:0 0 10px rgba(255,0,170,0.2); }
        .active-title { font-size:0.85em; padding:3px 10px; border-radius:10px; font-weight:bold; display:inline-block; margin-bottom:6px; }
        .msg-title { font-size:0.72em; color:#aaa; font-weight:normal; font-style:italic; margin-left:6px; }
        .lootbox-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:20px; width:100%; max-width:1000px; }
        .lb-card { background:rgba(0,0,0,0.5); border-radius:15px; padding:20px; text-align:center; cursor:pointer; transition:0.25s; position:relative; overflow:hidden; backdrop-filter: blur(5px); }
        .lb-card:hover { transform:translateY(-4px); }
        .lb-card-1 { border:2px solid #aaa; }
        .lb-card-2 { border:2px solid #4d94ff; box-shadow:0 0 15px rgba(77,148,255,0.2); }
        .lb-card-3 { border:2px solid #b366ff; box-shadow:0 0 20px rgba(179,102,255,0.3); }
        .lb-card-4 { border:2px solid #ffd700; box-shadow:0 0 25px rgba(255,215,0,0.35); animation:shimmer 2s infinite; }
        .lb-card-5 { border:2px solid #ff00aa; box-shadow:0 0 35px rgba(255,0,170,0.4); animation:mythicGlow 2s infinite; }
        .lb-icon { font-size:4em; margin-bottom:10px; display:block; }
        .lb-odds { font-size:0.78em; color:#aaa; margin-top:10px; text-align:left; background:rgba(0,0,0,0.3); border-radius:8px; padding:10px; }
        .lb-odd-row { display:flex; justify-content:space-between; margin:2px 0; }
        #lootbox-open-modal .modal-card { min-height:350px; position:relative; }
        .lb-open-box { font-size:5em; display:block; margin:20px auto; width:fit-content; transition:1s; }
        .lb-open-box.shaking { animation:boxShake 0.8s ease; }
        .lb-result-item { animation:revealItem 0.6s ease forwards; opacity:0; position:relative; }

        .inv-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:12px; width:100%; max-width:900px; }
        .inv-item { background:rgba(0,0,0,0.4); border-radius:10px; padding:12px; text-align:center; position:relative; backdrop-filter: blur(5px); }
        .inv-badge { position:absolute; top:-5px; right:-5px; background:var(--primary); color:#000; border-radius:50%; width:22px; height:22px; display:flex; align-items:center; justify-content:center; font-size:0.75em; font-weight:bold; }
        .theme-swatch { width:45px; height:45px; border-radius:50%; margin:0 auto 8px; border:2px solid rgba(255,255,255,0.3); }
        .trade-card { background:rgba(0,0,0,0.35); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:15px; margin-bottom:10px; backdrop-filter: blur(5px); }
        .trade-card.pending { border-color:rgba(0,212,255,0.5); }
        .trade-card.accepted { border-color:rgba(0,255,100,0.5); }
        .trade-card.declined { border-color:rgba(255,80,80,0.4); opacity:0.7; }
        .trade-side { background:rgba(0,0,0,0.25); border-radius:8px; padding:10px; flex:1; }
        .trade-item-chip { display:inline-flex; align-items:center; gap:4px; background:rgba(255,255,255,0.1); border-radius:8px; padding:3px 8px; font-size:0.8em; margin:2px; }
        
        /* Games CSS */
        .game-card { background:rgba(0,0,0,0.5); border:1px solid var(--primary); border-radius:15px; padding:20px; text-align:center; margin-bottom:20px; backdrop-filter: blur(5px); }
        
        .plinko-board { display:flex; flex-direction:column; align-items:center; margin:20px auto; position:relative; width: 100%; max-width: 700px; height: 520px; background: rgba(0,0,0,0.3); border-radius: 10px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); will-change: transform; }
        .plinko-ball { width: 12px; height: 12px; background: #fff; border-radius: 50%; position: absolute; top: 0; left: 50%; transform: translate(-50%, -20px); box-shadow: 0 0 10px #fff; z-index: 10; will-change: transform; }
        .plinko-pegs { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: space-evenly; align-items: center; padding: 16px 0 32px 0; pointer-events:none; }
        .plinko-row { display: flex; justify-content: center; gap: 18px; }
        .plinko-peg { width: 7px; height: 7px; background: #888; border-radius: 50%; box-shadow: 0 0 4px rgba(255,255,255,0.25), inset -1px -1px 3px rgba(0,0,0,0.8); }
        .plinko-bins { position: absolute; bottom: 0; left: 0; right: 0; display: flex; height: 22px; z-index: 5; }
        .plinko-bin { flex: 1; border-right: 1px solid rgba(255,255,255,0.12); display: flex; align-items: center; justify-content: center; font-size: 0.48em; font-weight: bold; color: #fff; background: rgba(0,0,0,0.9); min-width: 0; overflow: hidden; padding: 0; line-height: 1; text-shadow: 0 1px 2px rgba(0,0,0,0.9); }
        .plinko-bin:last-child { border-right: none; }
        .plinko-bin.active-bin { background: rgba(0,212,255,0.4) !important; color: #00d4ff !important; }
        
        /* Roulette CSS */
        .roulette-board { display:grid; grid-template-columns: 60px repeat(12, 1fr); grid-template-rows: repeat(3, 40px); gap:2px; max-width:800px; margin: 20px auto; background: #222; padding:5px; border-radius:10px; }
        .rl-spot { display:flex; align-items:center; justify-content:center; font-weight:bold; cursor:pointer; position:relative; background:#0b0b0b; color:white; border:1px solid #444; transition: 0.1s; }
        .rl-spot:hover { filter: brightness(1.3); }
        .rl-zero { grid-row: 1 / 4; background:#008800; border-radius:8px 0 0 8px; font-size:1.5em; }
        .rl-red { background:#cc0000; }
        .rl-black { background:#111; }
        .rl-outside { grid-column: 2 / 14; display:flex; gap:2px; margin-top:5px; }
        .rl-out-btn { flex:1; height:40px; background:#333; color:white; border:1px solid #555; display:flex; align-items:center; justify-content:center; font-weight:bold; cursor:pointer; }
        .rl-chip { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:24px; height:24px; border-radius:50%; background:var(--primary); color:black; font-size:0.6em; display:flex; align-items:center; justify-content:center; font-weight:bold; border:2px dashed black; z-index:10; pointer-events:none; }
        
        /* Physical Wheel Architecture */
        .rl-wheel-container { width:220px; height:220px; border-radius:50%; border:8px solid #333; margin:0 auto 20px; position:relative; overflow:hidden; background:#222; box-shadow: 0 5px 25px rgba(0,0,0,0.7), inset 0 0 15px rgba(0,0,0,0.8); }
        .rl-wheel-pointer { width:0; height:0; border-left:12px solid transparent; border-right:12px solid transparent; border-top:20px solid #fff; position:absolute; top:-2px; left:50%; transform:translateX(-50%); z-index:20; filter:drop-shadow(0 4px 4px rgba(0,0,0,0.7)); }
        #rl-wheel { width:100%; height:100%; position:relative; border-radius:50%; overflow:hidden; transition: transform 4s cubic-bezier(0.15, 0.85, 0.1, 1); }
        .rl-wedge { position:absolute; top:0; right:50%; width:50%; height:50%; transform-origin:100% 100%; display:flex; align-items:center; justify-content:center; overflow:hidden; border: 1px solid rgba(0,0,0,0.25); box-sizing: border-box; }
        .rl-wedge span { position:absolute; left:4px; top:14px; font-size: 0.55em; font-weight:bold; color:white; text-shadow: 0 0 3px rgba(0,0,0,0.9), 0 1px 2px rgba(0,0,0,1); white-space:nowrap; pointer-events:none; }

        .slots-reel { background: rgba(0,0,0,0.6); border: 2px solid var(--primary); border-radius: 12px; width: 100px; height: 110px; display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative; box-shadow: 0 0 15px rgba(0,212,255,0.2); }
        .slots-reel.spinning { animation: slotsBlur 0.15s linear infinite; border-color: #ffcc00; box-shadow: 0 0 20px rgba(255,204,0,0.4); }
        @keyframes slotsBlur { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
        .slots-reel.winner { border-color: #ffd700; box-shadow: 0 0 25px rgba(255,215,0,0.6); animation: slotsWin 0.4s ease 3; }
        @keyframes slotsWin { 0%,100%{transform:scale(1)} 50%{transform:scale(1.08)} }
        .rps-btn { font-size: 3em; background: rgba(0,0,0,0.4); border: 2px solid #555; border-radius: 15px; padding: 10px 20px; cursor: pointer; transition: 0.2s; }
        .rps-btn:hover { border-color: var(--primary); background: rgba(255,255,255,0.1); transform: scale(1.1); }
        .bj-card { display: inline-block; background: white; color: black; border-radius: 5px; padding: 10px; margin: 5px; font-size: 1.2em; font-weight: bold; width: 40px; text-align: center; box-shadow: 0 2px 5px rgba(0,0,0,0.5); }
        .bj-card.red { color: red; }
        
        .admin-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; width:100%; max-width:1100px; }
        .admin-box { background:rgba(0,0,0,0.3); padding:20px; border-radius:10px; border:1px solid var(--admin); max-height:400px; overflow-y:auto; backdrop-filter: blur(10px); }
        .admin-box.full { grid-column:span 2; max-height:none; }
        .profile-points-badge { background:rgba(0,0,0,0.5); border:2px solid var(--primary); border-radius:15px; padding:10px 20px; margin:10px 0; font-size:1.2em; color:var(--primary); font-weight:bold; backdrop-filter: blur(5px); }
        
        /* High-Pop Gradient Overrides */
        body.gradient-active #app-container { background: rgba(10, 10, 10, 0.25) !important; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
        body.gradient-active .sidebar, body.gradient-active .right-sidebar { background: rgba(0, 0, 0, 0.2) !important; border-color: rgba(255,255,255,0.1) !important; }
        body.gradient-active .msg { background: rgba(0, 0, 0, 0.45) !important; border-color: rgba(255,255,255,0.15) !important; box-shadow: 0 8px 16px rgba(0,0,0,0.2) !important; }
        body.gradient-active .input-area, body.gradient-active nav, body.gradient-active #chat-header { background: rgba(0, 0, 0, 0.3) !important; border-color: rgba(255,255,255,0.1) !important; }
        body.gradient-active .modal-card { backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px); border-color: rgba(255,255,255,0.2) !important; }

        /* Preview Modal Specifics */
        .preview-pane { background: var(--prev-bg); padding: 20px; border-radius: 10px; display: flex; gap: 10px; border: 1px solid #fff; }
        .prev-sidebar { background: var(--prev-sidebar); width: 100px; border-radius: 5px; padding: 10px; color: var(--prev-text); font-size: 0.8em; }
        .prev-chat { background: var(--prev-panel); flex: 1; border-radius: 5px; padding: 10px; display: flex; flex-direction: column; gap: 10px; }
        .prev-msg { background: var(--prev-msg-bg); color: var(--prev-text); padding: 8px; border-radius: 8px; width: fit-content; font-size: 0.8em; }
        .prev-msg.me { background: var(--prev-msg-me); align-self: flex-end; }
        .prev-input { background: rgba(0,0,0,0.5); border: 1px solid var(--prev-primary); border-radius: 5px; padding: 8px; margin-top: 10px; color: var(--prev-text); }
    </style>
</head>
<body>

<canvas id="mythic-canvas"></canvas>

<!-- Mythic Reveal Overlay -->
<div id="mythic-reveal-overlay" class="hidden"></div>

<!-- Loading Screen -->
<div id="loading-screen">
    <h1>AMAN CHAT</h1>
    <p id="loading-msg" style="color:#666; margin-bottom:20px; letter-spacing:2px;">Connecting...</p>
    <div class="loading-bar"><div class="loading-fill"></div></div>
</div>

<div id="app-container">
    <!-- Modals -->
    <!-- Custom Confirm Modal -->
    <div id="modal-confirm" class="modal hidden">
        <div class="modal-card" style="max-width:380px;">
            <div id="confirm-icon" style="font-size:2.5em; margin-bottom:10px;">❓</div>
            <h3 id="confirm-title" style="color:var(--primary); margin:0 0 10px;">Are you sure?</h3>
            <p id="confirm-msg" style="color:#ddd; margin-bottom:20px; font-size:0.95em;"></p>
            <div style="display:flex; gap:10px;">
                <button class="btn" id="confirm-yes-btn" style="flex:1; font-weight:bold;">Confirm</button>
                <button class="btn" style="flex:1; background:rgba(255,255,255,0.1); color:white;" onclick="closeM('modal-confirm'); if(window._confirmReject) window._confirmReject();">Cancel</button>
            </div>
        </div>
    </div>

    <div id="modal-delete-srv" class="modal hidden">
        <div class="modal-card">
            <h3 style="color:red; font-size:1.5em; margin-top:0;">🗑️ Delete Server</h3>
            <p style="color:#ddd; margin-bottom:20px;">Are you absolutely sure you want to delete this server? This action <strong>cannot be undone</strong> and all chat history will be lost forever.</p>
            <div style="display:flex; gap:10px;">
                <button class="btn" style="flex:1; background:red; color:white; box-shadow:0 0 10px rgba(255,0,0,0.5);" onclick="confirmDeleteServer()">Yes, Delete</button>
                <button class="btn" style="flex:1; background:rgba(255,255,255,0.1); color:white;" onclick="closeM('modal-delete-srv')">Cancel</button>
            </div>
        </div>
    </div>

    <!-- Theme Preview Modal -->
    <div id="modal-theme-preview" class="modal hidden">
        <div class="modal-card" style="width: 600px;">
            <h3 style="color:var(--primary); margin-top:0;">🎨 Live Theme Preview</h3>
            <div id="preview-container" class="preview-pane">
                <div class="prev-sidebar"># general<br># rules<br><br>Users Online: 2</div>
                <div class="prev-chat">
                    <div class="prev-msg"><strong style="color:var(--prev-primary)">@Howard</strong><br>Check out this new theme!</div>
                    <div class="prev-msg me"><strong style="color:var(--prev-primary)">@You</strong><br>Looks awesome!</div>
                    <div class="prev-input">Type message...</div>
                </div>
            </div>
            <button class="btn primary" style="width:100%; margin-top:15px;" onclick="closeM('modal-theme-preview')">Close Preview</button>
        </div>
    </div>

    <div id="modal-profile" class="modal hidden" onclick="closeM('modal-profile')">
        <div class="modal-card" onclick="event.stopPropagation()">
            <div id="view-title-display" style="margin-bottom:4px; font-size:0.9em; position:relative; z-index:2;"></div>
            <h2 id="view-user" style="color:var(--primary); margin:0; position:relative; z-index:2;">@User</h2>
            <img id="view-pfp" style="width:140px; height:140px; background:white; border-radius:10px; margin:12px 0; border:2px solid var(--primary); position:relative; z-index:2;">
            <p id="view-bio" style="font-style:italic; color:#aaa; min-height:30px; margin:5px 0; position:relative; z-index:2;"></p>
            <p id="view-rank" style="font-weight:bold; color:var(--admin); margin:5px 0; position:relative; z-index:2;"></p>
            <div id="view-points-display" style="color:#aaa; font-size:0.9em; margin-bottom:10px; position:relative; z-index:2;"></div>
            <div id="prof-actions" style="display:flex; flex-direction:column; gap:10px; margin-bottom:15px; position:relative; z-index:2;">
                <button class="btn primary" id="prof-btn-add" onclick="profActionAdd()">Add Friend</button>
                <button class="btn" id="prof-btn-trade" style="background:rgba(0,0,0,0.5); color:var(--primary); border:1px solid var(--primary);" onclick="openTradeFromProfile()">📦 Trade</button>
                <button class="btn" id="prof-btn-report" style="background:rgba(0,0,0,0.5); color:white; border:1px solid red;" onclick="openReportModal()">Report User</button>
            </div>
            <button class="btn" style="width:100%; background:rgba(0,0,0,0.5); color:#ddd; position:relative; z-index:2;" onclick="closeM('modal-profile')">Close</button>
        </div>
    </div>

    <div id="modal-draw-msg" class="modal hidden">
        <div class="modal-card">
            <h3>Draw a Message</h3>
            <canvas id="msg-draw-canvas" width="280" height="200" style="border:2px solid #333; background:white; cursor:crosshair; border-radius:10px; touch-action:none;"></canvas>
            <div style="display:flex; gap:10px; margin:15px 0; align-items:center; justify-content:center;">
                <label>Color:</label>
                <input type="color" id="msg-draw-color" value="#000000" style="padding:0; width:40px; height:40px; cursor:pointer;">
                <button class="btn" style="background:#444; color:white; flex:1;" onclick="clearMsgDraw()">Clear</button>
            </div>
            <button class="btn primary" style="width:100%; margin-bottom:10px;" onclick="sendDrawMsg()">Send Drawing</button>
            <button class="btn" style="width:100%; background:none; color:#ddd;" onclick="closeM('modal-draw-msg')">Cancel</button>
        </div>
    </div>

    <div id="modal-srv-mod" class="modal hidden">
        <div class="modal-card">
            <h3 style="color:var(--primary);">Server Moderation</h3>
            <input type="text" id="srv-mod-user" placeholder="Target Username" style="margin-bottom:15px; width:calc(100% - 24px);">
            <div style="display:flex; flex-direction:column; gap:10px;">
                <button class="btn" style="background:#ff9900; color:black;" onclick="srvModAct('mute')">Mute (Hours)</button>
                <button class="btn" style="background:var(--admin); color:white;" onclick="srvModAct('ban')">Ban from Server</button>
            </div>
            <button class="btn" style="width:100%; background:none; color:#ddd; margin-top:15px;" onclick="closeM('modal-srv-mod')">Done</button>
        </div>
    </div>

    <div id="modal-report" class="modal hidden">
        <div class="modal-card">
            <h3 style="color:red;">Report User</h3>
            <p style="font-size:0.8em; color:#aaa;" id="report-target-txt"></p>
            <textarea id="report-reason" placeholder="Reason for reporting..." style="height:80px; margin-bottom:15px; width:90%;"></textarea>
            <button class="btn primary" style="width:100%; margin-bottom:10px;" onclick="submitReport()">Submit Report</button>
            <button class="btn" style="width:100%; background:none; color:#ddd;" onclick="closeM('modal-report')">Cancel</button>
        </div>
    </div>

    <div id="modal-code" class="modal hidden">
        <div class="modal-card">
            <h3>Server Code</h3>
            <p style="font-size:0.8em; color:#aaa;">Share this code with friends to let them join your private server.</p>
            <h1 id="display-code-val" style="color:var(--primary); letter-spacing:5px;">XXXX</h1>
            <button class="btn primary" style="width:100%; margin-top:15px;" onclick="closeM('modal-code')">Done</button>
        </div>
    </div>

    <div id="modal-server" class="modal hidden">
        <div class="modal-card">
            <h3 id="srv-modal-title">Create Server</h3>
            <input type="text" id="srv-name-in" placeholder="Server name?">
            <button class="btn primary" style="width:100%; margin-top:15px;" onclick="executeServerCreate()">Create It!</button>
            <button class="btn" style="width:100%; background:none; color:#ddd;" onclick="closeM('modal-server')">Cancel</button>
        </div>
    </div>

    <div id="modal-join-priv" class="modal hidden">
        <div class="modal-card">
            <h3>Join Private Server</h3>
            <input type="text" id="priv-code-in" placeholder="Code..." maxlength="4" style="text-align:center; font-size:1.5em; text-transform:uppercase;">
            <button class="btn primary" style="width:100%; margin-top:15px;" onclick="executeJoinPrivate()">Join Server</button>
            <button class="btn" style="width:100%; background:none; color:#ddd;" onclick="closeM('modal-join-priv')">Cancel</button>
        </div>
    </div>

    <div id="modal-add-chan" class="modal hidden">
        <div class="modal-card">
            <h3>Add Chat Chain</h3>
            <input type="text" id="chan-name-in" placeholder="channel-name">
            <button class="btn primary" style="width:100%; margin-top:15px;" onclick="executeAddChannel()">Create Chain</button>
            <button class="btn" style="width:100%; background:none; color:#ddd;" onclick="closeM('modal-add-chan')">Cancel</button>
        </div>
    </div>

    <div id="lootbox-open-modal" class="modal hidden">
        <div class="modal-card" style="min-height:380px; position:relative;">
            <h3 id="lb-open-title" style="color:var(--primary);">Opening Lootbox...</h3>
            <div id="lb-opening-phase">
                <span id="lb-open-box" class="lb-open-box">📦</span>
                <p style="color:#aaa; margin:5px 0;">Tap the box to open!</p>
                <button id="lb-tap-btn" class="btn primary" style="width:100%; margin-top:10px;" onclick="shakeLootbox()">🎲 Open It!</button>
            </div>
            <div id="lb-result-phase" class="hidden">
                <div class="lb-result-item" id="lb-result-inner">
                    <div id="lb-sparkle-container" style="position:absolute; top:50%; left:50%; pointer-events:none; z-index: 100;">
                    </div>
                    <div id="lb-result-icon" style="font-size:3.5em; margin-bottom:10px; position:relative; z-index:2;"></div>
                    <div id="lb-result-rarity" style="margin-bottom:8px; position:relative; z-index:2;"></div>
                    <div id="lb-result-name" style="font-size:1.3em; font-weight:bold; color:var(--text); position:relative; z-index:2;"></div>
                    <div id="lb-result-type" style="font-size:0.85em; color:#888; margin-top:4px; position:relative; z-index:2;"></div>
                    <div id="lb-dupe-notice" style="font-size:0.8em; color:#ff9900; margin-top:6px; position:relative; z-index:2;" class="hidden">Already owned — added as duplicate!</div>
                </div>
                <button class="btn primary" style="width:100%; margin-top:20px;" onclick="closeM('lootbox-open-modal'); loadInventory();">Claim!</button>
            </div>
        </div>
    </div>

    <div id="modal-trade-create" class="modal hidden">
        <div class="modal-card" style="width:700px; max-width:96vw;">
            <h3 style="color:var(--primary);">📦 Create Trade</h3>
            <div style="display:flex; gap:15px; flex-wrap:wrap; margin-bottom:15px;">
                <div style="flex:1; min-width:200px;">
                    <div style="font-size:0.85em; color:#aaa; margin-bottom:5px;">Trade Partner:</div>
                    <select id="trade-partner-sel" style="width:100%;" onchange="loadPartnerInventory()">
                        <option value="">-- Select Friend --</option>
                    </select>
                </div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:15px; margin-bottom:15px;">
                <div>
                    <div style="font-weight:bold; color:var(--primary); margin-bottom:8px;">Your Offer</div>
                    <input type="number" id="trade-my-points" placeholder="Points to offer" min="0" style="margin-bottom:8px; width:calc(100% - 24px);">
                    <div style="font-size:0.8em; color:#aaa; margin-bottom:5px;">Select items from your inventory:</div>
                    <div id="trade-my-items-grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(90px,1fr)); gap:6px; max-height:200px; overflow-y:auto;"></div>
                    <div id="trade-my-selected" style="margin-top:8px; font-size:0.8em; color:#aaa;">No items selected</div>
                </div>
                <div>
                    <div style="font-weight:bold; color:#ff9900; margin-bottom:8px;">Their Offer (Request)</div>
                    <input type="number" id="trade-their-points" placeholder="Points you want" min="0" style="margin-bottom:8px; width:calc(100% - 24px);">
                    <div style="font-size:0.8em; color:#aaa; margin-bottom:5px;">Select from their inventory:</div>
                    <div id="trade-their-items-grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(90px,1fr)); gap:6px; max-height:200px; overflow-y:auto;"></div>
                    <div id="trade-their-selected" style="margin-top:8px; font-size:0.8em; color:#aaa;">No items selected</div>
                </div>
            </div>
            <button class="btn primary" style="width:100%; margin-bottom:8px;" onclick="sendTradeRequest()">Send Trade Request</button>
            <button class="btn" style="width:100%; background:none; color:#ddd;" onclick="closeM('modal-trade-create')">Cancel</button>
        </div>
    </div>

    <div id="modal-trade-view" class="modal hidden">
        <div class="modal-card" style="width:600px; max-width:95vw;">
            <h3 style="color:var(--primary);">📦 Trade Offer</h3>
            <p id="tv-from-user" style="color:#aaa;"></p>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:15px; margin:15px 0;">
                <div class="trade-side"><div style="font-weight:bold; color:#ff9900; margin-bottom:8px;">They Offer:</div><div id="tv-their-offer"></div></div>
                <div class="trade-side"><div style="font-weight:bold; color:var(--primary); margin-bottom:8px;">They Want:</div><div id="tv-want-offer"></div></div>
            </div>
            <div style="display:flex; gap:10px;">
                <button class="btn primary" style="flex:1;" onclick="executeTrade('accept')">✅ Accept</button>
                <button class="btn" style="flex:1; background:rgba(0,0,0,0.5); color:var(--admin); border:1px solid var(--admin);" onclick="executeTrade('decline')">❌ Decline</button>
            </div>
            <button class="btn" style="width:100%; background:none; color:#ddd; margin-top:8px;" onclick="closeM('modal-trade-view')">Close</button>
        </div>
    </div>

    <div id="modal-market-create" class="modal hidden">
        <div class="modal-card" style="width:680px; max-width:96vw;">
            <h3 style="color:var(--primary);">🌐 Post Market Offer</h3>
            <p style="color:#aaa; font-size:0.85em; margin-top:0;">Anyone who holds the required items can accept your offer.</p>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:15px; margin-bottom:15px;">
                <div>
                    <div style="font-weight:bold; color:var(--primary); margin-bottom:8px;">You Give</div>
                    <input type="number" id="mkt-give-points" placeholder="Points to give" min="0" style="margin-bottom:8px; width:calc(100% - 24px);">
                    <div style="font-size:0.8em; color:#aaa; margin-bottom:5px;">Items to give:</div>
                    <div id="mkt-give-grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(90px,1fr)); gap:6px; max-height:200px; overflow-y:auto;"></div>
                    <div id="mkt-give-selected" style="margin-top:8px; font-size:0.8em; color:#aaa;">No items selected</div>
                </div>
                <div>
                    <div style="font-weight:bold; color:#ff9900; margin-bottom:8px;">You Want (Conditions)</div>
                    <input type="number" id="mkt-want-points" placeholder="Min points acceptor must have" min="0" style="margin-bottom:8px; width:calc(100% - 24px);">
                    <div style="font-size:0.8em; color:#aaa; margin-bottom:5px;">Required items acceptor must own:</div>
                    <div id="mkt-want-type-tabs" style="display:flex; gap:5px; margin-bottom:8px; flex-wrap:wrap;">
                        <button class="btn" style="padding:4px 8px; font-size:0.75em; background:var(--primary); color:black;" id="mkt-want-tab-theme" onclick="setMktWantTab('theme')">🎨 Themes</button>
                        <button class="btn" style="padding:4px 8px; font-size:0.75em; background:rgba(0,0,0,0.5); color:white;" id="mkt-want-tab-title" onclick="setMktWantTab('title')">🏷️ Titles</button>
                        <button class="btn" style="padding:4px 8px; font-size:0.75em; background:rgba(0,0,0,0.5); color:white;" id="mkt-want-tab-lootbox" onclick="setMktWantTab('lootbox')">📦 Boxes</button>
                    </div>
                    <div id="mkt-want-grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(90px,1fr)); gap:6px; max-height:180px; overflow-y:auto;"></div>
                    <div id="mkt-want-selected" style="margin-top:8px; font-size:0.8em; color:#aaa;">No conditions set</div>
                </div>
            </div>
            <button class="btn primary" style="width:100%; margin-bottom:8px;" onclick="submitMarketOffer()">📢 Post to Market</button>
            <button class="btn" style="width:100%; background:none; color:#ddd;" onclick="closeM('modal-market-create')">Cancel</button>
        </div>
    </div>
    <!-- Poker Invite Modal -->
    <div id="modal-poker-invite" class="modal hidden">
        <div class="modal-card" style="width:420px; max-width:96vw;">
            <h3 style="color:var(--primary); margin-top:0;">📨 Invite Players</h3>
            <p style="color:#aaa; font-size:0.88em; margin-bottom:12px;">Select online users to send a DM invite with your game code.</p>
            <div id="poker-invite-list" style="max-height:260px; overflow-y:auto; margin-bottom:14px;"></div>
            <div style="display:flex; gap:10px; justify-content:flex-end;">
                <button class="btn" onclick="pokerSendInvites()" style="background:rgba(0,100,0,0.4);">Send Invites</button>
                <button class="btn" style="background:rgba(0,0,0,0.4);" onclick="closeM('modal-poker-invite')">Cancel</button>
            </div>
        </div>
    </div>

    <div id="section-auth" style="padding:10vh 20px; text-align:center; flex:1; overflow-y:auto; position:relative; z-index:2;">
        <h1 style="color:var(--primary); letter-spacing:4px; font-size:3em; text-shadow: 0 4px 10px rgba(0,0,0,0.5);">AMAN CHAT</h1>
        <div id="auth-initial">
            <button class="btn primary" style="width:250px; margin:10px auto;" onclick="setAuth('login')">Login</button><br>
            <button class="btn" style="width:250px; background:rgba(0,0,0,0.6); color:white; margin:0 auto;" onclick="setAuth('create')">Create Account</button>
        </div>
        <div id="auth-inputs" class="hidden" style="max-width:300px; margin:auto; background:rgba(0,0,0,0.6); padding:20px; border-radius:15px; backdrop-filter: blur(10px);">
