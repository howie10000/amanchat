<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>
<script>
// =========================================================
//  FIREBASE INIT
// =========================================================
const firebaseConfig = { databaseURL: "https://chattest-70259-default-rtdb.firebaseio.com/" };
firebase.initializeApp(firebaseConfig);
const db = firebase.database();

// =========================================================
//  GLOBAL STATE
// =========================================================
let user = null, role = 'user', canCreateSrv = false;
let aId = null, aType = null, aChan = 'chat-1', aSrvOwner = null, aMyRole = null, aIsAnnouncements = false;
let authMode = 'login', typingTimeout, isCreatingPrivate = false;
let currentViewUser = null;
let unreadDMs = {}, unreadServers = {};
let myPoints = 0, myInventory = { themes: {}, titles: {}, lootboxes: {} }, myCeremonial = {};
let myActiveTitle = null, myActiveTheme = 'dark';
let pendingLootboxIndex = null, pendingLootResult = null, openingFromInventory = false;
let pendingTradeId = null;
let myFriends = [];
let tradeMySelected = [], tradeTheirSelected = [];
let sessionMsgCount = 0;
let currentPartnerInventory = null;

// DB-loaded config
let ALL_THEMES = {};
let ALL_TITLES = {};
let LOOT_POOL = { common:[], rare:[], epic:[], legendary:[], mythic:[] };
let configLoaded = false;

// =========================================================
//  CANVAS BACKGROUND ENGINE (MYTHICS)
// =========================================================
let bgAnimFrame;
function startBgAnimation(themeId) {
    cancelAnimationFrame(bgAnimFrame);
    const canvas = document.getElementById('mythic-canvas');
    if (!themeId.startsWith('mythic_')) {
        canvas.style.display = 'none';
        return;
    }
    
    canvas.style.display = 'block';
    const ctx = canvas.getContext('2d');
    let W = canvas.width = window.innerWidth;
    let H = canvas.height = window.innerHeight;
    window.addEventListener('resize', () => { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; });

    let particles = [];

    if (themeId === 'mythic_matrix') {
        const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789ｦｧｨｩｪｫｬｭｮｯｰ@#$%^&*<>{}[]|/\\';
        const fontSize = 16;
        const columns = Math.floor(W / fontSize);
        // Each column: [yPos, speed, brightness, charTimer]
        const drops = Array.from({length: columns}, () => ({
            y: Math.random() * -50,
            speed: Math.random() * 1.5 + 0.5,
            bright: Math.random() > 0.92,  // rare bright columns
            len: Math.floor(Math.random() * 20 + 10),
            trail: []
        }));

        function drawMatrix() {
            // Dark semi-transparent overlay — less fade = longer visible trails
            ctx.fillStyle = 'rgba(0, 0, 0, 0.18)';
            ctx.fillRect(0, 0, W, H);

            drops.forEach((col, i) => {
                col.y += col.speed;

                // Build trail: each entry is {ch, alpha}
                col.trail.unshift(chars[Math.floor(Math.random() * chars.length)]);
                if (col.trail.length > col.len) col.trail.pop();

                col.trail.forEach((ch, t) => {
                    const yPos = (col.y - t) * fontSize;
                    if (yPos < -fontSize || yPos > H) return;

                    if (t === 0) {
                        // Glowing white head
                        ctx.shadowBlur = 18;
                        ctx.shadowColor = '#afffaf';
                        ctx.fillStyle = '#ffffff';
                    } else if (t < 3) {
                        // Bright green near head
                        ctx.shadowBlur = 10;
                        ctx.shadowColor = '#00ff41';
                        ctx.fillStyle = col.bright ? '#88ffaa' : '#00ff41';
                    } else {
                        // Fade tail: green → dark green
                        const alpha = Math.max(0.05, 1 - t / col.len);
                        ctx.shadowBlur = 0;
                        ctx.shadowColor = 'transparent';
                        ctx.fillStyle = col.bright
                            ? `rgba(100,255,140,${alpha})`
                            : `rgba(0,${Math.floor(180 * alpha + 40)},0,${alpha})`;
                    }
                    ctx.font = `${fontSize}px monospace`;
                    ctx.fillText(ch, i * fontSize, yPos);
                });

                ctx.shadowBlur = 0;

                // Reset column when it scrolls off bottom
                if (col.y * fontSize > H + col.len * fontSize && Math.random() > 0.97) {
                    col.y = Math.random() * -30;
                    col.speed = Math.random() * 1.5 + 0.5;
                    col.bright = Math.random() > 0.92;
                    col.len = Math.floor(Math.random() * 20 + 10);
                    col.trail = [];
                }
            });
            bgAnimFrame = requestAnimationFrame(drawMatrix);
        }
        drawMatrix();
    } 
    else if (themeId === 'mythic_void') {
        for(let i=0; i<300; i++) particles.push({ angle: Math.random()*Math.PI*2, radius: Math.random()*W, speed: Math.random()*0.02+0.005 });
        
        function drawVoid() {
            ctx.fillStyle = 'rgba(10, 0, 20, 0.2)';
            ctx.fillRect(0, 0, W, H);
            const cx = W/2, cy = H/2;
            
            // Heavy Bloom Effects
            ctx.shadowBlur = 20;
            ctx.shadowColor = '#aa00ff';
            
            particles.forEach(p => {
                p.angle += p.speed;
                p.radius -= 2;
                if(p.radius < 10) { p.radius = W; p.angle = Math.random()*Math.PI*2; }
                const x = cx + Math.cos(p.angle) * p.radius;
                const y = cy + Math.sin(p.angle) * p.radius;
                ctx.fillStyle = `rgba(170, 0, 255, ${Math.min(1, p.radius/300)})`;
                ctx.beginPath(); ctx.arc(x, y, 2.5, 0, Math.PI*2); ctx.fill();
            });

            ctx.shadowBlur = 50;
            ctx.shadowColor = '#ff00aa';
            ctx.fillStyle = '#000';
            ctx.beginPath(); ctx.arc(cx, cy, 60, 0, Math.PI*2); ctx.fill();
            ctx.strokeStyle = '#aa00ff'; ctx.lineWidth = 4;
            ctx.stroke();

            bgAnimFrame = requestAnimationFrame(drawVoid);
        }
        drawVoid();
    }
    else if (themeId === 'mythic_inferno') {
        // Fire columns — each is a vertical flame strip
        const COLS = Math.ceil(W / 8);
        // noise buffer for flame shape
        let noiseA = new Float32Array(COLS).map(() => Math.random());
        let noiseB = new Float32Array(COLS).map(() => Math.random());

        // Embers / sparks rising upward
        const embers = Array.from({length: 200}, () => ({
            x: Math.random()*W,
            y: H * (0.4 + Math.random()*0.6),
            vx: (Math.random()-0.5)*1.2,
            vy: -(Math.random()*3+1.5),
            size: Math.random()*3+1,
            life: Math.random(),
            maxLife: Math.random()*0.6+0.4,
            hue: Math.random()*40  // orange to yellow
        }));

        // Large glowing fire balls that drift up
        const fireballs = Array.from({length: 18}, () => ({
            x: Math.random()*W,
            y: H * (0.5 + Math.random()*0.5),
            r: Math.random()*60+20,
            vy: -(Math.random()*1.5+0.5),
            vx: (Math.random()-0.5)*0.8,
            hue: Math.random()*30,
            alpha: Math.random()*0.4+0.2
        }));

        let tick = 0;

        function drawInferno() {
            tick++;

            // Dark red background base
            ctx.fillStyle = '#0d0000';
            ctx.fillRect(0, 0, W, H);

            // ── Bottom gradient glow pool ──────────────────────────────────────
            const poolGrad = ctx.createLinearGradient(0, H*0.55, 0, H);
            poolGrad.addColorStop(0, 'rgba(255,80,0,0)');
            poolGrad.addColorStop(0.5, 'rgba(255,40,0,0.35)');
            poolGrad.addColorStop(1, 'rgba(255,100,0,0.7)');
            ctx.fillStyle = poolGrad;
            ctx.fillRect(0, H*0.55, W, H*0.45);

            // ── Flickering fire layer (column-based) ──────────────────────────
            // Advance noise: shift left and add new random on right
            for(let i = 0; i < COLS-1; i++) noiseA[i] = (noiseA[i]*0.85 + noiseA[i+1]*0.1 + Math.random()*0.05);
            for(let i = 0; i < COLS-1; i++) noiseB[i] = (noiseB[i]*0.78 + noiseB[i+1]*0.15 + Math.random()*0.07);
            noiseA[COLS-1] = Math.random(); noiseB[COLS-1] = Math.random();

            const colW = W / COLS;
            for(let i = 0; i < COLS; i++) {
                const flameH = (noiseA[i]*0.55 + noiseB[i]*0.45) * H * 0.72;
                const x = i * colW;
                const grad = ctx.createLinearGradient(x, H, x, H - flameH);
                grad.addColorStop(0,   'rgba(255,220,0,0.95)');
                grad.addColorStop(0.15,'rgba(255,140,0,0.9)');
                grad.addColorStop(0.45,'rgba(255,40,0,0.7)');
                grad.addColorStop(0.75,'rgba(180,10,0,0.35)');
                grad.addColorStop(1,   'rgba(80,0,0,0)');
                ctx.fillStyle = grad;
                ctx.fillRect(x, H - flameH, colW + 1, flameH);
            }

            // ── Floating fireballs (soft glowing blobs) ───────────────────────
            fireballs.forEach(fb => {
                fb.y += fb.vy;
                fb.x += fb.vx + Math.sin(tick*0.02 + fb.x)*0.3;
                if(fb.y < H*0.1) { fb.y = H*(0.6+Math.random()*0.4); fb.x = Math.random()*W; }
                const g = ctx.createRadialGradient(fb.x, fb.y, 0, fb.x, fb.y, fb.r);
                g.addColorStop(0,   `hsla(${fb.hue+50},100%,90%,${fb.alpha*1.4})`);
                g.addColorStop(0.3, `hsla(${fb.hue+30},100%,60%,${fb.alpha})`);
                g.addColorStop(0.7, `hsla(${fb.hue+10},100%,35%,${fb.alpha*0.5})`);
                g.addColorStop(1,   'transparent');
                ctx.fillStyle = g;
                ctx.beginPath(); ctx.arc(fb.x, fb.y, fb.r, 0, Math.PI*2); ctx.fill();
                fb.hue = (fb.hue + 0.2) % 40;
            });

            // ── Ember sparks ──────────────────────────────────────────────────
            embers.forEach(e => {
                e.x += e.vx + Math.sin(tick*0.03 + e.y*0.01)*0.5;
                e.y += e.vy;
                e.life += 0.012;
                if(e.life > e.maxLife || e.y < 0) {
                    e.x = Math.random()*W;
                    e.y = H*(0.6 + Math.random()*0.4);
                    e.vy = -(Math.random()*3+1.5);
                    e.vx = (Math.random()-0.5)*1.2;
                    e.life = 0; e.maxLife = Math.random()*0.6+0.4;
                }
                const alpha = Math.sin(Math.PI * e.life / e.maxLife);
                ctx.shadowBlur = 8;
                ctx.shadowColor = `hsl(${e.hue+30},100%,70%)`;
                ctx.fillStyle = `hsla(${e.hue+50},100%,85%,${alpha})`;
                ctx.beginPath();
                ctx.arc(e.x, e.y, e.size*(1-e.life*0.7), 0, Math.PI*2);
                ctx.fill();
            });
            ctx.shadowBlur = 0;

            bgAnimFrame = requestAnimationFrame(drawInferno);
        }
        drawInferno();
    }
    else if (themeId === 'mythic_ocean') {
        // ── DEEP OCEAN — Tidal waves, fast fish, falling debris, ripples, sunlight glares ──────
        
        // Tidal wave columns (dramatic, like inferno fire)
        const WAVE_COLS = Math.ceil(W / 10);
        let waveNoiseA = new Float32Array(WAVE_COLS).map(() => Math.random());
        let waveNoiseB = new Float32Array(WAVE_COLS).map(() => Math.random());
        
        // Fast swimming fish (left to right and right to left)
        const fastFish = Array.from({length: 20}, () => ({
            x: Math.random() * W,
            y: Math.random() * H * 0.7 + H * 0.15,
            size: Math.random() * 25 + 15,
            vx: (Math.random() > 0.5 ? 1 : -1) * (Math.random() * 4 + 3),
            vy: (Math.random() - 0.5) * 0.5,
            color: Math.random() > 0.7 ? '#ff6b6b' : Math.random() > 0.4 ? '#ffd93d' : '#6bcb77'
        }));
        
        // Falling debris (physics-based, creates ripples on impact)
        const fallingDebris = Array.from({length: 8}, () => ({
            x: Math.random() * W,
            y: -50 - Math.random() * 200,
            vy: 0,
            size: Math.random() * 8 + 4,
            active: true,
            rippleRadius: 0,
            rippleAlpha: 0
        }));
        
        // Water ripples (expanding circles)
        const ripples = [];
        
        // Sunlight glares (occasional bright spots)
        const sunGlare = {
            x: Math.random() * W,
            y: Math.random() * H * 0.4,
            radius: 0,
            maxRadius: Math.random() * 100 + 50,
            alpha: 0,
            phase: 'fadein',
            timer: 0
        };
        
        // Rising bubbles
        const bubbles = Array.from({length: 100}, () => ({
            x: Math.random() * W,
            y: Math.random() * H,
            r: Math.random() * 4 + 1,
            speed: Math.random() * 1.5 + 0.5,
            wobble: Math.random() * Math.PI * 2,
            wobbleSpeed: Math.random() * 0.03 + 0.01
        }));
        
        // Bioluminescent particles
        const biolums = Array.from({length: 150}, () => ({
            x: Math.random() * W,
            y: Math.random() * H,
            r: Math.random() * 3 + 0.5,
            vx: (Math.random() - 0.5) * 0.3,
            vy: (Math.random() - 0.5) * 0.3,
            life: Math.random(),
            hue: Math.random() * 60 + 160
        }));
        
        // Light rays from surface
        const lightRays = Array.from({length: 8}, () => ({
            x: Math.random() * W,
            angle: (Math.random() - 0.5) * 0.3,
            width: Math.random() * 100 + 50,
            speed: Math.random() * 0.002 + 0.001,
            offset: Math.random() * Math.PI * 2,
            alpha: Math.random() * 0.06 + 0.03
        }));
        
        // Dim surface light that pulses in and out
        let surfaceLight = {
            alpha: 0,
            phase: 'in',
            speed: 0.003 + Math.random() * 0.002
        };
        
        let tick = 0;
        
        function drawOcean() {
            tick++;
            
            // Deep ocean gradient background
            const gradient = ctx.createLinearGradient(0, 0, 0, H);
            gradient.addColorStop(0, '#002a4d');
            gradient.addColorStop(0.3, '#001a33');
            gradient.addColorStop(0.6, '#001122');
            gradient.addColorStop(0.85, '#000811');
            gradient.addColorStop(1, '#000000');
            ctx.fillStyle = gradient;
            ctx.fillRect(0, 0, W, H);
            
            // ── Tidal waves (dramatic, like inferno fire columns) ─────────────────
            for(let i = 0; i < WAVE_COLS-1; i++) waveNoiseA[i] = (waveNoiseA[i]*0.85 + waveNoiseA[i+1]*0.1 + Math.random()*0.05);
            for(let i = 0; i < WAVE_COLS-1; i++) waveNoiseB[i] = (waveNoiseB[i]*0.8 + waveNoiseB[i+1]*0.15 + Math.random()*0.05);
            waveNoiseA[WAVE_COLS-1] = Math.random(); waveNoiseB[WAVE_COLS-1] = Math.random();
            
            const waveColW = W / WAVE_COLS;
            for(let i = 0; i < WAVE_COLS; i++) {
                const waveH = (waveNoiseA[i]*0.55 + waveNoiseB[i]*0.45) * H * 0.7;
                const x = i * waveColW;
                const waveGrad = ctx.createLinearGradient(x, H, x, H - waveH);
                waveGrad.addColorStop(0, 'rgba(0, 180, 220, 0.7)');
                waveGrad.addColorStop(0.15, 'rgba(0, 140, 200, 0.6)');
                waveGrad.addColorStop(0.4, 'rgba(0, 100, 160, 0.4)');
                waveGrad.addColorStop(0.7, 'rgba(0, 60, 120, 0.2)');
                waveGrad.addColorStop(1, 'rgba(0, 30, 80, 0)');
                ctx.fillStyle = waveGrad;
                ctx.fillRect(x, H - waveH, waveColW + 1, waveH);
            }
            
            // ── Light rays from surface ─────────────────────────────────────
            lightRays.forEach(ray => {
                ray.offset += ray.speed;
                const alpha = ray.alpha * (0.6 + 0.4 * Math.sin(ray.offset));
                ctx.save();
                ctx.translate(ray.x, 0);
                ctx.rotate(ray.angle);
                const rayGrad = ctx.createLinearGradient(0, 0, 0, H);
                rayGrad.addColorStop(0, `rgba(180, 240, 255, ${alpha * 2})`);
                rayGrad.addColorStop(0.4, `rgba(100, 200, 255, ${alpha})`);
                rayGrad.addColorStop(0.8, `rgba(50, 150, 220, ${alpha * 0.5})`);
                rayGrad.addColorStop(1, 'rgba(0, 50, 100, 0)');
                ctx.fillStyle = rayGrad;
                ctx.beginPath();
                ctx.moveTo(-ray.width / 2, 0);
                ctx.lineTo(ray.width / 2, 0);
                ctx.lineTo(ray.width * 1.3, H);
                ctx.lineTo(-ray.width * 1.3, H);
                ctx.closePath();
                ctx.fill();
                ctx.restore();
            });
            
