// Weighted reel pool — high-value symbols appear less often
// 🍒 appears 10× (most common), ⭐ appears 1× (rarest)
const SLOT_POOL = [
    '🍒','🍒','🍒','🍒','🍒','🍒','🍒','🍒','🍒','🍒','🍒','🍒', // 12 — very common
    '🍋','🍋','🍋','🍋','🍋','🍋','🍋','🍋',                       //  8 — common
    '🔔','🔔','🔔','🔔','🔔','🔔',                                   //  6 — uncommon
    '💎','💎','💎','💎','💎',                                        //  5 — rare
    '7️⃣','7️⃣','7️⃣','7️⃣',                                         //  4 — very rare
    '⭐','⭐','⭐'                                                   //  3 — ultra rare
];
const SLOT_PAYS = { '🍒🍒🍒':5, '🍋🍋🍋':8, '🔔🔔🔔':12, '💎💎💎':25, '7️⃣7️⃣7️⃣':50, '⭐⭐⭐':100 };
let slotsSpinning = false;

async function playSlotsGame() {
    if(slotsSpinning) return;
    const bet = parseInt(document.getElementById('slots-bet').value);
    if(!bet || bet < 1 || bet > 10000) return alert("Enter bet between 1 and 10,000.");
    if(myPoints < bet) return alert("Not enough points.");

    slotsSpinning = true;
    const btn = document.getElementById('slots-btn');
    btn.disabled = true;
    document.getElementById('slots-status').innerText = "Spinning...";
    document.getElementById('slots-status').style.color = '#ffcc00';

    await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-bet));

    // Animate reels spinning
    const reelIds = ['slots-r0','slots-r1','slots-r2'];
    reelIds.forEach(id => document.getElementById(id).classList.add('spinning'));

    // Pick results after staggered delays
    const results = [];
    for(let i = 0; i < 3; i++) {
        await new Promise(r => setTimeout(r, 600 + i * 400));
        const sym = SLOT_POOL[Math.floor(Math.random() * SLOT_POOL.length)];
        results.push(sym);
        document.getElementById(`slots-r${i}-sym`).innerText = sym;
        document.getElementById(`slots-r${i}`).classList.remove('spinning');
    }

    await new Promise(r => setTimeout(r, 200));

    const key = results.join('');
    let multiplier = 0;
    let win = 0;

    if(SLOT_PAYS[key]) {
        multiplier = SLOT_PAYS[key];
        win = Math.floor(bet * multiplier);
        reelIds.forEach(id => document.getElementById(id).classList.add('winner'));
        document.getElementById('slots-status').innerText = `🎉 ${key} — ${multiplier}x! You won ${win} pts!`;
        document.getElementById('slots-status').style.color = '#55ff55';
    } else {
        // 2-match: consolation (1.5x — matches paytable)
        if(results[0]===results[1] || results[1]===results[2] || results[0]===results[2]) {
            multiplier = 1.5;
            win = Math.floor(bet * multiplier);
            document.getElementById('slots-status').innerText = `2 Match — ${win} pts back (1.5x)`;
            document.getElementById('slots-status').style.color = '#ffcc00';
        } else {
            document.getElementById('slots-status').innerText = `No match. Lost ${bet} pts.`;
            document.getElementById('slots-status').style.color = '#ff5555';
        }
    }

    if(win > 0) await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(win));

    await new Promise(r => setTimeout(r, 1500));
    reelIds.forEach(id => document.getElementById(id).classList.remove('winner'));
    slotsSpinning = false;
    btn.disabled = false;
}

