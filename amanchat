                </div>`:`<button onclick="event.stopPropagation();mktGiveAdj('${type}','${id}','${data.name}',1,${selQty>0?-1:1})" style="background:${selQty>0?'var(--primary)':'rgba(0,0,0,0.5)'};color:${selQty>0?'black':'white'};border:none;border-radius:3px;padding:2px 5px;cursor:pointer;font-size:0.65em;margin-top:3px;">${selQty>0?'✓':'Add'}</button>`}`;
