// ── Join game ────────────────────────────────────────────────────
async function pokerJoin() {
    const code = document.getElementById('poker-code-in').value.trim().toUpperCase();
    if(!code || code.length < 4) return alert('Enter a valid code.');
    const snap = await db.ref(`poker_games/${code}`).once('value');
    if(!snap.exists()) return alert('Game not found. Check the code.');
    const g = snap.val();
    if(g.phase !== 'waiting') return alert('This game has already started.');
    const players = Object.keys(g.players||{});
    if(players.length >= 8) return alert('Game is full (max 8 players).');
    if(players.includes(user)) { pokerCode=code; pokerRef=db.ref(`poker_games/${code}`); pokerSubscribe(); pokerShowWaiting(); return; }
    pokerCode = code;
    pokerRef = db.ref(`poker_games/${code}`);
    await pokerRef.child(`players/${user}`).set({ chips: myPoints, bet: 0, folded: false, allIn: false, lastSeen: Date.now() });
    pokerSubscribe();
    pokerShowWaiting();
}

// ── Subscribe to game state ──────────────────────────────────────
function pokerSubscribe() {
    if(pokerListener) pokerRef.off('value', pokerListener);
    pokerListener = pokerRef.on('value', snap => {
        if(!snap.exists()) { pokerReset(); return; }
        pokerState = snap.val();
        pokerRender();
    });
    // Track own presence
    const presRef = pokerRef.child(`players/${user}/lastSeen`);
    const presInterval = setInterval(()=>{ if(!pokerCode){clearInterval(presInterval);return;} presRef.set(Date.now()); }, 4000);
    // Start offline watcher for host
    if(pokerIsHost) pokerStartOfflineWatch();
    // Subscribe to chat
    pokerSubscribeChat();
}

// ── Show waiting room ────────────────────────────────────────────
function pokerShowWaiting() {
