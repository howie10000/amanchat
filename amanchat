function checkServerPermsAndOpen(isPriv) {
    if(!isPriv&&!canCreateSrv&&role!=='admin') return alert("Only Server Creators can make Public Servers!");
    isCreatingPrivate=isPriv; document.getElementById('srv-name-in').value="";
    document.getElementById('srv-modal-title').innerText=isPriv?"Create Private Server":"Create Public Server";
    document.getElementById('modal-server').classList.remove('hidden');
}
async function executeServerCreate() {
    const name=document.getElementById('srv-name-in').value.trim(); if(!name) return alert("Enter a name.");
    const code=isCreatingPrivate?Math.random().toString(36).substring(2,6).toUpperCase():null;
    const ref=db.ref('servers').push();
    await ref.set({name,owner:user,priv:isCreatingPrivate,code,isOfficial:false});
    await db.ref(`servers/${ref.key}/channels/general/created`).set(true);
    await db.ref(`servers/${ref.key}/roles/${user}`).set('owner');
    if(isCreatingPrivate) await db.ref(`users/${user}/unlocked/${ref.key}`).set(true);
    closeM('modal-server'); openChat('srv',ref.key,name,user);
    if(isCreatingPrivate) openCodeModal(code);
}

async function deleteServer() {
    if (!aId || aType !== 'srv') return;
    
    const sInfo = await db.ref(`servers/${aId}`).once('value');
    if (!sInfo.exists()) return;
    const sData = sInfo.val();

    if (sData.isOfficial) return alert("Cannot delete official servers.");

    // SUPER ADMIN CHECK: Allow owner OR "Howard"
    if (user !== sData.owner && user !== 'Howard') {
        return alert("You do not have permission to delete this server.");
    }

    document.getElementById('modal-delete-srv').classList.remove('hidden');
}

async function confirmDeleteServer() {
    closeM('modal-delete-srv');
    if (!aId || aType !== 'srv') return;
    
    // Double check permission before deleting from DB to prevent code bypass
    const sInfo = await db.ref(`servers/${aId}`).once('value');
    if (!sInfo.exists()) return;
    const sData = sInfo.val();

    if (user !== sData.owner && user !== 'Howard') {
        return alert("You do not have permission to delete this server.");
    }
    
    await db.ref(`servers/${aId}`).remove();
    
    aId = null;
    document.getElementById('header-text').innerText = "Select a chat";
    document.getElementById('chat-controls').classList.add('hidden');
    document.getElementById('channel-controls').classList.add('hidden');
    document.getElementById('member-sidebar').classList.add('hidden');
    document.getElementById('msg-history').innerHTML = "<div style='text-align:center; color:#ddd; margin-top:50px;'>Server deleted. Select a server or friend to start chatting!</div>";
    tab('chat'); subTab('pub');
}

function openJoinPrivate(){document.getElementById('priv-code-in').value="";document.getElementById('modal-join-priv').classList.remove('hidden');}
async function executeJoinPrivate() {
    const code=document.getElementById('priv-code-in').value.trim().toUpperCase(); if(!code) return;
    const s=await db.ref('servers').orderByChild('code').equalTo(code).once('value');
    if(s.exists()){s.forEach(c=>{db.ref(`users/${user}/unlocked/${c.key}`).set(true);closeM('modal-join-priv');openChat('srv',c.key,c.val().name,c.val().owner);});}
