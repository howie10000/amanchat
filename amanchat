let msgCtx,msgDrawing=false;
function initMsgCanvas(){
    const mc=document.getElementById('msg-draw-canvas'); msgCtx=mc.getContext('2d');
    msgCtx.lineWidth=4; msgCtx.lineCap='round';
    const getP=e=>{const r=mc.getBoundingClientRect();return{x:(e.touches?e.touches[0].clientX:e.clientX)-r.left,y:(e.touches?e.touches[0].clientY:e.clientY)-r.top};};
    mc.onmousedown=mc.ontouchstart=e=>{msgDrawing=true;msgCtx.strokeStyle=document.getElementById('msg-draw-color').value;msgCtx.beginPath();const p=getP(e);msgCtx.moveTo(p.x,p.y);};
    mc.onmousemove=mc.ontouchmove=e=>{if(msgDrawing){const p=getP(e);msgCtx.lineTo(p.x,p.y);msgCtx.stroke();e.preventDefault();}};
    mc.onmouseup=mc.ontouchend=()=>msgDrawing=false;
}
