async function playMythicReveal(themeId, item) {
    const overlay = document.getElementById('mythic-reveal-overlay');
    const W = window.innerWidth;
    const H = window.innerHeight;
    overlay.classList.remove('hidden');
    overlay.innerHTML = '';
    
    // === PRE-ANIMATION: Star spin-grow and glass shatter (plays before all mythics) ===
    // Phase 1: Star starts at 10%, slowly spinning, gets faster and bigger to 50% (7.5s)
    const minDim = Math.min(W, H);
    overlay.innerHTML = `
        <div style="position:absolute;inset:0;background:#000;"></div>
        <div style="position:absolute;top:50%;left:50%;width:${minDim * 0.1}px;height:${minDim * 0.1}px;transform:translate(-50%,-50%);background:#fff;clip-path:polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);box-shadow:0 0 80px #fff,0 0 160px #fff,0 0 300px rgba(255,255,255,0.8),inset 0 0 60px rgba(255,255,255,0.9);animation:starSpinGrow 7.5s linear forwards;filter:drop-shadow(0 0 50px #fff);"></div>
    `;
    await sleep(7500);
    
    // Phase 2: Glass shatter effect
    let glassHTML = '<div style="position:absolute;inset:0;animation:glassShatter 0.8s ease forwards;"></div>';
    // Add crack lines
    for(let i = 0; i < 12; i++) {
        const angle = (i / 12) * 360;
        const length = 30 + Math.random() * 40;
        glassHTML += `<div style="position:absolute;top:50%;left:50%;width:2px;height:${length}%;background:linear-gradient(to bottom,rgba(255,255,255,0.9),rgba(255,255,255,0));transform-origin:top center;transform:translate(-50%,0) rotate(${angle}deg);animation:glassCrack 0.8s ease forwards;"></div>`;
    }
    // Add shattered glass shards
    for(let i = 0; i < 20; i++) {
        const x = Math.random() * 100;
        const y = Math.random() * 100;
        const size = 20 + Math.random() * 40;
        const rot = Math.random() * 360;
        glassHTML += `<div style="position:absolute;top:${y}%;left:${x}%;width:${size}px;height:${size}px;background:rgba(255,255,255,0.3);clip-path:polygon(${50 + Math.random() * 20}% 0%,100% ${30 + Math.random() * 20}%,${70 + Math.random() * 20}% 100%,0% ${60 + Math.random() * 20}%);transform:rotate(${rot}deg);animation:glassCrack 0.8s ease forwards;"></div>`;
    }
    overlay.innerHTML = glassHTML;
    await sleep(800);
    
    // Clear overlay before specific mythic animation
    overlay.innerHTML = '';
    
    // === SPECIFIC MYTHIC ANIMATION ===
    if(themeId === 'mythic_ocean') {
        await playOceanReveal(item);
    } else if(themeId === 'mythic_inferno') {
        await playInfernoReveal(item);
    } else if(themeId === 'mythic_matrix') {
        await playMatrixReveal(item);
    } else if(themeId === 'mythic_void') {
        await playVoidReveal(item);
    } else if(themeId === 'mythic_nebula') {
        await playNebulaReveal(item);
    } else if(themeId === 'mythic_gold') {
        await playGoldReveal(item);
    }
    
    overlay.classList.add('hidden');
    showNormalResult(item, 'mythic', false);
    
    // Screen shake after returning to claim page for nebula
    if(themeId === 'mythic_nebula') {
        document.body.style.animation = 'screenShake 0.5s ease';
        await sleep(500);
        document.body.style.animation = '';
    }
}

