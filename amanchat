function renderTradeMyItems() {
    const grid=document.getElementById('trade-my-items-grid'); grid.innerHTML='';
    const inv=myInventory||{themes:{},titles:{},lootboxes:{}};
    const addItems=(items,type,dict)=>{
        for(const [id,count] of Object.entries(items||{})){
            if(count<1) continue; const data=dict[id]; if(!data) continue;
            const chip=document.createElement('div'); chip.className=`item-card ic-${data.rarity}`; chip.style.padding='8px';
            const sel=tradeMySelected.some(x=>x.id===id&&x.type===type);
            if(sel) chip.classList.add('selected');
            chip.innerHTML=`<div style="font-size:1.4em;">${type==='theme'?'🎨':type==='lootbox'?'📦':'🏷️'}</div><div style="font-size:0.72em;text-align:center;" class="${RARITY_CLASS[data.rarity]||'rc'}">${data.name}</div>${count>1?`<div style="font-size:0.65em;color:#888;">x${count}</div>`:''}`;
            chip.onclick=()=>{const idx=tradeMySelected.findIndex(x=>x.id===id&&x.type===type);if(idx>=0)tradeMySelected.splice(idx,1);else tradeMySelected.push({type,id,name:data.name});renderTradeMyItems();document.getElementById('trade-my-selected').innerText=tradeMySelected.length?tradeMySelected.map(x=>x.name).join(', '):'No items selected';};
            grid.appendChild(chip);
        }
    };
    addItems(inv.themes,'theme',ALL_THEMES);
    addItems(inv.titles,'title',ALL_TITLES);
    // Lootboxes: build a dict from the LOOTBOXES array
    const lbDict = {}; LOOTBOXES.forEach(lb => { lbDict[lb.id] = { name: lb.name, rarity: 'common' }; });
    addItems(inv.lootboxes||{},'lootbox',lbDict);
    for(const [id] of Object.entries(myCeremonial||{})){
        const data=ALL_TITLES[id]; if(!data) continue;
        const chip=document.createElement('div'); chip.className='item-card'; chip.style.cssText='padding:8px;opacity:0.4;cursor:not-allowed;';
        chip.innerHTML=`<div style="font-size:1.4em;">🏆</div><div style="font-size:0.72em;text-align:center;color:#ff6666;">${data.name}</div><div style="font-size:0.6em;color:#aaa;">Not tradeable</div>`;
        grid.appendChild(chip);
    }
}

