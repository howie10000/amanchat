        .filter(([id,count]) => count>0 && ALL_TITLES[id])
        .sort((a,b) => {
            const ra = RARITY_ORDER[ALL_TITLES[a[0]].rarity]??9;
            const rb = RARITY_ORDER[ALL_TITLES[b[0]].rarity]??9;
            return ra !== rb ? ra - rb : ALL_TITLES[a[0]].name.localeCompare(ALL_TITLES[b[0]].name);
