function loadActiveEvents() {
    db.ref('system/events').on('value', snap => {
        const container = document.getElementById('dynamic-events-container');
        container.innerHTML = '';
        if (!snap.exists()) return;

        snap.forEach(child => {
            const ev = child.val();
            if (!ev.isActive) return;

            container.innerHTML += `
                <div style="margin-top:30px; padding:20px; background:rgba(255,0,0,0.2); border:1px solid ${ev.color || '#ff4500'}; border-radius:10px; text-align:center; backdrop-filter: blur(5px);">
                    <h3 style="color:${ev.color || '#ffa500'}; margin-top:0;">🌟 ${ev.name} 🌟</h3>
                    <p style="color:#fff; font-size:0.9em; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${ev.description}</p>
                    <button class="btn" style="background:${ev.color || '#ff0000'}; color:yellow; font-weight:bold; box-shadow: 0 2px 5px rgba(0,0,0,0.5);" onclick="claimEventReward('${child.key}', '${ev.rewardType}', '${ev.rewardId}')">${ev.buttonText || 'Claim Now'}</button>
                </div>`;
        });
    });
}

