            const chip=document.createElement('div'); chip.className=`item-card ic-${data.rarity}`; chip.style.padding='6px';
            if(selQty>0) chip.classList.add('selected');
            const icon = type==='theme'?'🎨':type==='lootbox'?'📦':'🏷️';
            chip.innerHTML=`
                <div style="font-size:1.3em;">${icon}</div>
                <div style="font-size:0.68em;text-align:center;" class="${RARITY_CLASS[data.rarity]||'rc'}">${data.name}</div>
                <div style="font-size:0.62em;color:#888;">Own: ${count}</div>
                ${count>1 ? `<div style="display:flex;align-items:center;gap:3px;margin-top:4px;">
                    <button onclick="event.stopPropagation();tradeQtyAdj('my','${type}','${id}','${data.name}',${count},-1)" style="background:#333;color:#fff;border:none;border-radius:4px;width:18px;height:18px;cursor:pointer;font-size:0.9em;line-height:1;">-</button>
                    <span style="font-size:0.75em;min-width:16px;text-align:center;">${selQty}</span>
                    <button onclick="event.stopPropagation();tradeQtyAdj('my','${type}','${id}','${data.name}',${count},1)" style="background:#333;color:#fff;border:none;border-radius:4px;width:18px;height:18px;cursor:pointer;font-size:0.9em;line-height:1;">+</button>
                </div>` : `<button onclick="event.stopPropagation();tradeQtyAdj('my','${type}','${id}','${data.name}',1,${selQty>0?-1:1})" style="background:${selQty>0?'var(--primary)':'rgba(0,0,0,0.5)'};color:${selQty>0?'black':'white'};border:none;border-radius:4px;padding:2px 6px;cursor:pointer;font-size:0.7em;margin-top:4px;">${selQty>0?'✓ Selected':'Add'}</button>`}`;
            grid.appendChild(chip);
        }
    };
    addItems(inv.themes,'theme',ALL_THEMES);
    addItems(inv.titles,'title',ALL_TITLES);
    addItems(inv.lootboxes||{},'lootbox',lbDict);
    for(const [id] of Object.entries(myCeremonial||{})){
        const data=ALL_TITLES[id]; if(!data) continue;
        const chip=document.createElement('div'); chip.className='item-card'; chip.style.cssText='padding:8px;opacity:0.4;cursor:not-allowed;';
        chip.innerHTML=`<div style="font-size:1.4em;">🏆</div><div style="font-size:0.72em;text-align:center;color:#ff6666;">${data.name}</div><div style="font-size:0.6em;color:#aaa;">Not tradeable</div>`;
        grid.appendChild(chip);
    }
    document.getElementById('trade-my-selected').innerText = tradeMySelected.length ? tradeMySelected.map(x=>`${x.name} x${x.qty}`).join(', ') : 'No items selected';
}

function tradeQtyAdj(side, type, id, name, maxQty, delta) {
    const arr = side==='my' ? tradeMySelected : tradeTheirSelected;
    const idx = arr.findIndex(x=>x.id===id&&x.type===type);
    if(idx>=0) {
        arr[idx].qty += delta;
        if(arr[idx].qty <= 0) arr.splice(idx, 1);
        else if(arr[idx].qty > maxQty) arr[idx].qty = maxQty;
    } else if(delta > 0) {
        arr.push({type, id, name, qty: 1});
    }
    if(side==='my') renderTradeMyItems(); else renderTradeTheirItems();
}

