        function formatTimeLeft(ms) {
            const seconds = Math.floor(ms / 1000);
            const minutes = Math.floor(seconds / 60);
            const hours = Math.floor(minutes / 60);
            const days = Math.floor(hours / 24);

            if (days > 0) return `${days}d ${hours % 24}h`;
            if (hours > 0) return `${hours}h ${minutes % 60}m`;
            if (minutes > 0) return `${minutes}m ${seconds % 60}s`;
            return `${seconds}s`;
        }

        async function createAuction() {
            const itemType = document.getElementById('auction-item-type').value;
            const itemId = document.getElementById('auction-item-id').value;
            const startingBid = parseInt(document.getElementById('auction-starting-bid').value);
            const buyNowPrice = parseInt(document.getElementById('auction-buy-now').value) || 0;
            const duration = parseInt(document.getElementById('auction-duration').value);
            const shouldAnnounce = document.getElementById('auction-announce').checked;

            if (!startingBid || startingBid <= 0) return alert("Please enter a valid starting bid.");

            const auction = {
                itemType,
                itemId,
                startingBid,
                buyNowPrice,
                currentBid: startingBid,
                currentBidder: null,
                endTime: Date.now() + duration,
                status: 'active',
                createdBy: user,
                createdAt: Date.now()
            };

            const ref = db.ref('auctions').push();
            await ref.set(auction);

            if (shouldAnnounce) {
                const itemData = itemType === 'theme' ? ALL_THEMES[itemId] : ALL_TITLES[itemId];
                const itemName = itemData ? itemData.name : itemId;
                await db.ref('auctionAnnouncement').set({
                    message: `📢 Aman Auction is now selling ${itemName} for ${startingBid} points!`,
                    timestamp: Date.now()
                });

                // Auto-remove announcement after 10 seconds
                setTimeout(() => {
                    db.ref('auctionAnnouncement').remove();
                }, 10000);
            }

            alert("Auction created successfully!");
            loadAuction();
        }

        async function placeBid(auctionId) {
            const bidInput = document.getElementById(`auction-bid-${auctionId}`);
            const bidAmount = parseInt(bidInput.value);

            if (!bidAmount || bidAmount <= 0) return alert("Please enter a valid bid.");

            const snap = await db.ref(`auctions/${auctionId}`).once('value');
            const auction = snap.val();

            if (!auction || auction.status !== 'active') return alert("This auction is no longer active.");
            if (auction.endTime <= Date.now()) return alert("This auction has ended.");
            if (bidAmount <= (auction.currentBid || auction.startingBid)) return alert(`Bid must be higher than current bid of ${auction.currentBid || auction.startingBid}.`);
            if (auction.currentBidder === user) return alert("You are already the top bidder.");
            if (myPoints < bidAmount) return alert("Not enough points to place this bid.");

            // 3-second cooldown check
            const now = Date.now();
            if (auction.lastBidTime && (now - auction.lastBidTime) < 3000) {
                const wait = Math.ceil((3000 - (now - auction.lastBidTime)) / 1000);
                return alert(`Please wait ${wait} second(s) between bids.`);
            }

            try {
                await showConfirm('💰', 'Place Bid?', `Bid ${bidAmount} points on this auction?`, 'Place Bid', 'var(--primary)');
            } catch (e) { return; }

            // Atomic bid update via transaction to prevent race conditions
            const txResult = await db.ref(`auctions/${auctionId}`).transaction(current => {
                if (!current) return current;
                if (current.status !== 'active') return; // abort
                if (current.endTime <= Date.now()) return; // abort
                if (bidAmount <= (current.currentBid || current.startingBid)) return; // abort
                if (current.lastBidTime && (Date.now() - current.lastBidTime) < 3000) return; // abort
                const previousBidder = current.currentBidder;
                const previousBid = current.currentBid;
                current.currentBid = bidAmount;
                current.currentBidder = user;
                current.lastBidTime = Date.now();
                // Stash previous bidder info for refund step
                current._refundTo = previousBidder || null;
                current._refundAmt = previousBidder ? previousBid : 0;
                return current;
            });

            if (!txResult.committed) return alert("Bid failed: someone else may have bid first or cooldown active.");

            // Deduct bid from user
            await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-bidAmount));

            // Refund previous bidder atomically using stashed info
            const fresh = txResult.snapshot.val();
            if (fresh._refundTo && fresh._refundAmt > 0) {
                await db.ref(`users/${fresh._refundTo}/points`).set(firebase.database.ServerValue.increment(fresh._refundAmt));
            }
            // Cleanup helper fields
            await db.ref(`auctions/${auctionId}/_refundTo`).remove();
            await db.ref(`auctions/${auctionId}/_refundAmt`).remove();

            alert("Bid placed successfully!");
        }

        async function buyNowAuction(auctionId, price) {
            if (myPoints < price) return alert(`Not enough points! Need ${price}.`);

            const snap = await db.ref(`auctions/${auctionId}`).once('value');
            const auction = snap.val();

            if (!auction || auction.status !== 'active') return alert("This auction is no longer active.");

            try {
                await showConfirm('💰', 'Buy It Now?', `Purchase this item for ${price} points?`, 'Buy Now', 'var(--primary)');
            } catch (e) { return; }

            // Deduct points
            await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-price));

            // Give item to user
            const folderName = auction.itemType === 'theme' ? 'themes' : 'titles';
            await db.ref(`users/${user}/inventory/${folderName}/${auction.itemId}`).set(firebase.database.ServerValue.increment(1));

            // Return previous bidder's points if exists
            if (auction.currentBidder) {
                await db.ref(`users/${auction.currentBidder}/points`).set(firebase.database.ServerValue.increment(auction.currentBid));
            }

            // End auction
            await db.ref(`auctions/${auctionId}`).update({
                status: 'sold',
                soldTo: user,
                soldPrice: price,
                soldAt: Date.now()
            });

            alert("Purchase successful! Item added to your inventory.");
            loadAuction();
        }

