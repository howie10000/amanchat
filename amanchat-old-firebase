        function mktWantAdj(type, id, name, delta) {
            const idx = mktWantSelected.findIndex(x => x.id === id && x.type === type);
            if (idx >= 0) { mktWantSelected[idx].qty += delta; if (mktWantSelected[idx].qty <= 0) mktWantSelected.splice(idx, 1); }
            else if (delta > 0) mktWantSelected.push({ type, id, name, qty: 1 });
            renderMktWantGrid();
        }

        async function submitMarketOffer() {
            const givePoints = parseInt(document.getElementById('mkt-give-points').value) || 0;
            const wantPoints = parseInt(document.getElementById('mkt-want-points').value) || 0;
            if (mktGiveSelected.length === 0 && givePoints === 0) return alert("You must offer something.");
            if (givePoints > myPoints) return alert("Not enough points to offer.");

            // Validate you own all the give items
            for (const item of mktGiveSelected) {
                const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
                const owned = (myInventory[folderName] || {})[item.id] || 0;
                if (owned < item.qty) return alert(`You don't have enough ${item.name} to offer.`);
            }

            // Escrow: deduct items and points from user immediately
            for (const item of mktGiveSelected) {
                const q = item.qty || 1;
                const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
                await db.ref(`users/${user}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(-q));
            }
            if (givePoints > 0) {
                await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-givePoints));
            }

            const offer = {
                from: user,
                giveItems: mktGiveSelected,
                givePoints,
                wantItems: mktWantSelected,
                wantPoints,
                status: 'open',
                ts: Date.now()
            };
            const ref = db.ref('market').push();
            await ref.set(offer);
            closeM('modal-market-create');
            alert("Offer posted to Open Market! Items and points have been escrowed.");
            loadMarket();
        }

        function loadMarket() {
            const container = document.getElementById('market-listings');
            container.innerHTML = '<div style="color:#aaa;">Loading...</div>';
            // Fetch all, filter client-side — avoids needing a Firebase index
            db.ref('market').once('value', snap => {
                container.innerHTML = '';
                let count = 0;
                if (snap.exists()) {
                    snap.forEach(child => {
                        const offer = child.val();
                        if (offer.status !== 'open') return; // skip non-open
                        count++;
                        const isOwn = offer.from === user;
                        const card = document.createElement('div');
                        card.className = 'trade-card pending';
                        card.style.marginBottom = '12px';
                        const giveHtml = renderMarketItems(offer.giveItems, offer.givePoints);
                        const wantHtml = renderMarketItems(offer.wantItems, offer.wantPoints);
                        card.innerHTML = `
                    <div style="font-size:0.85em;color:#aaa;margin-bottom:8px;">📢 Posted by <strong>@${offer.from}</strong> · ${new Date(offer.ts).toLocaleDateString()}</div>
                    <div style="display:flex;gap:10px;margin-bottom:10px;flex-wrap:wrap;">
                        <div class="trade-side"><div style="font-size:0.8em;color:#55ff55;margin-bottom:4px;">🎁 They Give:</div>${giveHtml}</div>
                        <div class="trade-side"><div style="font-size:0.8em;color:#ff9900;margin-bottom:4px;">📋 Required from You:</div>${wantHtml || '<span style="color:#555;font-size:0.8em;">No conditions</span>'}</div>
                    </div>
                    ${isOwn
                                ? `<button class="btn" style="background:rgba(255,0,0,0.4);color:white;padding:5px 12px;font-size:0.8em;" onclick="cancelMarketOffer('${child.key}')">🗑️ Cancel Offer</button>`
                                : `<button class="btn primary" style="padding:6px 16px;font-size:0.85em;" onclick="acceptMarketOffer('${child.key}')">✅ Accept Offer</button>`
                            }`;
                        container.appendChild(card);
                    });
                }
                if (count === 0) container.innerHTML = '<div style="color:#555; text-align:center; padding:30px;">No open offers yet. Be the first to post one!</div>';
            });
        }

        function renderMarketItems(items, points) {
            let html = '';
            if (points > 0) html += `<span class="trade-item-chip">✨ ${points} pts</span>`;
            (items || []).forEach(item => {
                const lbDict = {}; LOOTBOXES.forEach(lb => { lbDict[lb.id] = { name: lb.name, rarity: 'common' }; });
                const data = item.type === 'theme' ? ALL_THEMES[item.id] : item.type === 'lootbox' ? lbDict[item.id] : ALL_TITLES[item.id];
                const icon = item.type === 'theme' ? '🎨' : item.type === 'lootbox' ? '📦' : '🏷️';
                const qty = item.qty > 1 ? ` x${item.qty}` : '';
                if (data) html += `<span class="trade-item-chip ${RARITY_CLASS[data.rarity] || 'rc'}">${icon} ${data.name}${qty}</span>`;
            });
            return html || '<span style="color:#555;font-size:0.8em;">Nothing</span>';
        }

        // =========================================================
        //  CUSTOM CONFIRM MODAL HELPER (replaces browser confirm())
        // =========================================================
        function showConfirm(icon, title, msg, btnLabel, btnColor) {
            return new Promise((resolve, reject) => {
                document.getElementById('confirm-icon').innerText = icon || '❓';
                document.getElementById('confirm-title').innerText = title || 'Are you sure?';
                document.getElementById('confirm-msg').innerText = msg || '';
                const yesBtn = document.getElementById('confirm-yes-btn');
                yesBtn.innerText = btnLabel || 'Confirm';
                yesBtn.style.background = btnColor || 'var(--primary)';
                yesBtn.style.color = btnColor ? 'white' : '#000';
                // Clean up old listener
                const newBtn = yesBtn.cloneNode(true);
                yesBtn.parentNode.replaceChild(newBtn, yesBtn);
                newBtn.addEventListener('click', () => {
                    closeM('modal-confirm');
                    window._confirmReject = null;
                    resolve(true);
                });
                window._confirmReject = () => { window._confirmReject = null; reject(new Error('cancelled')); };
                document.getElementById('modal-confirm').classList.remove('hidden');
            });
        }

        async function acceptMarketOffer(offerId) {
            const snap = await db.ref(`market/${offerId}`).once('value');
            const offer = snap.val();
            if (!offer || offer.status !== 'open') return alert("This offer is no longer available.");
            if (offer.from === user) return alert("You cannot accept your own offer.");

            // Check acceptor meets all conditions
            if (offer.wantPoints > 0 && myPoints < offer.wantPoints) return alert(`You need at least ${offer.wantPoints} points.`);
            for (const item of (offer.wantItems || [])) {
                const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
                const owned = (myInventory[folderName] || {})[item.id] || 0;
                if (owned < item.qty) return alert(`You need ${item.qty}x ${item.name} to accept this offer.`);
            }

            try {
                await showConfirm('✅', 'Accept This Offer?', 'Items will be transferred immediately. This cannot be undone.', 'Accept Offer', '#00aa55');
            } catch (e) { return; } // user cancelled

            // Atomically claim the offer to prevent double-accept
            const txResult = await db.ref(`market/${offerId}`).transaction(current => {
                if (!current || current.status !== 'open') return; // abort
                current.status = 'verifying';
                current.verifyAt = Date.now();
                current.verifyBy = user;
                return current;
            });
            if (!txResult.committed) { alert("This offer is no longer available."); loadMarket(); return; }

            // Transfer escrowed give items: directly to acceptor (already deducted from offerer)
            for (const item of (offer.giveItems || [])) {
                const q = item.qty || 1;
                const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
                await db.ref(`users/${user}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(q));
            }
            if (offer.givePoints > 0) {
                await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(offer.givePoints));
            }

            // Transfer want items: me → offerer
            for (const item of (offer.wantItems || [])) {
                const q = item.qty || 1;
                const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
                await db.ref(`users/${user}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(-q));
                await db.ref(`users/${offer.from}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(q));
            }
            if (offer.wantPoints > 0) {
                await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-offer.wantPoints));
                await db.ref(`users/${offer.from}/points`).set(firebase.database.ServerValue.increment(offer.wantPoints));
            }

            await db.ref(`market/${offerId}/status`).set('accepted');
            alert("✅ Trade complete! Items have been transferred.");
            loadMarket();
        }

        async function cancelMarketOffer(offerId) {
            try {
                await showConfirm('🗑️', 'Cancel Your Offer?', 'Remove your offer from the market? Your escrowed items and points will be returned to you.', 'Remove Offer', '#cc3333');
            } catch (e) { return; } // user cancelled

            const snap = await db.ref(`market/${offerId}`).once('value');
            const offer = snap.val();
            if (!offer || offer.from !== user) return;

            // Return escrowed items to user
            for (const item of (offer.giveItems || [])) {
                const q = item.qty || 1;
                const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
                await db.ref(`users/${user}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(q));
            }
            if (offer.givePoints > 0) {
                await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(offer.givePoints));
            }

            await db.ref(`market/${offerId}/status`).set('cancelled');
            alert("Offer cancelled. Your items and points have been returned.");
            loadMarket();
        }

