        <div id="modal-trade-create" class="modal hidden">
            <div class="modal-card" style="width:700px; max-width:96vw;">
                <h3 style="color:var(--primary);">📦 Create Trade</h3>
                <div style="display:flex; gap:15px; flex-wrap:wrap; margin-bottom:15px;">
                    <div style="flex:1; min-width:200px;">
                        <div style="font-size:0.85em; color:#aaa; margin-bottom:5px;">Trade Partner:</div>
                        <select id="trade-partner-sel" style="width:100%;" onchange="loadPartnerInventory()">
                            <option value="">-- Select Friend --</option>
                        </select>
                    </div>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:15px; margin-bottom:15px;">
