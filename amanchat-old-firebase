        // --- ROULETTE (MATH DOM GENERATION) ---
        let rlCurrentChip = 10;
        let rlBets = {};
        let rlSpinning = false;
        const ROULETTE_ORDER = [0, 32, 15, 19, 4, 21, 2, 25, 17, 34, 6, 27, 13, 36, 11, 30, 8, 23, 10, 5, 24, 16, 33, 1, 20, 14, 31, 9, 22, 18, 29, 7, 28, 12, 35, 3, 26];
        const RL_REDS = [1, 3, 5, 7, 9, 12, 14, 16, 18, 19, 21, 23, 25, 27, 30, 32, 34, 36];

        let rlCanvas, rlCtx;
        let rlWheelAngle = 0;
        let rlBallAngle = 0;

        function drawRouletteCanvas(wheelAng, ballAng, ballRad) {
            if (!rlCanvas) {
                rlCanvas = document.getElementById('rl-canvas');
                if (!rlCanvas) return;
                rlCtx = rlCanvas.getContext('2d');
            }
            const ctx = rlCtx;
            ctx.clearRect(0, 0, 360, 360);
            ctx.save();
            ctx.translate(180, 180);

            // Draw outer rim
            ctx.beginPath();
            ctx.arc(0, 0, 175, 0, Math.PI * 2);
            ctx.fillStyle = '#2a1a05';
            ctx.fill();
            ctx.lineWidth = 10;
            ctx.strokeStyle = '#ffd700';
            ctx.stroke();

            // Rotate wheel
            ctx.save();
            ctx.rotate(wheelAng);

            // Draw wedges
            const anglePerWedge = (Math.PI * 2) / 37;
            for (let i = 0; i < 37; i++) {
                const num = ROULETTE_ORDER[i];
                const isRed = RL_REDS.includes(num);
                const color = num === 0 ? '#008800' : (isRed ? '#cc0000' : '#111');

                ctx.beginPath();
                ctx.moveTo(0, 0);
                ctx.arc(0, 0, 165, i * anglePerWedge - anglePerWedge / 2, (i + 1) * anglePerWedge - anglePerWedge / 2);
                ctx.fillStyle = color;
                ctx.fill();
                ctx.strokeStyle = 'rgba(255,255,255,0.2)';
                ctx.lineWidth = 1;
                ctx.stroke();

                // Draw numbers
                ctx.save();
                ctx.rotate(i * anglePerWedge);
                ctx.translate(140, 0); // distance from center
                ctx.rotate(Math.PI / 2); // point outward
                ctx.fillStyle = '#fff';
                ctx.font = 'bold 12px Arial';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(num, 0, 0);
                ctx.restore();
            }

            // Center cap
            ctx.beginPath();
            ctx.arc(0, 0, 30, 0, Math.PI * 2);
            ctx.fillStyle = '#8b6914';
            ctx.fill();
            ctx.strokeStyle = '#ffd700';
            ctx.lineWidth = 4;
            ctx.stroke();

            ctx.restore(); // Undo wheel rotation

            // Pointer
            ctx.beginPath();
            ctx.moveTo(180, 10);
            ctx.lineTo(170, 30);
            ctx.lineTo(190, 30);
            ctx.fillStyle = '#ffd700';
            ctx.fill();

            // Draw ball
            ctx.save();
            ctx.rotate(ballAng);
            ctx.beginPath();
            ctx.arc(0, -ballRad, 6, 0, Math.PI * 2);
            ctx.fillStyle = '#fff';
            ctx.fill();
            ctx.shadowBlur = 5;
            ctx.shadowColor = 'rgba(0,0,0,0.8)';
            ctx.stroke();
            ctx.restore();

            ctx.restore(); // undo center translate
        }

        function buildRouletteBoard() {
            drawRouletteCanvas(rlWheelAngle, rlBallAngle, 160);

            const board = document.getElementById('rl-board');
            if (!board) return;
            board.innerHTML = '';
            let html = '';

            html += `<div class="rl-spot rl-zero" onclick="placeRlBet('0')">0<div class="rl-chip hidden" id="rl-chip-0"></div></div>`;

            for (let i = 1; i <= 36; i++) {
                const isRed = RL_REDS.includes(i);
                const col = isRed ? 'rl-red' : 'rl-black';
                const r = ((i - 1) % 3) + 1;
                const c = Math.floor((i - 1) / 3) + 2;
                html += `<div class="rl-spot ${col}" style="grid-row:${r}; grid-column:${c};" onclick="placeRlBet('${i}')">${i}<div class="rl-chip hidden" id="rl-chip-${i}"></div></div>`;
            }

            html += `<div class="rl-outside">
                <div class="rl-out-btn" style="background:#cc0000;" onclick="placeRlBet('red')">RED<div class="rl-chip hidden" id="rl-chip-red"></div></div>
                <div class="rl-out-btn" style="background:#111;" onclick="placeRlBet('black')">BLACK<div class="rl-chip hidden" id="rl-chip-black"></div></div>
                <div class="rl-out-btn" onclick="placeRlBet('even')">EVEN<div class="rl-chip hidden" id="rl-chip-even"></div></div>
                <div class="rl-out-btn" onclick="placeRlBet('odd')">ODD<div class="rl-chip hidden" id="rl-chip-odd"></div></div>
             </div>`;

            board.innerHTML = html;
        }

        function setRlChip(val) { rlCurrentChip = val; document.getElementById('rl-current-chip').innerText = val; }

        function placeRlBet(spot) {
            if (rlSpinning) return;
