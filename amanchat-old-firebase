<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aman Chat - Deluxe Edition</title>
    <style>
        /* Dynamic theme styles injected by JS */
        :root {
            --primary: #00d4ff;
            --bg: #0b0b0b;
            --panel: rgba(22, 22, 22, 0.85);
            --sidebar: rgba(17, 17, 17, 0.85);
            --text: #f0f0f0;
            --admin: #ff3e3e;
            --msg-bg: rgba(34, 34, 34, 0.85);
            --msg-me: rgba(0, 75, 90, 0.85);
        }

        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: var(--sidebar);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            filter: brightness(1.2);
        }

        @keyframes shimmer {

            0%,
            100% {
                opacity: .7
            }

            50% {
                opacity: 1
            }
        }

        @keyframes legendaryGlow {

            0%,
            100% {
                text-shadow: 0 0 8px #ffd700, 0 0 16px #ffd700
            }

            50% {
                text-shadow: 0 0 20px #ffd700, 0 0 40px #ff9900
            }
        }

        @keyframes epicGlow {

            0%,
            100% {
                text-shadow: 0 0 8px #b366ff
            }

            50% {
                text-shadow: 0 0 20px #b366ff, 0 0 35px #9900ff
            }
        }

        @keyframes rareGlow {

            0%,
            100% {
                text-shadow: 0 0 6px #4d94ff
            }

            50% {
                text-shadow: 0 0 15px #4d94ff
            }
        }

        @keyframes legendGlowPulse {

            0%,
            100% {
                text-shadow: 0 0 10px #ffaa00, 0 0 20px #ff5500;
                filter: brightness(1.2);
            }

            50% {
                text-shadow: 0 0 25px #ffaa00, 0 0 45px #ffcc00;
                filter: brightness(1.6);
            }
        }

        /* ENHANCED MYTHIC GLOW */
        @keyframes mythicGlow {

            0%,
            100% {
                text-shadow: 0 0 15px #ff00aa, 0 0 30px #ff00aa, 0 0 40px #00ffff;
                filter: brightness(1.2) drop-shadow(0 0 10px rgba(255, 0, 170, 0.8));
            }

            50% {
                text-shadow: 0 0 35px #00ffff, 0 0 60px #ff00aa, 0 0 80px #00ffff;
                filter: brightness(1.5) drop-shadow(0 0 20px rgba(0, 255, 255, 1));
            }
        }

        @keyframes mythicBurst {
            0% {
                opacity: 1;
                transform: scale(0);
            }

            100% {
                opacity: 0;
                transform: scale(3) translate(var(--dx), var(--dy));
            }
        }

        @keyframes boxShake {

            0%,
            100% {
                transform: translateX(0)
            }

            10% {
                transform: translateX(-12px) rotate(-5deg)
            }

            20% {
                transform: translateX(14px) rotate(5deg)
            }

            30% {
                transform: translateX(-10px) rotate(-3deg)
            }

            40% {
                transform: translateX(10px) rotate(3deg)
            }

            50% {
                transform: translateX(-6px) rotate(-2deg)
            }

            60% {
                transform: translateX(6px) rotate(2deg)
            }

            70% {
                transform: translateX(0)
            }

            100% {
                transform: translateX(0)
            }
        }

        /* Mythic Reveal Animations */
        #mythic-reveal-overlay {
            position: fixed;
            inset: 0;
            z-index: 100000;
            pointer-events: none;
        }

        @keyframes oceanZoomOut {
            0% {
                transform: scale(1);
            }

            100% {
                transform: scale(3);
            }
        }

        @keyframes fishSwim {
            0% {
                transform: translateX(-100px);
            }

            100% {
                transform: translateX(calc(100vw + 100px));
            }
        }

        @keyframes flicker {
            0% {
                opacity: 0.8;
                transform: translateX(-50%) scale(1);
            }

            100% {
                opacity: 1;
                transform: translateX(-50%) scale(1.1);
            }
        }

        @keyframes fishSwimReverse {
            0% {
                transform: translateX(calc(100vw + 100px));
            }

            100% {
                transform: translateX(-100px);
            }
        }

        @keyframes sharkAppear {
            0% {
                transform: translateX(100vw) scale(0.5);
                opacity: 0;
            }

            50% {
                transform: translateX(50vw) scale(1.2);
                opacity: 1;
            }

            100% {
                transform: translateX(30vw) scale(1);
                opacity: 1;
            }
        }

        @keyframes whiteFlash {
            0% {
                background: rgba(255, 255, 255, 0);
            }

            10% {
                background: rgba(255, 255, 255, 1);
            }

            100% {
                background: rgba(255, 255, 255, 0);
            }
        }

        @keyframes biteMarkPop {
            0% {
                transform: translate(-50%, -50%) scale(0) rotate(-15deg);
                opacity: 0;
            }

            50% {
                transform: translate(-50%, -50%) scale(1.3) rotate(5deg);
                opacity: 1;
            }

            70% {
                transform: translate(-50%, -50%) scale(0.9) rotate(-3deg);
            }

            100% {
                transform: translate(-50%, -50%) scale(1) rotate(0deg);
                opacity: 1;
            }
        }

        @keyframes rippleExpand {
            0% {
                transform: translate(-50%, -50%) scale(0.5);
                opacity: 0.8;
            }

            100% {
                transform: translate(-50%, -50%) scale(2);
                opacity: 0;
            }
        }

        @keyframes screenShake {

            0%,
            100% {
                transform: translate(0, 0)
            }

            10% {
                transform: translate(-10px, 5px)
            }

            20% {
                transform: translate(10px, -5px)
            }

            30% {
                transform: translate(-8px, 3px)
            }

            40% {
                transform: translate(8px, -3px)
            }

            50% {
                transform: translate(-5px, 2px)
            }

            60% {
                transform: translate(5px, -2px)
            }

            70% {
                transform: translate(-3px, 1px)
            }

            80% {
                transform: translate(3px, -1px)
            }

            90% {
                transform: translate(-1px, 0)
            }
        }

        @keyframes volcanoErupt {
            0% {
                transform: scale(0.8);
                opacity: 0;
            }

            30% {
                transform: scale(1.1);
                opacity: 1;
            }

            50% {
                transform: scale(1);
            }

            100% {
                transform: scale(1);
            }
        }

        @keyframes lavaFlow {
            0% {
                height: 0;
            }

            100% {
                height: 100%;
            }
        }

        @keyframes emberRise {
            0% {
                transform: translateY(0) scale(1);
                opacity: 1;
            }

            100% {
                transform: translateY(-200px) scale(0);
                opacity: 0;
            }
        }

        @keyframes eruption {
            0% {
                transform: translateY(100%);
                opacity: 0;
            }

            50% {
                transform: translateY(0);
                opacity: 1;
            }

            100% {
                transform: translateY(-50%);
                opacity: 0;
            }
        }

        @keyframes matrixFall {
            0% {
                transform: translateY(-100%);
                opacity: 0;
            }

            10% {
                opacity: 1;
            }

            90% {
                opacity: 1;
            }

            100% {
                transform: translateY(100vh);
                opacity: 0;
            }
        }

        @keyframes blackHoleGrow {
            0% {
                transform: scale(0);
                opacity: 0;
            }

            50% {
                transform: scale(1);
                opacity: 1;
            }

            100% {
                transform: scale(3);
                opacity: 0;
            }
        }

        @keyframes suckIn {
            0% {
                transform: translate(0, 0) scale(1);
                opacity: 1;
            }

            100% {
                transform: translate(50vw, 50vh) scale(0);
                opacity: 0;
            }
        }

        @keyframes planetOrbit {
            0% {
                transform: rotate(0deg) translateX(100px) rotate(0deg);
            }

            100% {
                transform: rotate(360deg) translateX(100px) rotate(-360deg);
            }
        }

        @keyframes asteroidOrbit {
            0% {
                transform: rotate(0deg) translateX(var(--orbit-radius)) rotate(0deg) scale(1);
            }

            50% {
                transform: rotate(180deg) translateX(var(--orbit-radius)) rotate(-180deg) scale(1.1);
            }

            100% {
                transform: rotate(360deg) translateX(var(--orbit-radius)) rotate(-360deg) scale(1);
            }
        }

        @keyframes coinFallFast {
            0% {
                transform: translateY(-100px) rotate(0deg);
                opacity: 1;
            }

            100% {
                transform: translateY(100vh) rotate(720deg);
                opacity: 1;
            }
        }

        @keyframes nebulaSwirl {
            0% {
                transform: translate(0, 0) scale(1) rotate(0deg);
            }

            100% {
                transform: translate(30px, 30px) scale(1.2) rotate(45deg);
            }
        }

        @keyframes starTwinkle {
            0% {
                opacity: 0.3;
                transform: scale(0.8);
            }

            100% {
                opacity: 1;
                transform: scale(1.2);
            }
        }

        @keyframes starGrowPulse {
            0% {
                transform: translate(-50%, -50%) scale(0.5);
                opacity: 0;
            }

            30% {
                transform: translate(-50%, -50%) scale(1);
                opacity: 0.5;
            }

            50% {
                transform: translate(-50%, -50%) scale(2);
                opacity: 0.8;
            }

            70% {
                transform: translate(-50%, -50%) scale(1.5);
                opacity: 0.6;
            }

            100% {
                transform: translate(-50%, -50%) scale(4);
                opacity: 1;
            }
        }

        @keyframes brightFlash {
            0% {
                background: rgba(255, 255, 255, 0);
            }

            20% {
                background: rgba(255, 255, 255, 1);
            }

            100% {
                background: rgba(255, 255, 255, 0);
            }
        }

        @keyframes fadeOut {
            0% {
                opacity: 1;
            }

            100% {
                opacity: 0;
            }
        }

        /* Pre-animation: Star spin-grow from 10% to 50% then glass shatter - 7.5s total */
        @keyframes starSpinGrow {
            0% {
                width: 10vw;
                height: 10vw;
                opacity: 0.6;
                transform: translate(-50%, -50%) rotate(0deg);
            }

            25% {
                transform: translate(-50%, -50%) rotate(360deg);
            }

            50% {
                width: 35vw;
                height: 35vw;
                transform: translate(-50%, -50%) rotate(900deg);
            }

            75% {
                width: 50vw;
                height: 50vw;
                transform: translate(-50%, -50%) rotate(1350deg);
            }

            100% {
                width: 55vw;
                height: 55vw;
                opacity: 0;
                transform: translate(-50%, -50%) rotate(1800deg);
            }
        }

        @keyframes glassShatter {
            0% {
                background: rgba(255, 255, 255, 0);
                backdrop-filter: blur(0);
            }

            10% {
                background: rgba(255, 255, 255, 0.1);
                backdrop-filter: blur(2px);
            }

            30% {
                background: rgba(255, 255, 255, 0.3);
                backdrop-filter: blur(5px);
            }

            50% {
                background: rgba(255, 255, 255, 0.6);
                backdrop-filter: blur(10px);
            }

            70% {
                background: rgba(255, 255, 255, 0.8);
                backdrop-filter: blur(20px);
            }

            90% {
                background: rgba(255, 255, 255, 1);
                backdrop-filter: blur(0);
            }

            100% {
                background: rgba(255, 255, 255, 0);
                backdrop-filter: blur(0);
            }
        }

        @keyframes glassCrack {
            0% {
                opacity: 0;
                transform: scale(0.8);
            }

            50% {
                opacity: 1;
                transform: scale(1);
            }

            100% {
                opacity: 0;
                transform: scale(1.2);
            }
        }

        @keyframes revealItem {
            0% {
                opacity: 0;
                transform: scale(0.2) translateY(30px)
            }

            60% {
                transform: scale(1.2) translateY(-10px)
            }

            100% {
                opacity: 1;
                transform: scale(1) translateY(0)
            }
        }

        @keyframes gradientBG {
            0% {
                background-position: 0% 50%
            }

            50% {
                background-position: 100% 50%
            }

            100% {
                background-position: 0% 50%
            }
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: var(--bg);
            color: var(--text);
            margin: 0;
            width: 100vw;
            height: 100vh;
            overflow: hidden;
            display: flex;
            transition: 0.3s;
        }

        #mythic-canvas {
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
        }

        #app-container {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            background: var(--panel);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            position: relative;
            z-index: 1;
        }

        .hidden {
            display: none !important;
        }

        nav {
            display: flex;
            background: rgba(0, 0, 0, 0.8);
            padding: 5px;
            gap: 4px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            flex-shrink: 0;
            flex-wrap: wrap;
        }

        nav button {
            flex: 1;
            padding: 10px 6px;
            background: transparent;
            border: none;
            color: #888;
            cursor: pointer;
            border-radius: 6px;
            font-weight: bold;
            transition: 0.2s;
            position: relative;
            font-size: 0.8em;
        }

        nav button.active {
            background: var(--primary);
            color: #000;
        }

        #main-view-area {
            flex: 1;
            display: flex;
            overflow: hidden;
            position: relative;
            min-height: 0;
        }

        .tab-pane {
            display: flex;
            flex: 1;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .sidebar {
            width: 250px;
            min-width: 180px;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            display: flex;
            flex-direction: column;
            background: var(--sidebar);
            overflow-y: auto;
            flex-shrink: 0;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        .chat-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: transparent;
            position: relative;
            min-width: 0;
        }

        .right-sidebar {
            width: 220px;
            border-left: 1px solid rgba(255, 255, 255, 0.05);
            background: var(--sidebar);
            padding: 10px;
            overflow-y: auto;
            flex-shrink: 0;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        .list-header {
            padding: 15px 10px 5px;
            font-size: 0.75em;
            color: #777;
            text-transform: uppercase;
            font-weight: bold;
            letter-spacing: 1px;
        }

        .list-item {
            padding: 12px 10px;
            cursor: pointer;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
        }

        .list-item:hover {
            background: rgba(255, 255, 255, 0.1);
            color: var(--primary);
        }

        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #444;
            display: inline-block;
            margin-right: 5px;
        }

        .status-online {
            background: #00ff00;
            box-shadow: 0 0 5px #00ff00;
        }

        .unread-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: yellow;
            box-shadow: 0 0 8px yellow;
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
        }

        #msg-history {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            min-height: 0;
        }

        .msg {
            background: var(--msg-bg);
            padding: 10px 14px;
            border-radius: 10px;
            width: fit-content;
            max-width: 80%;
            position: relative;
            word-wrap: break-word;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .msg.me {
            align-self: flex-end;
            background: var(--msg-me);
        }

        .msg-info {
            font-size: 0.85em;
            color: var(--primary);
            margin-bottom: 5px;
            font-weight: bold;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
        }

        .msg-ts {
            font-size: 0.75em;
            color: #aaa;
            font-weight: normal;
        }

        .msg img {
            max-width: 250px;
            border-radius: 8px;
            margin-top: 5px;
            cursor: pointer;
            border: 1px solid #444;
            background: white;
        }

        .del-msg {
            color: red;
            cursor: pointer;
            display: none;
            margin-left: 10px;
            font-size: 1.2em;
        }

        .msg:hover .del-msg {
            display: inline-block;
        }

        .input-area {
            padding: 15px;
            background: rgba(0, 0, 0, 0.4);
            display: flex;
            flex-direction: column;
            gap: 5px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            flex-shrink: 0;
            backdrop-filter: blur(10px);
        }

        .input-row {
            display: flex;
            gap: 10px;
        }

        input,
        textarea,
        select {
            flex: 1;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid #444;
            color: var(--text);
            padding: 12px;
            border-radius: 8px;
            outline: none;
        }

        .btn {
            padding: 10px 18px;
            border-radius: 8px;
            border: 2px solid transparent;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .primary {
            background: var(--primary);
            color: #000;
            box-shadow: 0 0 10px rgba(0, 212, 255, 0.2);
        }

        .modal {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.9);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        .modal-card {
            background: var(--panel);
            padding: 25px;
            border-radius: 15px;
            width: 360px;
            max-width: 92vw;
            text-align: center;
            border: 1px solid var(--primary);
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        /* Loading screen */
        #loading-screen {
            position: fixed;
            inset: 0;
            background: #0b0b0b;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 99999;
        }

        #loading-screen h1 {
            color: #00d4ff;
            font-size: 2.5em;
            letter-spacing: 5px;
            margin-bottom: 20px;
        }

        .loading-bar {
            width: 300px;
            height: 4px;
            background: #222;
            border-radius: 2px;
            overflow: hidden;
        }

        .loading-fill {
            height: 100%;
            background: #00d4ff;
            border-radius: 2px;
            animation: loadFill 3.5s ease forwards;
        }

        @keyframes loadFill {
            0% {
                width: 0%
            }

            80% {
                width: 90%
            }

            100% {
                width: 100%
            }
        }

        /* Rarity classes */
        .rc {
            color: #aaa;
        }

        .rr {
            color: #4d94ff;
            animation: rareGlow 2s infinite;
        }

        .re {
            color: #b366ff;
            animation: epicGlow 2s infinite;
        }

        .rl {
            color: #ffd700;
            animation: legendaryGlow 2s infinite;
        }

        .rm {
            color: #ff00aa;
            animation: mythicGlow 3s infinite;
            font-weight: bold;
        }

        .rcr {
            color: #ff6666;
        }

        .rev {
            color: #ff9900;
        }

        .rm-legend {
            color: #ffaa00;
            animation: legendGlowPulse 2.5s infinite;
            font-weight: bold;
        }

        /* Legend Title Shapes */
        .title-shape-diamond {
            position: relative;
            border: 1px solid #ffaa00;
            padding: 0px 8px;
            clip-path: polygon(10% 0%, 90% 0%, 100% 50%, 90% 100%, 10% 100%, 0% 50%);
            background: rgba(255, 170, 0, 0.15);
            box-shadow: 0 0 5px #ffaa00;
        }

        .title-shape-wing {
            position: relative;
            padding: 0 18px;
            text-shadow: 0 0 5px #ffaa00;
        }

        .title-shape-wing::before,
        .title-shape-wing::after {
            content: '🪽';
            position: absolute;
            font-size: 1em;
            top: 50%;
            transform: translateY(-50%);
        }

        .title-shape-wing::before {
            left: -2px;
        }

        .title-shape-wing::after {
            right: -2px;
            transform: translateY(-50%) scaleX(-1);
        }

        .title-shape-orbit {
            position: relative;
            border: 1px solid #ffaa00;
            border-radius: 12px;
            padding: 0px 10px;
            box-shadow: 0 0 8px #ffaa00, inset 0 0 4px #ffaa00;
            background: rgba(255, 170, 0, 0.1);
        }

        .rarity-badge {
            font-size: 0.7em;
            padding: 2px 8px;
            border-radius: 10px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .rb-common {
            background: rgba(170, 170, 170, 0.2);
            color: #aaa;
            border: 1px solid #aaa;
        }

        .rb-rare {
            background: rgba(77, 148, 255, 0.2);
            color: #4d94ff;
            border: 1px solid #4d94ff;
        }

        .rb-epic {
            background: rgba(179, 102, 255, 0.2);
            color: #b366ff;
            border: 1px solid #b366ff;
        }

        .rb-legendary {
            background: rgba(255, 215, 0, 0.2);
            color: #ffd700;
            border: 1px solid #ffd700;
        }

        .rb-mythic {
            background: rgba(255, 0, 170, 0.2);
            color: #ff00aa;
            border: 1px solid #ff00aa;
        }

        .rb-ceremonial {
            background: rgba(255, 102, 102, 0.2);
