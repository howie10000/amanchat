        async function executeTrade(action) {
            const tradeId = pendingTradeId;
            const snap = await db.ref(`trades/${tradeId}`).once('value');
            const t = snap.val(); if (!t || t.status !== 'pending') return closeM('modal-trade-view');

            if (action === 'accept') {
                // Validate receiver (me) has the requested items + points
                const mySnap = await db.ref(`users/${user}`).once('value'); const myData = mySnap.val();
                if ((t.toRequest.points || 0) > (myData.points || 0)) { alert("You don't have enough points for this trade!"); return; }
                for (const item of (t.toRequest.items || [])) {
                    const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
                    const owned = ((myData.inventory || {})[folderName] || {})[item.id] || 0;
                    if (owned < item.qty) { alert(`You don't have enough ${item.name || item.id} to complete this trade.`); return; }
                }

                closeM('modal-trade-view');

                // Transfer escrowed items from trade to receiver (me)
                for (const item of (t.fromOffer.items || [])) {
                    const q = item.qty || 1;
                    const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
                    await db.ref(`users/${user}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(q));
                }
                if ((t.fromOffer.points || 0) > 0) {
                    await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(t.fromOffer.points));
                }

                // Transfer requested items from receiver (me) to sender
                for (const item of (t.toRequest.items || [])) {
                    const q = item.qty || 1;
                    const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
                    await db.ref(`users/${user}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(-q));
                    await db.ref(`users/${t.from}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(q));
                }
                if ((t.toRequest.points || 0) > 0) {
                    await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-t.toRequest.points));
                    await db.ref(`users/${t.from}/points`).set(firebase.database.ServerValue.increment(t.toRequest.points));
                }

                await db.ref(`trades/${tradeId}/status`).set('accepted');
                alert("✅ Trade accepted! Items transferred.");
            } else {
                // Decline incoming: refund sender's escrowed items
                await refundTradeEscrow(t);
                await db.ref(`trades/${tradeId}/status`).set('declined');
            }
            closeM('modal-trade-view'); loadTrades();
        }

        async function refundTradeEscrow(t) {
            if (!t || !t.from) return;
            for (const item of (t.fromOffer?.items || [])) {
                const q = item.qty || 1;
                const folderName = item.type === 'lootbox' ? 'lootboxes' : item.type + 's';
                await db.ref(`users/${t.from}/inventory/${folderName}/${item.id}`).set(firebase.database.ServerValue.increment(q));
            }
            if ((t.fromOffer?.points || 0) > 0) {
                await db.ref(`users/${t.from}/points`).set(firebase.database.ServerValue.increment(t.fromOffer.points));
            }
        }

        async function cancelTrade(tradeId) {
            if (!confirm("Cancel this trade? Your escrowed items will be returned.")) return;
            const snap = await db.ref(`trades/${tradeId}`).once('value');
            const t = snap.val();
            if (!t) return alert("Trade not found.");
            if (t.status !== 'pending') return alert("This trade can no longer be cancelled.");
            if (t.from !== user && t.to !== user) return alert("You are not part of this trade.");

            // Atomically mark as cancelling to prevent race with accept
            const txResult = await db.ref(`trades/${tradeId}`).transaction(current => {
                if (!current || current.status !== 'pending') return; // abort if not pending
                current.status = 'cancelled';
                return current;
            });
            if (!txResult.committed) return alert("Trade can no longer be cancelled (already accepted or in verification).");

            // Refund escrow to sender
            await refundTradeEscrow(t);
            alert("Trade cancelled. Escrowed items have been returned.");
            loadTrades();
