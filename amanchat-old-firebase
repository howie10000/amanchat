                if (!bet || bet < 1 || bet > 50000) { alert("Enter bet between 1 and 50,000."); return; }
                if (myPoints < bet) { alert("Not enough points."); return; }

                // Deduct bet
                await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-bet));

                // Initialize game state
                minesGameState = {
                    bet: bet,
                    bombs: bombs,
                    gemsFound: 0,
                    revealed: [],
                    gameOver: false,
                    grid: generateMinesGrid(bombs)
                };

                // Update UI
                document.getElementById('mines-bet-area').classList.add('hidden');
