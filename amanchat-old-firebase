                const y = Math.random() * 100;
                const size = Math.random() * 2 + 1;
                voidHTML += `<div style="position:absolute;top:${y}%;left:${x}%;width:${size}px;height:${size}px;background:#fff;border-radius:50%;opacity:${Math.random() * 0.5 + 0.3};animation:starTwinkle ${1 + Math.random()}s ease-in-out infinite alternate;"></div>`;
