        async function burnSelectedItems() {
            const qtyInputs = document.querySelectorAll('.altar-burn-qty');
            let totalShards = 0;
            const itemsToBurn = [];

            qtyInputs.forEach(input => {
                const qty = parseInt(input.value) || 0;
                if (qty > 0) {
                    const type = input.dataset.type;
                    const id = input.dataset.id;
                    const shards = parseInt(input.dataset.shards);
                    const max = parseInt(input.dataset.max);

                    if (qty > max) {
                        input.value = max;
                        itemsToBurn.push({ type, id, qty: max, shards });
                        totalShards += shards * max;
                    } else {
                        itemsToBurn.push({ type, id, qty, shards });
                        totalShards += shards * qty;
                    }
                }
            });

            if (itemsToBurn.length === 0) return alert("Select quantities to burn first.");

            try {
                await showConfirm('🔥', 'Burn These Items?', `You will receive ${totalShards} shards. This cannot be undone!`, 'Burn Items', '#ff6600');
            } catch (e) { return; }

            // Show animation
