        function mktGiveAdj(type, id, name, maxQty, delta) {
            const idx = mktGiveSelected.findIndex(x => x.id === id && x.type === type);
            if (idx >= 0) { mktGiveSelected[idx].qty += delta; if (mktGiveSelected[idx].qty <= 0) mktGiveSelected.splice(idx, 1); else if (mktGiveSelected[idx].qty > maxQty) mktGiveSelected[idx].qty = maxQty; }
            else if (delta > 0) mktGiveSelected.push({ type, id, name, qty: 1 });
            renderMktGiveGrid();
        }

