            const initialTotalBet = bjBet * bjPlayerHands.length;
            if (payout > initialTotalBet) resEl.style.color = '#55ff55';
            else if (payout === initialTotalBet) resEl.style.color = '#ffcc00';
            else resEl.style.color = '#ff5555';

            if (payout > 0) await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(payout));
        }

