        // =========================================================
        //  PROFILE PICTURE DRAWING (Large canvas modal)
        // =========================================================
        let pfpDrawCtx, pfpDrawActive = false;
        function openPfpDrawModal() {
            document.getElementById('modal-draw-pfp').classList.remove('hidden');
            setTimeout(initPfpDrawCanvas, 50); // ensure canvas is in DOM
        }
        function initPfpDrawCanvas() {
            const c = document.getElementById('pfp-draw-canvas');
            if (!c) return;
            pfpDrawCtx = c.getContext('2d');
            pfpDrawCtx.lineCap = 'round';
            pfpDrawCtx.lineJoin = 'round';
            // Pre-fill white background
            pfpDrawCtx.fillStyle = '#ffffff';
            pfpDrawCtx.fillRect(0, 0, 280, 280);
            // Load existing pfp if any
            db.ref(`users/${user}/pfp`).once('value', s => {
                if (s.val()) { const img = new Image(); img.onload = () => pfpDrawCtx.drawImage(img, 0, 0, 280, 280); img.src = s.val(); }
            });
            const getP = e => {
                const r = c.getBoundingClientRect();
                const sx = c.width / r.width;
                const sy = c.height / r.height;
                const x = (e.touches ? e.touches[0].clientX : e.clientX) - r.left;
                const y = (e.touches ? e.touches[0].clientY : e.clientY) - r.top;
                return { x: x * sx, y: y * sy };
            };
            c.onmousedown = c.ontouchstart = e => {
                pfpDrawActive = true;
                pfpDrawCtx.strokeStyle = document.getElementById('pfp-draw-color').value;
                pfpDrawCtx.lineWidth = parseInt(document.getElementById('pfp-draw-size').value) || 4;
                pfpDrawCtx.beginPath();
                const p = getP(e); pfpDrawCtx.moveTo(p.x, p.y);
                e.preventDefault();
            };
            c.onmousemove = c.ontouchmove = e => {
                if (pfpDrawActive) { const p = getP(e); pfpDrawCtx.lineTo(p.x, p.y); pfpDrawCtx.stroke(); e.preventDefault(); }
            };
            window.addEventListener('mouseup', () => pfpDrawActive = false);
            c.ontouchend = () => pfpDrawActive = false;
        }
        function clearPfpDraw() {
