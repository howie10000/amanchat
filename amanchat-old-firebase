        // ── Player actions ───────────────────────────────────────────────
        async function pokerFold() {
            if (!pokerState || pokerState.actionOn !== user) return;
            await pokerRef.child(`players/${user}/folded`).set(true);
            await pokerAdvanceAction();
        }

        async function pokerCheck(event) {
            if (!pokerState || pokerState.actionOn !== user) return;
            // Prevent double-check by disabling button temporarily
            const btn = event.target;
            if (btn) btn.disabled = true;
            await pokerAdvanceAction();
            if (btn) setTimeout(() => btn.disabled = false, 500);
        }

        async function pokerCall(amt) {
            if (!pokerState || pokerState.actionOn !== user) return;
            const me = pokerState.players[user];
            const actual = Math.min(amt, me.chips);
            await pokerRef.child(`players/${user}/chips`).set(me.chips - actual);
            await pokerRef.child(`players/${user}/bet`).set((me.bet || 0) + actual);
            await pokerRef.child('pot').set((pokerState.pot || 0) + actual);
            await pokerAdvanceAction();
        }

        async function pokerConfirmRaise() {
            if (!pokerState || pokerState.actionOn !== user) return;
            const amt = parseInt(document.getElementById('poker-raise-in').value);
            if (!amt || amt < 1) return alert('Enter a raise amount.');
            const me = pokerState.players[user];
            const callAmt = Math.max(0, (pokerState.currentBet || 0) - (me.bet || 0));
            const total = callAmt + amt;
            if (total > me.chips) return alert(`Not enough chips. You have ${me.chips}.`);
            const newBet = (me.bet || 0) + total;
            await pokerRef.child(`players/${user}/chips`).set(me.chips - total);
            await pokerRef.child(`players/${user}/bet`).set(newBet);
            await pokerRef.child('pot').set((pokerState.pot || 0) + total);
            await pokerRef.child('currentBet').set(newBet);
            await pokerRef.child('lastRaiser').set(user);
            document.getElementById('poker-raise-row').classList.add('hidden');
            await pokerAdvanceAction();
        }

        async function pokerAllIn() {
            if (!pokerState || pokerState.actionOn !== user) return;
            const me = pokerState.players[user];
            const chips = me.chips;
            const newBet = (me.bet || 0) + chips;
            await pokerRef.child(`players/${user}/chips`).set(0);
            await pokerRef.child(`players/${user}/bet`).set(newBet);
            await pokerRef.child(`players/${user}/allIn`).set(true);
            await pokerRef.child('pot').set((pokerState.pot || 0) + chips);
            if (newBet > (pokerState.currentBet || 0)) await pokerRef.child('currentBet').set(newBet);
            await pokerAdvanceAction();
        }

        async function pokerAdvanceAction() {
            // Always re-read state fresh from Firebase to avoid stale data race
            const freshSnap = await pokerRef.once('value');
            const g = freshSnap.val();
            if (!g) return;
            const order = g.order || [];
            const players = g.players || {};
            const curIdx = order.indexOf(g.actionOn);
            // Find next active (not folded, not all-in) player
            let nextIdx = (curIdx + 1) % order.length;
            let checked = 0;
            while (checked < order.length) {
                const p = order[nextIdx];
                const pd = players[p] || {};
                if (!pd.folded && !pd.allIn) break;
                nextIdx = (nextIdx + 1) % order.length;
                checked++;
            }
            const nextPlayer = order[nextIdx];
            // Check if betting round is over:
            // Round ends only when we would return to the lastRaiser AND all active bets are equal
            const active = order.filter(p => !(players[p] || {}).folded);
            const allEqual = active.every(p => (players[p] || {}).bet === (g.currentBet || 0) || (players[p] || {}).allIn);
            const backToLastRaiser = nextPlayer === g.lastRaiser && allEqual;
            const onlyOneLeft = active.length === 1;

            if (onlyOneLeft || backToLastRaiser) {
                // Advance phase
                await pokerNextPhaseFromState(g);
            } else {
                await pokerRef.child('actionOn').set(nextPlayer);
            }
        }

        async function pokerNextPhase() {
            await pokerNextPhaseFromState(pokerState);
        }

        async function pokerNextPhaseFromState(g) {
            const deck = g.deck || [];
            const comm = g.community || [];
            const players = g.players || {};
            const order = g.order || [];
            const active = order.filter(p => !(players[p] || {}).folded);

            if (active.length === 1 || g.phase === 'river') {
                await pokerShowdown();
                return;
            }

            // Reset bets for new phase
            const playerUpdates = {};
            order.forEach(p => {
                playerUpdates[`players/${p}/bet`] = 0;
            });

            let nextPhase, newComm = [...comm];
            if (g.phase === 'preflop') { nextPhase = 'flop'; newComm.push(deck.pop(), deck.pop(), deck.pop()); }
            else if (g.phase === 'flop') { nextPhase = 'turn'; newComm.push(deck.pop()); }
            else if (g.phase === 'turn') { nextPhase = 'river'; newComm.push(deck.pop()); }

            // First to act post-flop = first non-folded player after dealer
            const dealerIdx = (g.round - 1) % order.length;
            let firstIdx = (dealerIdx + 1) % order.length;
            while ((players[order[firstIdx]] || {}).folded) firstIdx = (firstIdx + 1) % order.length;

            const updates = { phase: nextPhase, community: newComm, deck, currentBet: 0, lastRaiser: order[firstIdx], actionOn: order[firstIdx], ...playerUpdates };
            await pokerRef.update(updates);
        }

        // ── Showdown ─────────────────────────────────────────────────────
        async function pokerShowdown() {
            const g = pokerState;
            const players = g.players || {};
            const order = g.order || [];
            const active = order.filter(p => !(players[p] || {}).folded);
            const comm = g.community || [];
            const hands = g.hands || {};

            let winnerId;
            if (active.length === 1) {
                winnerId = active[0];
            } else {
                // Evaluate each hand
                let best = null, bestPlayer = null;
                active.forEach(p => {
                    const h = [...(hands[p] || []), ...comm];
                    const ev = pokerEvalHand(h);
                    if (!best || pokerCompare(ev, best) > 0) { best = ev; bestPlayer = p; }
                });
                winnerId = bestPlayer;
            }

            // Award pot
            const pot = g.pot || 0;
            const winnerChips = (players[winnerId] || {}).chips || 0;
            const playerUpdates = {};
            order.forEach(p => { playerUpdates[`players/${p}/bet`] = 0; });
            playerUpdates[`players/${winnerId}/chips`] = winnerChips + pot;
            playerUpdates['pot'] = 0;
            playerUpdates['phase'] = 'showdown';
            playerUpdates['winner'] = winnerId;
            playerUpdates['winnerPot'] = pot;
            await pokerRef.update(playerUpdates);
        }

        // ── Showdown render ──────────────────────────────────────────────
        function pokerRenderShowdown() {
            const g = pokerState;
            const players = g.players || {};
            const winner = g.winner || '';
            const pot = g.winnerPot || 0;
            document.getElementById('poker-winner-msg').textContent = `🏆 ${winner} wins ${pot.toLocaleString()} pts!`;

            // Show all hands
            const hands = g.hands || {};
            const comm = g.community || [];
            const order = g.order || [];
            let html = '<div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center;">';
            order.forEach(p => {
                const h = hands[p] || [];
                const pd = players[p] || {};
                const rank = h.length >= 2 ? pokerEvalHand([...h, ...comm]).name : '';
