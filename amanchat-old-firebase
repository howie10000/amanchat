                const size = 25 + Math.random() * 30;
                const duration = 3 + Math.random() * 2;
                const delay = Math.random() * 2;
                // Create irregular asteroid shape using clip-path polygon
                const points = Array.from({ length: 6 }, () => {
                    const angle = Math.random() * Math.PI * 2;
                    const r = 45 + (Math.random() - 0.5) * 30;
                    return `${50 + r * Math.cos(angle) * 0.5}% ${50 + r * Math.sin(angle) * 0.5}%`;
                }).join(', ');
                voidHTML += `<div style="position:absolute;top:50%;left:50%;width:${size}px;height:${size}px;background:linear-gradient(135deg,#666 0%,#333 50%,#555 100%);clip-path:polygon(${points});--orbit-radius:${orbitRadius}px;transform-origin:center;animation:asteroidOrbit ${duration}s linear infinite;animation-delay:-${delay}s;box-shadow:0 0 10px rgba(100,100,100,0.5);"></div>`;
            }

            // Centered Black hole
            voidHTML += `<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:80px;height:80px;background:radial-gradient(circle,#000 20%,#1a0033 40%,#330066 60%,transparent 80%);border-radius:50%;box-shadow:0 0 40px #4400aa,0 0 80px #220044;"></div>`;

            overlay.innerHTML = voidHTML;
            await sleep(2500);

            // Phase 2: Black hole expands and consumes everything (1s)
            overlay.innerHTML = `
        <div style="position:absolute;inset:0;background:#000;"></div>
        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:80px;height:80px;background:radial-gradient(circle,#000 20%,#1a0033 40%,#330066 60%,transparent 80%);border-radius:50%;animation:blackHoleGrow 1s ease forwards;box-shadow:0 0 60px #4400aa,0 0 120px #220044;"></div>
    `;
            await sleep(1000);

            // Phase 3: White flash (0.3s)
            overlay.innerHTML = `<div style="position:absolute;inset:0;animation:whiteFlash 0.3s ease forwards;"></div>`;
            await sleep(300);

            // Phase 4: Screen shake (0.5s)
            document.body.style.animation = 'screenShake 0.5s ease';
            await sleep(500);
            document.body.style.animation = '';

            // Phase 5: Fade back (0.5s)
            overlay.innerHTML = `<div style="position:absolute;inset:0;background:#000;animation:fadeOut 0.5s ease forwards;"></div>`;
            await sleep(500);
        }

