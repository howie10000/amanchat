            box-shadow: 0 0 50px 20px #fff; animation: eyePulse 1.5s ease-in-out infinite;
        }
        @keyframes eyePulse { 0%, 100% { transform: translate(-50%,-50%) scale(1); opacity: 0.5; } 50% { transform: translate(-50%,-50%) scale(8); opacity: 1; } }
        
        .legend-shard {
            position: absolute; width: 30px; height: 30px; clip-path: polygon(50% 0%, 100% 100%, 0% 100%);
            animation: shardFly 0.8s ease-out forwards;
