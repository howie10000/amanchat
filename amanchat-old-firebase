            }
            overlay.innerHTML = glassHTML;
            await sleep(800);

            // Clear overlay before specific mythic animation
            overlay.innerHTML = '';

            // === SPECIFIC MYTHIC ANIMATION ===
            if (themeId === 'mythic_ocean') {
                await playOceanReveal(item);
            } else if (themeId === 'mythic_inferno') {
                await playInfernoReveal(item);
