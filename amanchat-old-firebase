        async function spinRoulette() {
            if (rlSpinning) return;
            const totalBet = Object.values(rlBets).reduce((a, b) => a + b, 0);
            if (totalBet === 0) return alert("Place a bet first!");
            if (totalBet > myPoints) { clearRlBets(); return alert("You don't have enough points for these bets."); }

            rlSpinning = true;
            document.getElementById('rl-spin-btn').disabled = true;
            await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-totalBet));

            document.getElementById('rl-status').innerText = "🎡 Spinning...";
            document.getElementById('rl-status').style.color = '#ffcc00';

            const resultNum = Math.floor(Math.random() * 37);
            const targetIndex = ROULETTE_ORDER.indexOf(resultNum);
            const anglePerWedge = (Math.PI * 2) / 37;

            // Calculate targets
            let targetAng = (-Math.PI / 2 - targetIndex * anglePerWedge) % (Math.PI * 2);
            if (targetAng < 0) targetAng += Math.PI * 2;

            let currentMod = rlWheelAngle % (Math.PI * 2);
            if (currentMod < 0) currentMod += Math.PI * 2;

            let diff = targetAng - currentMod;
            if (diff < 0) diff += Math.PI * 2;

            const startWheelAngle = rlWheelAngle;
            const finalWheelAngle = rlWheelAngle + diff + Math.PI * 2 * 10; // 10 spins

            const startBallAngle = rlBallAngle;
            const ballRevolutions = -(Math.PI * 2 * 15); // spin opposite

            const duration = 6000;
            const startTime = Date.now();

            function animate() {
                let t = (Date.now() - startTime) / duration;
                if (t > 1) t = 1;

                // easeOutQuart
                const ease = 1 - Math.pow(1 - t, 4);
                rlWheelAngle = startWheelAngle + (finalWheelAngle - startWheelAngle) * ease;

                // ball ease out cubic
                let bEase = 1 - Math.pow(1 - t, 3);
                let bAngle = startBallAngle + ballRevolutions * bEase;

                let bRad = 160;
                if (t > 0.7) {
                    let dropT = (t - 0.7) / 0.3; // 0 to 1
                    bRad = 160 - 20 * Math.sin(dropT * Math.PI / 2);

                    let lockAngle = rlWheelAngle + targetIndex * anglePerWedge + Math.PI / 2;
                    while (lockAngle > bAngle + Math.PI) lockAngle -= Math.PI * 2;
                    while (lockAngle < bAngle - Math.PI) lockAngle += Math.PI * 2;

                    bAngle = bAngle * (1 - dropT) + lockAngle * dropT;
                }
                if (t > 0.95) {
                    bRad = 140;
                    bAngle = rlWheelAngle + targetIndex * anglePerWedge + Math.PI / 2;
                }

                rlBallAngle = bAngle;
                drawRouletteCanvas(rlWheelAngle, rlBallAngle, bRad);

                if (t < 1) requestAnimationFrame(animate);
                else finishSpin(resultNum, totalBet);
            }
            animate();
        }

        async function finishSpin(resultNum, totalBet) {
            let totalWin = 0;
            for (const [spot, amount] of Object.entries(rlBets)) {
                if (spot === String(resultNum)) totalWin += amount * 36;
                else if (resultNum !== 0) {
                    const isRed = RL_REDS.includes(resultNum);
                    const isEven = resultNum % 2 === 0;
                    if (spot === 'red' && isRed) totalWin += amount * 2;
                    if (spot === 'black' && !isRed) totalWin += amount * 2;
                    if (spot === 'even' && isEven) totalWin += amount * 2;
                    if (spot === 'odd' && !isEven) totalWin += amount * 2;
                }
            }

            const isRedResult = resultNum !== 0 && RL_REDS.includes(resultNum);
            const status = document.getElementById('rl-status');
            const colorStr = resultNum === 0 ? 'GREEN 🟢' : (isRedResult ? 'RED 🔴' : 'BLACK ⚫');
            const payoutStr = totalWin > 0 ? `WIN +${totalWin} pts` : `Loss -${totalBet} pts`;
            if (totalWin > 0) {
                status.innerHTML = `🎉 <strong>${resultNum} ${colorStr}</strong> — <span style="color:#55ff55;">${payoutStr}</span>`;
                await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(totalWin));
            } else {
                status.innerHTML = `<strong>${resultNum} ${colorStr}</strong> — <span style="color:#ff5555;">${payoutStr}</span>`;
            }

            await new Promise(r => setTimeout(r, 3000));
            rlSpinning = false;
            document.getElementById('rl-spin-btn').disabled = false;
            clearRlBets();
        }

