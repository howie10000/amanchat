        // ─── PLINKO REWRITE ───────────────────────────────────────────
        const PLINKO_ROWS = 16;
        const PLINKO_MULTS = [100, 40, 10, 5, 3, 1.5, 1, 0.4, 0.2, 0.4, 1, 1.5, 3, 5, 10, 40, 100];

        function buildPlinkoBoard() {
            buildPlinkoPegs();
            const binsEl = document.querySelector('.plinko-bins');
            if (!binsEl) return;
            binsEl.innerHTML = '';
            const mid = Math.floor(PLINKO_MULTS.length / 2);
            PLINKO_MULTS.forEach((m, i) => {
                const d = document.createElement('div');
                d.className = 'plinko-bin';
                const dist = Math.abs(i - mid);
                if (dist >= 7) d.style.background = 'rgba(255,180,0,0.35)';
                else if (dist >= 5) d.style.background = 'rgba(255,120,0,0.25)';
                else if (dist >= 3) d.style.background = 'rgba(180,60,0,0.2)';
                else if (dist === 0) d.style.background = 'rgba(220,0,0,0.35)';
                d.textContent = m >= 1 ? `${m}x` : `${m}x`;
                binsEl.appendChild(d);
            });
        }

        function buildPlinkoPegs() {
            const cont = document.getElementById('plinko-pegs');
            cont.innerHTML = '';
            const numBins = PLINKO_MULTS.length; // 17
            const boardH = 520, binH = 22;
            const usableH = boardH - binH - 16;
            const stepY = usableH / PLINKO_ROWS;

            for (let r = 1; r <= PLINKO_ROWS; r++) {
                // Row r has r+1 pegs. Peg j is at slotF = center - r/2 + j
                for (let j = 0; j <= r; j++) {
                    const slotF = (numBins - 1) / 2 - r / 2 + j;
                    const xPct = (slotF + 0.5) / numBins * 100;
                    const yPx = r * stepY;
                    const dot = document.createElement('div');
                    dot.className = 'plinko-peg';
                    dot.style.cssText = `position:absolute; left:calc(${xPct}% - 5.5px); top:${yPx}px; transform:translateY(-50%);`;
                    cont.appendChild(dot);
                }
            }
        }

        function buildPlinkoPath(boardWidth) {
            const numBins = PLINKO_MULTS.length; // 17
            const binWidth = boardWidth / numBins;
            const boardH = 520;
            const binH = 22;
            const usableH = boardH - binH - 16;
            const stepY = usableH / PLINKO_ROWS;

            // ±0.5 steps from center. After 16 steps: slotF = rights ∈ [0..16]
            // = Binomial(16, 0.5) → proper bell curve, ALL 17 bins reachable, perfectly symmetric
            let slotF = (numBins - 1) / 2; // 8.0 = center

            const path = [];
            path.push({ x: slotF * binWidth + binWidth / 2, y: 0 });

            for (let row = 0; row < PLINKO_ROWS; row++) {
                slotF += Math.random() < 0.5 ? 0.5 : -0.5;
                slotF = Math.max(0, Math.min(slotF, numBins - 1));
                path.push({
                    x: slotF * binWidth + binWidth / 2,
                    y: (row + 1) * stepY
                });
            }

            const binIndex = Math.round(slotF);
            path.push({ x: binIndex * binWidth + binWidth / 2, y: usableH });

            return { path, binIndex, boardH, binH };
        }

        function animatePlinkoBall(board, path, binIndex, boardH, binH) {
            return new Promise(resolve => {
                const ball = document.createElement('div');
                ball.className = 'plinko-ball';
                board.appendChild(ball);

                const boardWidth = board.getBoundingClientRect().width || 600;
                const totalSteps = path.length - 1;
                const stepDuration = 100; // ms per peg row
                const totalDuration = stepDuration * totalSteps;
                let startT = null;

                function step(now) {
                    if (startT === null) startT = now;
                    const elapsed = now - startT;
                    const globalT = Math.min(elapsed / totalDuration, 1);
                    const rawSeg = globalT * totalSteps;
                    const segIndex = Math.min(Math.floor(rawSeg), totalSteps - 1);
                    const segT = rawSeg - segIndex;

                    const p1 = path[segIndex];
                    const p2 = path[segIndex + 1] || path[totalSteps];

                    // Quadratic bezier: control point arcs slightly upward
                    const cpX = (p1.x + p2.x) / 2;
                    const cpY = Math.min(p1.y, p2.y) - 10;
                    const t = segT;
                    const x = (1 - t) * (1 - t) * p1.x + 2 * (1 - t) * t * cpX + t * t * p2.x;
                    const y = (1 - t) * (1 - t) * p1.y + 2 * (1 - t) * t * cpY + t * t * p2.y;

                    // Position ball: x is absolute from left of board, center ball on it
                    ball.style.left = `${x - 6}px`;
                    ball.style.top = `${y}px`;
                    ball.style.transform = 'none'; // override default transform

                    if (globalT < 1) {
                        requestAnimationFrame(step);
                    } else {
                        ball.style.top = `${boardH - binH - 14}px`;
                        setTimeout(() => { ball.remove(); resolve(binIndex); }, 300);
                    }
                }
                requestAnimationFrame(step);
            });
        }

        async function playPlinko() {
