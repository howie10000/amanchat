            <div class="modal-card">
                <h3>Server Code</h3>
                <p style="font-size:0.8em; color:#aaa;">Share this code with friends to let them join your private
                    server.</p>
                <h1 id="display-code-val" style="color:var(--primary); letter-spacing:5px;">XXXX</h1>
                <button class="btn primary" style="width:100%; margin-top:15px;"
                    onclick="closeM('modal-code')">Done</button>
            </div>
        </div>

        <div id="modal-server" class="modal hidden">
            <div class="modal-card">
                <h3 id="srv-modal-title">Create Server</h3>
                <input type="text" id="srv-name-in" placeholder="Server name?">
                <button class="btn primary" style="width:100%; margin-top:15px;" onclick="executeServerCreate()">Create
                    It!</button>
                <button class="btn" style="width:100%; background:none; color:#ddd;"
                    onclick="closeM('modal-server')">Cancel</button>
            </div>
        </div>

        <div id="modal-join-priv" class="modal hidden">
            <div class="modal-card">
                <h3>Join Private Server</h3>
                <input type="text" id="priv-code-in" placeholder="Code..." maxlength="4"
                    style="text-align:center; font-size:1.5em; text-transform:uppercase;">
                <button class="btn primary" style="width:100%; margin-top:15px;" onclick="executeJoinPrivate()">Join
                    Server</button>
                <button class="btn" style="width:100%; background:none; color:#ddd;"
                    onclick="closeM('modal-join-priv')">Cancel</button>
            </div>
        </div>

        <div id="modal-add-chan" class="modal hidden">
            <div class="modal-card">
                <h3>Add Chat Chain</h3>
                <input type="text" id="chan-name-in" placeholder="channel-name">
                <button class="btn primary" style="width:100%; margin-top:15px;" onclick="executeAddChannel()">Create
                    Chain</button>
                <button class="btn" style="width:100%; background:none; color:#ddd;"
                    onclick="closeM('modal-add-chan')">Cancel</button>
            </div>
        </div>

        <div id="lootbox-open-modal" class="modal hidden">
            <div class="modal-card" style="min-height:380px; position:relative;">
                <h3 id="lb-open-title" style="color:var(--primary);">Opening Lootbox...</h3>
                <div id="lb-opening-phase">
                    <span id="lb-open-box" class="lb-open-box">📦</span>
                    <p style="color:#aaa; margin:5px 0;">Tap the box to open!</p>
                    <button id="lb-tap-btn" class="btn primary" style="width:100%; margin-top:10px;"
