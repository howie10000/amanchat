                        <div id="lb-result-icon"
                            style="font-size:3.5em; margin-bottom:10px; position:relative; z-index:2;"></div>
                        <div id="lb-result-rarity" style="margin-bottom:8px; position:relative; z-index:2;"></div>
                        <div id="lb-result-name"
                            style="font-size:1.3em; font-weight:bold; color:var(--text); position:relative; z-index:2;">
