        @keyframes shardFly { 0% { transform: scale(0) rotate(0); opacity: 1; } 100% { transform: scale(3) rotate(360deg) translate(200px, 200px); opacity: 0; } }
        
        .legend-vortex {
            position: absolute; inset: 0;
            background: radial-gradient(circle, transparent 20%, #000 70%), 
