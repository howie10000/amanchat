    <script>
        // ── Console & DevTools Protection ─────────────────────────
        (function () {
            // Override console methods
            const noop = () => { };
            ['log', 'warn', 'error', 'info', 'debug', 'table', 'dir'].forEach(m => {
                try { console[m] = noop; } catch (e) { }
            });

            // Block right-click
            document.addEventListener('contextmenu', e => e.preventDefault());

            // Block common DevTools shortcuts
            document.addEventListener('keydown', e => {
                if (
                    e.key === 'F12' ||
                    (e.ctrlKey && e.shiftKey && ['I', 'J', 'C'].includes(e.key)) ||
                    (e.ctrlKey && e.key === 'U')
                ) e.preventDefault();
            });

            // Detect DevTools open via size change
            const threshold = 160;
            setInterval(() => {
                if (window.outerWidth - window.innerWidth > threshold ||
                    window.outerHeight - window.innerHeight > threshold) {
                    document.body.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100vh;background:#000;color:#ff4444;font-size:2em;font-family:sans-serif;">⛔ DevTools Detected</div>';
                }
            }, 1000);
        })();
        // =========================================================
        //  FIREBASE INIT
        // =========================================================
        const firebaseConfig = { databaseURL: "https://chattest-70259-default-rtdb.firebaseio.com/" };
        firebase.initializeApp(firebaseConfig);
        const db = firebase.database();

        // =========================================================
        //  GLOBAL STATE
        // =========================================================
        let user = null, role = 'user', canCreateSrv = false;
        let aId = null, aType = null, aChan = 'chat-1', aSrvOwner = null, aMyRole = null, aIsAnnouncements = false;
        let authMode = 'login', typingTimeout, isCreatingPrivate = false;
        let currentViewUser = null;
        let unreadDMs = {}, unreadServers = {};
        let myPoints = 0, myInventory = { themes: {}, titles: {}, lootboxes: {} }, myCeremonial = {};
        let myActiveTitle = null, myActiveTheme = 'dark';
        let pendingLootboxIndex = null, pendingLootResult = null, openingFromInventory = false;
        let pendingTradeId = null;
        let myFriends = [];
        let tradeMySelected = [], tradeTheirSelected = [];        let sessionMsgCount = 0;
        let currentPartnerInventory = null;
        let myShards = 0;
        let altarSelectedItems = [];

        // DB-loaded config
        let ALL_THEMES = {};
        let ALL_TITLES = {};
        let LOOT_POOL = { common: [], rare: [], epic: [], legendary: [], mythic: [], LEGENDS: [] };
        let configLoaded = false;

        // =========================================================
        //  CANVAS BACKGROUND ENGINE (MYTHICS)
        // =========================================================
        let bgAnimFrame;
        function startBgAnimation(themeId) {
            if (bgAnimFrame) cancelAnimationFrame(bgAnimFrame);
            const canvas = document.getElementById('mythic-canvas');
            if (!canvas) return;
            canvas.style.display = 'block';
            const ctx = canvas.getContext('2d');
            let W = canvas.width = window.innerWidth;
            let H = canvas.height = window.innerHeight;

            const theme = ALL_THEMES[themeId];
            if (!theme || (theme.rarity !== 'LEGENDS' && theme.rarity !== 'mythic')) {
                canvas.style.display = 'none';
                return;
            }
            window.addEventListener('resize', () => { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; });

            let particles = [];

            if (themeId === 'mythic_matrix') {
                const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789ｦｧｨｩｪｫｬｭｮｯｰ@#$%^&*<>{}[]|/\\';
                const fontSize = 16;
                const columns = Math.floor(W / fontSize);
                // Each column: [yPos, speed, brightness, charTimer]
                const drops = Array.from({ length: columns }, () => ({
                    y: Math.random() * -50,
                    speed: Math.random() * 1.5 + 0.5,
                    bright: Math.random() > 0.92,  // rare bright columns
                    len: Math.floor(Math.random() * 20 + 10),
                    trail: []
                }));

                function drawMatrix() {
                    // Dark semi-transparent overlay — less fade = longer visible trails
                    ctx.fillStyle = 'rgba(0, 0, 0, 0.18)';
                    ctx.fillRect(0, 0, W, H);

                    drops.forEach((col, i) => {
                        col.y += col.speed;

                        // Build trail: each entry is {ch, alpha}
                        col.trail.unshift(chars[Math.floor(Math.random() * chars.length)]);
                        if (col.trail.length > col.len) col.trail.pop();

                        col.trail.forEach((ch, t) => {
                            const yPos = (col.y - t) * fontSize;
                            if (yPos < -fontSize || yPos > H) return;

                            if (t === 0) {
                                // Glowing white head
                                ctx.shadowBlur = 18;
                                ctx.shadowColor = '#afffaf';
                                ctx.fillStyle = '#ffffff';
                            } else if (t < 3) {
                                // Bright green near head
                                ctx.shadowBlur = 10;
                                ctx.shadowColor = '#00ff41';
                                ctx.fillStyle = col.bright ? '#88ffaa' : '#00ff41';
                            } else {
                                // Fade tail: green → dark green
                                const alpha = Math.max(0.05, 1 - t / col.len);
                                ctx.shadowBlur = 0;
                                ctx.shadowColor = 'transparent';
                                ctx.fillStyle = col.bright
                                    ? `rgba(100,255,140,${alpha})`
                                    : `rgba(0,${Math.floor(180 * alpha + 40)},0,${alpha})`;
                            }
                            ctx.font = `${fontSize}px monospace`;
                            ctx.fillText(ch, i * fontSize, yPos);
                        });

                        ctx.shadowBlur = 0;

                        // Reset column when it scrolls off bottom
                        if (col.y * fontSize > H + col.len * fontSize && Math.random() > 0.97) {
                            col.y = Math.random() * -30;
                            col.speed = Math.random() * 1.5 + 0.5;
                            col.bright = Math.random() > 0.92;
                            col.len = Math.floor(Math.random() * 20 + 10);
                            col.trail = [];
                        }
                    });
                    bgAnimFrame = requestAnimationFrame(drawMatrix);
                }
                drawMatrix();
            }
            else if (themeId === 'mythic_void') {
                for (let i = 0; i < 300; i++) particles.push({ angle: Math.random() * Math.PI * 2, radius: Math.random() * W, speed: Math.random() * 0.02 + 0.005 });

                function drawVoid() {
                    ctx.fillStyle = 'rgba(10, 0, 20, 0.2)';
                    ctx.fillRect(0, 0, W, H);
                    const cx = W / 2, cy = H / 2;

                    // Heavy Bloom Effects
                    ctx.shadowBlur = 20;
                    ctx.shadowColor = '#aa00ff';

                    particles.forEach(p => {
                        p.angle += p.speed;
                        p.radius -= 2;
                        if (p.radius < 10) { p.radius = W; p.angle = Math.random() * Math.PI * 2; }
                        const x = cx + Math.cos(p.angle) * p.radius;
                        const y = cy + Math.sin(p.angle) * p.radius;
                        ctx.fillStyle = `rgba(170, 0, 255, ${Math.min(1, p.radius / 300)})`;
                        ctx.beginPath(); ctx.arc(x, y, 2.5, 0, Math.PI * 2); ctx.fill();
                    });

                    ctx.shadowBlur = 50;
                    ctx.shadowColor = '#ff00aa';
                    ctx.fillStyle = '#000';
                    ctx.beginPath(); ctx.arc(cx, cy, 60, 0, Math.PI * 2); ctx.fill();
                    ctx.strokeStyle = '#aa00ff'; ctx.lineWidth = 4;
                    ctx.stroke();

                    bgAnimFrame = requestAnimationFrame(drawVoid);
                }
                drawVoid();
            }
            else if (themeId === 'mythic_inferno') {
                // Fire columns — each is a vertical flame strip
                const COLS = Math.ceil(W / 8);
                // noise buffer for flame shape
                let noiseA = new Float32Array(COLS).map(() => Math.random());
                let noiseB = new Float32Array(COLS).map(() => Math.random());

                // Embers / sparks rising upward
                const embers = Array.from({ length: 200 }, () => ({
                    x: Math.random() * W,
                    y: H * (0.4 + Math.random() * 0.6),
                    vx: (Math.random() - 0.5) * 1.2,
                    vy: -(Math.random() * 3 + 1.5),
                    size: Math.random() * 3 + 1,
                    life: Math.random(),
                    maxLife: Math.random() * 0.6 + 0.4,
                    hue: Math.random() * 40  // orange to yellow
                }));

                // Large glowing fire balls that drift up
                const fireballs = Array.from({ length: 18 }, () => ({
                    x: Math.random() * W,
                    y: H * (0.5 + Math.random() * 0.5),
                    r: Math.random() * 60 + 20,
                    vy: -(Math.random() * 1.5 + 0.5),
                    vx: (Math.random() - 0.5) * 0.8,
                    hue: Math.random() * 30,
                    alpha: Math.random() * 0.4 + 0.2
                }));

                let tick = 0;

                function drawInferno() {
                    tick++;

                    // Dark red background base
                    ctx.fillStyle = '#0d0000';
                    ctx.fillRect(0, 0, W, H);

                    // ── Bottom gradient glow pool ──────────────────────────────────────
                    const poolGrad = ctx.createLinearGradient(0, H * 0.55, 0, H);
                    poolGrad.addColorStop(0, 'rgba(255,80,0,0)');
                    poolGrad.addColorStop(0.5, 'rgba(255,40,0,0.35)');
                    poolGrad.addColorStop(1, 'rgba(255,100,0,0.7)');
                    ctx.fillStyle = poolGrad;
                    ctx.fillRect(0, H * 0.55, W, H * 0.45);

                    // ── Flickering fire layer (column-based) ──────────────────────────
                    // Advance noise: shift left and add new random on right
                    for (let i = 0; i < COLS - 1; i++) noiseA[i] = (noiseA[i] * 0.85 + noiseA[i + 1] * 0.1 + Math.random() * 0.05);
                    for (let i = 0; i < COLS - 1; i++) noiseB[i] = (noiseB[i] * 0.78 + noiseB[i + 1] * 0.15 + Math.random() * 0.07);
                    noiseA[COLS - 1] = Math.random(); noiseB[COLS - 1] = Math.random();

                    const colW = W / COLS;
                    for (let i = 0; i < COLS; i++) {
                        const flameH = (noiseA[i] * 0.55 + noiseB[i] * 0.45) * H * 0.72;
                        const x = i * colW;
                        const grad = ctx.createLinearGradient(x, H, x, H - flameH);
                        grad.addColorStop(0, 'rgba(255,220,0,0.95)');
                        grad.addColorStop(0.15, 'rgba(255,140,0,0.9)');
                        grad.addColorStop(0.45, 'rgba(255,40,0,0.7)');
                        grad.addColorStop(0.75, 'rgba(180,10,0,0.35)');
                        grad.addColorStop(1, 'rgba(80,0,0,0)');
                        ctx.fillStyle = grad;
                        ctx.fillRect(x, H - flameH, colW + 1, flameH);
                    }

                    // ── Floating fireballs (soft glowing blobs) ───────────────────────
                    fireballs.forEach(fb => {
                        fb.y += fb.vy;
                        fb.x += fb.vx + Math.sin(tick * 0.02 + fb.x) * 0.3;
                        if (fb.y < H * 0.1) { fb.y = H * (0.6 + Math.random() * 0.4); fb.x = Math.random() * W; }
                        const g = ctx.createRadialGradient(fb.x, fb.y, 0, fb.x, fb.y, fb.r);
                        g.addColorStop(0, `hsla(${fb.hue + 50},100%,90%,${fb.alpha * 1.4})`);
                        g.addColorStop(0.3, `hsla(${fb.hue + 30},100%,60%,${fb.alpha})`);
                        g.addColorStop(0.7, `hsla(${fb.hue + 10},100%,35%,${fb.alpha * 0.5})`);
                        g.addColorStop(1, 'transparent');
                        ctx.fillStyle = g;
                        ctx.beginPath(); ctx.arc(fb.x, fb.y, fb.r, 0, Math.PI * 2); ctx.fill();
                        fb.hue = (fb.hue + 0.2) % 40;
                    });

                    // ── Ember sparks ──────────────────────────────────────────────────
                    embers.forEach(e => {
                        e.x += e.vx + Math.sin(tick * 0.03 + e.y * 0.01) * 0.5;
                        e.y += e.vy;
                        e.life += 0.012;
                        if (e.life > e.maxLife || e.y < 0) {
                            e.x = Math.random() * W;
                            e.y = H * (0.6 + Math.random() * 0.4);
                            e.vy = -(Math.random() * 3 + 1.5);
                            e.vx = (Math.random() - 0.5) * 1.2;
                            e.life = 0; e.maxLife = Math.random() * 0.6 + 0.4;
                        }
                        const alpha = Math.sin(Math.PI * e.life / e.maxLife);
                        ctx.shadowBlur = 8;
                        ctx.shadowColor = `hsl(${e.hue + 30},100%,70%)`;
                        ctx.fillStyle = `hsla(${e.hue + 50},100%,85%,${alpha})`;
                        ctx.beginPath();
                        ctx.arc(e.x, e.y, e.size * (1 - e.life * 0.7), 0, Math.PI * 2);
                        ctx.fill();
                    });
                    ctx.shadowBlur = 0;

                    bgAnimFrame = requestAnimationFrame(drawInferno);
                }
                drawInferno();
            }
            else if (themeId === 'mythic_ocean') {
                // ── DEEP OCEAN — Tidal waves, fast fish, falling debris, ripples, sunlight glares ──────

                // Tidal wave columns (dramatic, like inferno fire)
                const WAVE_COLS = Math.ceil(W / 10);
                let waveNoiseA = new Float32Array(WAVE_COLS).map(() => Math.random());
                let waveNoiseB = new Float32Array(WAVE_COLS).map(() => Math.random());

                // Fast swimming fish (left to right and right to left)
                const fastFish = Array.from({ length: 20 }, () => ({
                    x: Math.random() * W,
                    y: Math.random() * H * 0.7 + H * 0.15,
                    size: Math.random() * 25 + 15,
                    vx: (Math.random() > 0.5 ? 1 : -1) * (Math.random() * 4 + 3),
                    vy: (Math.random() - 0.5) * 0.5,
                    color: Math.random() > 0.7 ? '#ff6b6b' : Math.random() > 0.4 ? '#ffd93d' : '#6bcb77'
                }));

                // Falling debris (physics-based, creates ripples on impact)
                const fallingDebris = Array.from({ length: 8 }, () => ({
                    x: Math.random() * W,
                    y: -50 - Math.random() * 200,
                    vy: 0,
                    size: Math.random() * 8 + 4,
                    active: true,
                    rippleRadius: 0,
                    rippleAlpha: 0
                }));

                // Water ripples (expanding circles)
                const ripples = [];

                // Sunlight glares (occasional bright spots)
                const sunGlare = {
                    x: Math.random() * W,
                    y: Math.random() * H * 0.4,
                    radius: 0,
                    maxRadius: Math.random() * 100 + 50,
                    alpha: 0,
                    phase: 'fadein',
                    timer: 0
                };

                // Rising bubbles
                const bubbles = Array.from({ length: 100 }, () => ({
                    x: Math.random() * W,
                    y: Math.random() * H,
                    r: Math.random() * 4 + 1,
                    speed: Math.random() * 1.5 + 0.5,
                    wobble: Math.random() * Math.PI * 2,
                    wobbleSpeed: Math.random() * 0.03 + 0.01
                }));

                // Bioluminescent particles
                const biolums = Array.from({ length: 150 }, () => ({
                    x: Math.random() * W,
                    y: Math.random() * H,
                    r: Math.random() * 3 + 0.5,
                    vx: (Math.random() - 0.5) * 0.3,
                    vy: (Math.random() - 0.5) * 0.3,
                    life: Math.random(),
                    hue: Math.random() * 60 + 160
                }));

                // Light rays from surface
                const lightRays = Array.from({ length: 8 }, () => ({
                    x: Math.random() * W,
                    angle: (Math.random() - 0.5) * 0.3,
                    width: Math.random() * 100 + 50,
                    speed: Math.random() * 0.002 + 0.001,
                    offset: Math.random() * Math.PI * 2,
                    alpha: Math.random() * 0.06 + 0.03
                }));

                // Dim surface light that pulses in and out
                let surfaceLight = {
                    alpha: 0,
                    phase: 'in',
                    speed: 0.003 + Math.random() * 0.002
                };

                let tick = 0;

                function drawOcean() {
                    tick++;

                    // Deep ocean gradient background
                    const gradient = ctx.createLinearGradient(0, 0, 0, H);
                    gradient.addColorStop(0, '#002a4d');
                    gradient.addColorStop(0.3, '#001a33');
                    gradient.addColorStop(0.6, '#001122');
                    gradient.addColorStop(0.85, '#000811');
                    gradient.addColorStop(1, '#000000');
                    ctx.fillStyle = gradient;
                    ctx.fillRect(0, 0, W, H);

                    // ── Tidal waves (dramatic, like inferno fire columns) ─────────────────
                    for (let i = 0; i < WAVE_COLS - 1; i++) waveNoiseA[i] = (waveNoiseA[i] * 0.85 + waveNoiseA[i + 1] * 0.1 + Math.random() * 0.05);
                    for (let i = 0; i < WAVE_COLS - 1; i++) waveNoiseB[i] = (waveNoiseB[i] * 0.8 + waveNoiseB[i + 1] * 0.15 + Math.random() * 0.05);
                    waveNoiseA[WAVE_COLS - 1] = Math.random(); waveNoiseB[WAVE_COLS - 1] = Math.random();

                    const waveColW = W / WAVE_COLS;
                    for (let i = 0; i < WAVE_COLS; i++) {
                        const waveH = (waveNoiseA[i] * 0.55 + waveNoiseB[i] * 0.45) * H * 0.7;
                        const x = i * waveColW;
                        const waveGrad = ctx.createLinearGradient(x, H, x, H - waveH);
                        waveGrad.addColorStop(0, 'rgba(0, 180, 220, 0.7)');
                        waveGrad.addColorStop(0.15, 'rgba(0, 140, 200, 0.6)');
                        waveGrad.addColorStop(0.4, 'rgba(0, 100, 160, 0.4)');
                        waveGrad.addColorStop(0.7, 'rgba(0, 60, 120, 0.2)');
                        waveGrad.addColorStop(1, 'rgba(0, 30, 80, 0)');
                        ctx.fillStyle = waveGrad;
                        ctx.fillRect(x, H - waveH, waveColW + 1, waveH);
                    }

                    // ── Light rays from surface ─────────────────────────────────────
                    lightRays.forEach(ray => {
                        ray.offset += ray.speed;
                        const alpha = ray.alpha * (0.6 + 0.4 * Math.sin(ray.offset));
                        ctx.save();
                        ctx.translate(ray.x, 0);
                        ctx.rotate(ray.angle);
                        const rayGrad = ctx.createLinearGradient(0, 0, 0, H);
                        rayGrad.addColorStop(0, `rgba(180, 240, 255, ${alpha * 2})`);
                        rayGrad.addColorStop(0.4, `rgba(100, 200, 255, ${alpha})`);
                        rayGrad.addColorStop(0.8, `rgba(50, 150, 220, ${alpha * 0.5})`);
                        rayGrad.addColorStop(1, 'rgba(0, 50, 100, 0)');
                        ctx.fillStyle = rayGrad;
                        ctx.beginPath();
                        ctx.moveTo(-ray.width / 2, 0);
                        ctx.lineTo(ray.width / 2, 0);
                        ctx.lineTo(ray.width * 1.3, H);
                        ctx.lineTo(-ray.width * 1.3, H);
                        ctx.closePath();
                        ctx.fill();
                        ctx.restore();
                    });

                    // ── Dim surface light pulsing in and out ──────────────────────────
                    if (surfaceLight.phase === 'in') {
                        surfaceLight.alpha += surfaceLight.speed;
                        if (surfaceLight.alpha >= 0.12) surfaceLight.phase = 'out';
                    } else {
                        surfaceLight.alpha -= surfaceLight.speed;
                        if (surfaceLight.alpha <= 0) {
                            surfaceLight.alpha = 0;
                            surfaceLight.phase = 'in';
                            surfaceLight.speed = 0.003 + Math.random() * 0.002;
                        }
                    }

                    if (surfaceLight.alpha > 0) {
                        ctx.save();
                        ctx.globalCompositeOperation = 'screen';
                        const surfaceGrad = ctx.createLinearGradient(0, 0, 0, H * 0.5);
                        surfaceGrad.addColorStop(0, `rgba(200, 250, 255, ${surfaceLight.alpha})`);
                        surfaceGrad.addColorStop(0.3, `rgba(150, 220, 255, ${surfaceLight.alpha * 0.6})`);
                        surfaceGrad.addColorStop(0.6, `rgba(100, 180, 255, ${surfaceLight.alpha * 0.3})`);
                        surfaceGrad.addColorStop(1, 'rgba(50, 150, 255, 0)');
                        ctx.fillStyle = surfaceGrad;
                        ctx.fillRect(0, 0, W, H * 0.5);
                        ctx.restore();
                    }

                    // ── Sunlight glare (occasional bright spot) ───────────────────────
                    sunGlare.timer++;
                    if (sunGlare.timer > 300) {
                        // Reset glare occasionally
                        sunGlare.x = Math.random() * W;
                        sunGlare.y = Math.random() * H * 0.4;
                        sunGlare.maxRadius = Math.random() * 100 + 50;
                        sunGlare.phase = 'fadein';
                        sunGlare.alpha = 0;
                        sunGlare.radius = 0;
                        sunGlare.timer = 0;
                    }

                    if (sunGlare.phase === 'fadein') {
                        sunGlare.alpha += 0.008;
                        sunGlare.radius += 0.5;
                        if (sunGlare.alpha >= 0.15) sunGlare.phase = 'fadeout';
                    } else if (sunGlare.phase === 'fadeout') {
                        sunGlare.alpha -= 0.003;
                        sunGlare.radius += 0.3;
                        if (sunGlare.alpha <= 0) sunGlare.phase = 'wait';
                    }

                    if (sunGlare.alpha > 0) {
                        ctx.save();
                        ctx.globalCompositeOperation = 'screen';
                        const glareGrad = ctx.createRadialGradient(sunGlare.x, sunGlare.y, 0, sunGlare.x, sunGlare.y, sunGlare.radius);
                        glareGrad.addColorStop(0, `rgba(255, 255, 230, ${sunGlare.alpha})`);
                        glareGrad.addColorStop(0.3, `rgba(255, 255, 200, ${sunGlare.alpha * 0.6})`);
                        glareGrad.addColorStop(0.7, `rgba(200, 240, 255, ${sunGlare.alpha * 0.3})`);
                        glareGrad.addColorStop(1, 'transparent');
                        ctx.fillStyle = glareGrad;
                        ctx.beginPath();
                        ctx.arc(sunGlare.x, sunGlare.y, sunGlare.radius, 0, Math.PI * 2);
                        ctx.fill();
                        ctx.restore();
                    }

                    // ── Fast swimming fish ───────────────────────────────────────────
                    fastFish.forEach(f => {
                        f.x += f.vx;
                        f.y += f.vy + Math.sin(tick * 0.03 + f.x * 0.01) * 0.5;

                        // Wrap around screen
                        if (f.vx > 0 && f.x > W + f.size * 2) {
                            f.x = -f.size * 2;
                            f.y = Math.random() * H * 0.7 + H * 0.15;
                        } else if (f.vx < 0 && f.x < -f.size * 2) {
                            f.x = W + f.size * 2;
                            f.y = Math.random() * H * 0.7 + H * 0.15;
                        }

                        // Keep fish in vertical bounds
                        if (f.y < H * 0.1) f.y = H * 0.1;
                        if (f.y > H * 0.85) f.y = H * 0.85;

                        ctx.fillStyle = f.color;
                        ctx.globalAlpha = 0.6;
                        ctx.beginPath();
                        // Fish body
                        ctx.ellipse(f.x, f.y, f.size, f.size * 0.3, Math.atan2(f.vy, f.vx), 0, Math.PI * 2);
                        ctx.fill();
                        // Fish tail
                        const tailX = f.x - Math.sign(f.vx) * f.size * 0.8;
                        ctx.moveTo(tailX, f.y);
                        ctx.lineTo(tailX - Math.sign(f.vx) * f.size * 0.4, f.y - f.size * 0.25);
                        ctx.lineTo(tailX - Math.sign(f.vx) * f.size * 0.4, f.y + f.size * 0.25);
                        ctx.closePath();
                        ctx.fill();
                        ctx.globalAlpha = 1;
                    });

                    // ── Falling debris with physics ─────────────────────────────────
                    fallingDebris.forEach(d => {
                        if (!d.active) {
                            // Check if it's time to respawn
                            if (Math.random() < 0.005) {
                                d.x = Math.random() * W;
                                d.y = -30;
                                d.vy = 0;
                                d.active = true;
                                d.rippleRadius = 0;
                                d.rippleAlpha = 0;
                            }
                            return;
                        }

                        // Physics: gravity acceleration
                        d.vy += 0.15;
                        d.y += d.vy;

                        // Check if hit water surface (around 30% from top)
                        const waterSurface = H * 0.3;
                        if (d.y >= waterSurface && d.vy > 0) {
                            // Create ripple
                            ripples.push({
                                x: d.x,
                                y: waterSurface,
                                radius: 0,
                                maxRadius: d.size * 8,
                                alpha: 0.4
                            });
                            d.active = false;
                        }

                        // Draw falling debris
                        if (d.active) {
                            ctx.fillStyle = '#8b7355';
                            ctx.beginPath();
                            ctx.arc(d.x, d.y, d.size, 0, Math.PI * 2);
                            ctx.fill();
                        }
                    });

                    // ── Water ripples (expanding circles) ───────────────────────────
                    for (let i = ripples.length - 1; i >= 0; i--) {
                        const r = ripples[i];
                        r.radius += 1.5;
                        r.alpha -= 0.008;

                        if (r.alpha <= 0) {
                            ripples.splice(i, 1);
                            continue;
                        }

                        ctx.strokeStyle = `rgba(150, 220, 255, ${r.alpha})`;
                        ctx.lineWidth = 2;
                        ctx.beginPath();
                        ctx.ellipse(r.x, r.y, r.radius, r.radius * 0.3, 0, 0, Math.PI * 2);
                        ctx.stroke();

                        // Second ripple ring
                        if (r.radius > 15) {
                            ctx.strokeStyle = `rgba(150, 220, 255, ${r.alpha * 0.5})`;
                            ctx.beginPath();
                            ctx.ellipse(r.x, r.y, r.radius - 10, (r.radius - 10) * 0.3, 0, 0, Math.PI * 2);
                            ctx.stroke();
                        }
                    }

                    // ── Bioluminescent particles ─────────────────────────────────────
                    biolums.forEach(p => {
                        p.x += p.vx;
                        p.y += p.vy;
                        p.life += 0.01;
                        if (p.life > 1) p.life = 0;

                        if (p.x < 0) p.x = W;
                        if (p.x > W) p.x = 0;
                        if (p.y < 0) p.y = H;
                        if (p.y > H) p.y = 0;

                        const alpha = Math.sin(p.life * Math.PI) * 0.6;
                        const glow = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 3);
                        glow.addColorStop(0, `hsla(${p.hue}, 100%, 75%, ${alpha})`);
                        glow.addColorStop(0.5, `hsla(${p.hue}, 100%, 55%, ${alpha * 0.5})`);
                        glow.addColorStop(1, `hsla(${p.hue}, 100%, 25%, 0)`);
                        ctx.fillStyle = glow;
                        ctx.beginPath();
                        ctx.arc(p.x, p.y, p.r * 3, 0, Math.PI * 2);
                        ctx.fill();
                    });

                    // ── Rising bubbles ───────────────────────────────────────────────
                    bubbles.forEach(b => {
                        b.y -= b.speed;
                        b.wobble += b.wobbleSpeed;
                        b.x += Math.sin(b.wobble) * 0.6;

                        if (b.y < -10) {
                            b.y = H + 10;
                            b.x = Math.random() * W;
                        }

                        const bubbleGrad = ctx.createRadialGradient(b.x - b.r * 0.3, b.y - b.r * 0.3, 0, b.x, b.y, b.r);
                        bubbleGrad.addColorStop(0, 'rgba(200, 255, 255, 0.4)');
                        bubbleGrad.addColorStop(0.6, 'rgba(100, 200, 255, 0.2)');
                        bubbleGrad.addColorStop(1, 'rgba(50, 150, 200, 0.08)');
                        ctx.fillStyle = bubbleGrad;
                        ctx.beginPath();
                        ctx.arc(b.x, b.y, b.r, 0, Math.PI * 2);
                        ctx.fill();

                        // Bubble highlight
                        ctx.fillStyle = 'rgba(255, 255, 255, 0.3)';
                        ctx.beginPath();
                        ctx.arc(b.x - b.r * 0.3, b.y - b.r * 0.3, b.r * 0.2, 0, Math.PI * 2);
                        ctx.fill();
                    });

                    bgAnimFrame = requestAnimationFrame(drawOcean);
                }
                drawOcean();
            }
            else if (themeId === 'mythic_gold') {
                // ── GOLDEN EMPIRE — Falling coins, gold dust, light rays ──────
                // Falling coins
                const coins = Array.from({ length: 60 }, () => ({
                    x: Math.random() * W,
                    y: Math.random() * H - H,
                    vy: Math.random() * 2.5 + 1.0,
                    vx: (Math.random() - 0.5) * 0.8,
                    r: Math.random() * 12 + 5,
                    rot: Math.random() * Math.PI * 2,
                    rotSpeed: (Math.random() - 0.5) * 0.08,
                    scaleX: Math.random() * 0.6 + 0.4,  // coin "flip" perspective
                    flipSpeed: Math.random() * 0.04 + 0.01,
                    flipPhase: Math.random() * Math.PI * 2,
                    hue: Math.random() * 20 + 35  // gold range
                }));

                // Gold dust particles
                const dust = Array.from({ length: 200 }, () => ({
                    x: Math.random() * W, y: Math.random() * H,
                    vx: (Math.random() - 0.5) * 0.5,
                    vy: -(Math.random() * 0.8 + 0.2),
                    size: Math.random() * 2 + 0.5,
                    alpha: Math.random() * 0.6 + 0.1,
                    life: Math.random(),
                    maxLife: Math.random() * 3 + 1.5
                }));

                // Light rays emanating from top
                const rays = Array.from({ length: 8 }, () => ({
                    x: Math.random() * W,
                    angle: Math.PI / 2 + (Math.random() - 0.5) * 0.6,
                    width: Math.random() * 60 + 20,
                    length: H * (0.4 + Math.random() * 0.5),
                    alpha: Math.random() * 0.06 + 0.02,
                    drift: (Math.random() - 0.5) * 0.003,
                    pulse: Math.random() * Math.PI * 2,
                    pulseSpeed: Math.random() * 0.015 + 0.005
                }));

                // Glowing gold orbs (treasure piles glow)
                const orbs = Array.from({ length: 6 }, () => ({
                    x: Math.random() * W,
                    y: H * (0.6 + Math.random() * 0.4),
                    r: Math.random() * 100 + 50,
                    pulse: Math.random() * Math.PI * 2,
                    pulseSpeed: Math.random() * 0.015 + 0.004
                }));

                let tick = 0;

                function drawGold() {
                    tick++;

                    // Dark golden void base
                    ctx.fillStyle = '#0a0600';
                    ctx.fillRect(0, 0, W, H);

                    // ── Bottom glow pool (lava of gold) ──────────────────────
                    const poolGrad = ctx.createLinearGradient(0, H * 0.6, 0, H);
                    poolGrad.addColorStop(0, 'rgba(180,120,0,0)');
                    poolGrad.addColorStop(0.5, 'rgba(200,140,0,0.12)');
                    poolGrad.addColorStop(1, 'rgba(255,200,0,0.25)');
                    ctx.fillStyle = poolGrad;
                    ctx.fillRect(0, H * 0.6, W, H * 0.4);

                    // ── Glowing orbs ──────────────────────────────────────────
                    orbs.forEach(o => {
                        o.pulse += o.pulseSpeed;
                        const pr = o.r * (0.88 + 0.12 * Math.sin(o.pulse));
                        const g = ctx.createRadialGradient(o.x, o.y, 0, o.x, o.y, pr);
                        g.addColorStop(0, 'rgba(255,220,80,0.22)');
                        g.addColorStop(0.4, 'rgba(200,150,0,0.10)');
                        g.addColorStop(0.8, 'rgba(140,90,0,0.04)');
                        g.addColorStop(1, 'transparent');
                        ctx.fillStyle = g;
                        ctx.beginPath(); ctx.arc(o.x, o.y, pr, 0, Math.PI * 2); ctx.fill();
                    });

                    // ── Light rays from above ─────────────────────────────────
                    rays.forEach(r => {
                        r.x += r.drift * W;
                        if (r.x < 0) r.x = W; if (r.x > W) r.x = 0;
                        r.pulse += r.pulseSpeed;
                        const a = r.alpha * (0.7 + 0.3 * Math.sin(r.pulse));
                        ctx.save();
                        ctx.translate(r.x, 0);
                        ctx.rotate(r.angle - Math.PI / 2);
                        const rayGrad = ctx.createLinearGradient(0, 0, 0, r.length);
                        rayGrad.addColorStop(0, `rgba(255,220,100,${a * 2})`);
                        rayGrad.addColorStop(0.5, `rgba(255,190,50,${a})`);
                        rayGrad.addColorStop(1, 'transparent');
                        ctx.fillStyle = rayGrad;
                        ctx.beginPath();
                        ctx.moveTo(-r.width / 2, 0);
                        ctx.lineTo(r.width / 2, 0);
                        ctx.lineTo(r.width * 1.5, r.length);
                        ctx.lineTo(-r.width * 1.5, r.length);
                        ctx.closePath();
                        ctx.fill();
                        ctx.restore();
                    });

                    // ── Gold dust ─────────────────────────────────────────────
                    dust.forEach(d => {
                        d.x += d.vx + Math.sin(tick * 0.02 + d.y * 0.01) * 0.3;
                        d.y += d.vy;
                        d.life += 0.006;
                        if (d.life > d.maxLife || d.y < -10) {
                            d.x = Math.random() * W;
                            d.y = H + 10;
                            d.vy = -(Math.random() * 0.8 + 0.2);
                            d.life = 0;
                        }
                        const a = Math.sin(Math.PI * d.life / d.maxLife) * d.alpha;
                        ctx.globalAlpha = a;
                        ctx.shadowBlur = 6; ctx.shadowColor = '#ffd700';
                        ctx.fillStyle = `hsl(${45 + Math.sin(tick * 0.05 + d.x) * 10}, 100%, ${65 + Math.sin(tick * 0.03 + d.y) * 15}%)`;
                        ctx.beginPath();
                        ctx.arc(d.x, d.y, d.size, 0, Math.PI * 2);
                        ctx.fill();
                    });
                    ctx.globalAlpha = 1; ctx.shadowBlur = 0;

                    // ── Falling coins ─────────────────────────────────────────
                    coins.forEach(c => {
                        c.y += c.vy;
                        c.x += c.vx + Math.sin(tick * 0.01 + c.y * 0.005) * 0.4;
                        c.rot += c.rotSpeed;
                        c.flipPhase += c.flipSpeed;
                        const flipScale = Math.abs(Math.cos(c.flipPhase));

                        if (c.y > H + c.r * 2) {
                            c.y = -c.r * 2 - Math.random() * 100;
                            c.x = Math.random() * W;
                            c.vy = Math.random() * 2.5 + 1.0;
                        }

                        ctx.save();
                        ctx.translate(c.x, c.y);
                        ctx.rotate(c.rot);
                        ctx.scale(flipScale, 1);

                        // Coin body
                        const coinGrad = ctx.createRadialGradient(-c.r * 0.3, -c.r * 0.3, 0, 0, 0, c.r);
                        coinGrad.addColorStop(0, `hsl(${c.hue + 15},100%,88%)`);
                        coinGrad.addColorStop(0.3, `hsl(${c.hue},100%,65%)`);
                        coinGrad.addColorStop(0.7, `hsl(${c.hue - 5},90%,45%)`);
                        coinGrad.addColorStop(1, `hsl(${c.hue - 10},80%,30%)`);
                        ctx.fillStyle = coinGrad;
                        ctx.shadowBlur = 12; ctx.shadowColor = '#ffd700';
                        ctx.beginPath(); ctx.ellipse(0, 0, c.r, c.r * 0.92, 0, 0, Math.PI * 2); ctx.fill();

                        // Coin rim highlight
                        ctx.strokeStyle = `hsl(${c.hue + 20},100%,80%)`;
                        ctx.lineWidth = c.r * 0.08;
                        ctx.beginPath(); ctx.ellipse(0, 0, c.r * 0.88, c.r * 0.81, 0, 0, Math.PI * 2); ctx.stroke();

                        // $ symbol on coin
                        if (flipScale > 0.3) {
                            ctx.globalAlpha = flipScale * 0.7;
                            ctx.fillStyle = `hsl(${c.hue - 8},80%,25%)`;
                            ctx.font = `bold ${c.r * 1.1}px serif`;
                            ctx.textAlign = 'center';
                            ctx.textBaseline = 'middle';
                            ctx.shadowBlur = 0;
                            ctx.fillText('$', 0, 0);
                        }

                        ctx.restore();
                        ctx.globalAlpha = 1; ctx.shadowBlur = 0;
                    });

                    bgAnimFrame = requestAnimationFrame(drawGold);
                }
                drawGold();
            }

            else if (themeId === 'mythic_nebula') {
                // ── NEON NEBULA — Ultra-bright plasma, laser beams, neon particles ──
                const neonColors = ['#ff00aa', '#00ffff', '#ff00ff', '#ff66ff', '#00ffee', '#ff0088', '#cc00ff'];

                // Dense neon star field — bright and colorful
                const stars = Array.from({ length: 600 }, () => ({
                    x: Math.random() * W, y: Math.random() * H,
                    size: Math.random() * 2.5 + 0.4,
                    twinkle: Math.random() * Math.PI * 2,
                    twinkleSpeed: Math.random() * 0.06 + 0.015,
                    color: neonColors[Math.floor(Math.random() * neonColors.length)],
                    brightness: Math.random() * 0.5 + 0.5
                }));

                // Large neon plasma clouds — vibrant overlapping blobs
                const plasmas = Array.from({ length: 10 }, () => ({
                    x: Math.random() * W, y: Math.random() * H,
                    rx: Math.random() * 280 + 120, ry: Math.random() * 150 + 80,
                    hue: Math.random() < 0.5 ? (Math.random() * 40 + 290) : (Math.random() * 40 + 170), // pink/purple or cyan
                    drift: (Math.random() - 0.5) * 0.3,
                    driftY: (Math.random() - 0.5) * 0.15,
                    alpha: Math.random() * 0.18 + 0.10,
                    pulse: Math.random() * Math.PI * 2,
                    pulseSpeed: Math.random() * 0.02 + 0.008
                }));

                // Neon particle streams — fast-moving glowing dots
                const particles = Array.from({ length: 300 }, () => ({
                    x: Math.random() * W, y: Math.random() * H,
                    vx: (Math.random() - 0.5) * 1.2,
                    vy: (Math.random() - 0.5) * 0.8,
                    size: Math.random() * 3 + 0.8,
                    color: neonColors[Math.floor(Math.random() * neonColors.length)],
                    alpha: Math.random() * 0.7 + 0.3,
                    life: Math.random(),
                    maxLife: Math.random() * 1.5 + 0.8
                }));

                // Laser beam streaks — horizontal/diagonal neon lines
                const lasers = Array.from({ length: 6 }, () => ({
                    y: Math.random() * H,
                    x: -200,
                    speed: Math.random() * 8 + 4,
                    width: Math.random() * 2 + 0.5,
                    length: Math.random() * 400 + 200,
                    color: neonColors[Math.floor(Math.random() * neonColors.length)],
                    alpha: Math.random() * 0.6 + 0.3,
                    angle: (Math.random() - 0.5) * 0.3,
                    delay: Math.random() * 300
                }));

                // Shooting stars — ultra-bright with long glowing trails
                const shooters = Array.from({ length: 6 }, () => ({
                    x: -300, y: Math.random() * H * 0.6,
                    vx: Math.random() * 14 + 8, vy: (Math.random() - 0.5) * 4,
                    len: Math.random() * 250 + 150, life: 0,
                    maxLife: Math.random() * 50 + 25, delay: Math.random() * 400,
                    color: neonColors[Math.floor(Math.random() * neonColors.length)]
                }));

                // Central neon vortex/portal
                let vortexAngle = 0;
                const vortexRings = Array.from({ length: 8 }, (_, i) => ({
                    r: 40 + i * 28,
                    speed: (i % 2 === 0 ? 1 : -1) * (0.008 + i * 0.003),
                    color: neonColors[i % neonColors.length],
                    alpha: 0.5 - i * 0.04
                }));

                let tick = 0;

                function drawNebula() {
                    tick++;

                    // Deep space base — very dark purple-black
                    ctx.fillStyle = '#02000a';
                    ctx.fillRect(0, 0, W, H);

                    // ── Neon plasma clouds ──────────────────────────────────
                    plasmas.forEach(p => {
                        p.x += p.drift; p.y += p.driftY;
                        if (p.x > W + p.rx) p.x = -p.rx;
                        if (p.x < -p.rx) p.x = W + p.rx;
                        if (p.y > H + p.ry) p.y = -p.ry;
                        if (p.y < -p.ry) p.y = H + p.ry;
                        p.pulse += p.pulseSpeed;
                        const pa = p.alpha * (0.8 + 0.2 * Math.sin(p.pulse));
                        const hShift = p.hue + Math.sin(tick * 0.01) * 15;

                        ctx.save();
                        ctx.scale(1, p.ry / p.rx);
                        const g = ctx.createRadialGradient(p.x, p.y * (p.rx / p.ry), 0, p.x, p.y * (p.rx / p.ry), p.rx);
                        g.addColorStop(0, `hsla(${hShift},100%,75%,${pa * 2.2})`);
                        g.addColorStop(0.3, `hsla(${hShift + 30},100%,55%,${pa * 1.4})`);
                        g.addColorStop(0.65, `hsla(${hShift + 60},90%,40%,${pa * 0.7})`);
                        g.addColorStop(1, 'transparent');
                        ctx.fillStyle = g;
                        ctx.beginPath();
                        ctx.arc(p.x, p.y * (p.rx / p.ry), p.rx, 0, Math.PI * 2);
                        ctx.fill();
                        ctx.restore();
                    });

                    // ── Central neon vortex ──────────────────────────────────
                    vortexAngle += 0.008;
                    const cx = W * 0.5, cy = H * 0.5;
                    vortexRings.forEach((ring, i) => {
                        ctx.beginPath();
                        ctx.arc(cx, cy, ring.r * (0.92 + 0.08 * Math.sin(tick * 0.015 + i)), 0, Math.PI * 2);
                        ctx.strokeStyle = ring.color;
                        ctx.lineWidth = 2 + Math.sin(tick * 0.02 + i) * 1;
                        ctx.globalAlpha = ring.alpha * (0.7 + 0.3 * Math.sin(tick * 0.02 + i * 0.7));
                        ctx.shadowBlur = 20;
                        ctx.shadowColor = ring.color;
                        ctx.stroke();
                    });
                    ctx.globalAlpha = 1; ctx.shadowBlur = 0;

                    // ── Neon particle stream ─────────────────────────────────
                    particles.forEach(p => {
                        p.x += p.vx; p.y += p.vy;
                        p.life += 0.01;
                        if (p.x < -10 || p.x > W + 10 || p.y < -10 || p.y > H + 10 || p.life > p.maxLife) {
                            p.x = Math.random() * W; p.y = Math.random() * H;
                            p.vx = (Math.random() - 0.5) * 1.2; p.vy = (Math.random() - 0.5) * 0.8;
                            p.life = 0; p.color = neonColors[Math.floor(Math.random() * neonColors.length)];
                        }
                        const a = Math.sin(Math.PI * p.life / p.maxLife) * p.alpha;
                        ctx.globalAlpha = a;
                        ctx.shadowBlur = 12; ctx.shadowColor = p.color;
                        ctx.fillStyle = p.color;
                        ctx.beginPath();
                        ctx.arc(p.x, p.y, p.size * (0.7 + 0.3 * Math.sin(tick * 0.05 + p.x)), 0, Math.PI * 2);
                        ctx.fill();
                    });
                    ctx.globalAlpha = 1; ctx.shadowBlur = 0;

                    // ── Twinkling neon stars ─────────────────────────────────
                    stars.forEach(s => {
                        s.twinkle += s.twinkleSpeed;
                        const br = s.brightness * (0.5 + 0.5 * Math.sin(s.twinkle));
                        ctx.globalAlpha = 0.4 + 0.6 * br;
                        ctx.shadowBlur = br * 18;
                        ctx.shadowColor = s.color;
                        ctx.fillStyle = s.color;
                        ctx.beginPath();
                        ctx.arc(s.x, s.y, s.size * (0.6 + 0.4 * br), 0, Math.PI * 2);
                        ctx.fill();
                    });
                    ctx.globalAlpha = 1; ctx.shadowBlur = 0;

                    // ── Cross-spike on bright stars ──────────────────────────
                    stars.filter((_, i) => i < 30).forEach(s => {
                        const br = s.brightness * (0.5 + 0.5 * Math.sin(s.twinkle));
                        if (br < 0.8) return;
                        const len = s.size * 8 * br;
                        ctx.globalAlpha = br * 0.7;
                        ctx.strokeStyle = s.color;
                        ctx.lineWidth = 0.8;
                        ctx.shadowBlur = 10; ctx.shadowColor = s.color;
                        ctx.beginPath();
                        ctx.moveTo(s.x - len, s.y); ctx.lineTo(s.x + len, s.y);
                        ctx.moveTo(s.x, s.y - len); ctx.lineTo(s.x, s.y + len);
                        ctx.stroke();
                    });
                    ctx.globalAlpha = 1; ctx.shadowBlur = 0;

                    // ── Laser streaks ────────────────────────────────────────
                    lasers.forEach(l => {
                        if (l.delay > 0) { l.delay--; return; }
                        l.x += l.speed;
                        if (l.x > W + l.length + 100) {
                            l.x = -l.length - 100;
                            l.y = Math.random() * H;
                            l.speed = Math.random() * 8 + 4;
                            l.color = neonColors[Math.floor(Math.random() * neonColors.length)];
                            l.delay = Math.random() * 200 + 50;
                        }
                        ctx.save();
                        ctx.translate(l.x, l.y);
                        ctx.rotate(l.angle);
                        const lg = ctx.createLinearGradient(-l.length, 0, 0, 0);
                        lg.addColorStop(0, 'transparent');
                        lg.addColorStop(0.3, `${l.color}88`);
                        lg.addColorStop(1, l.color);
                        ctx.strokeStyle = lg;
                        ctx.lineWidth = l.width;
                        ctx.shadowBlur = 15; ctx.shadowColor = l.color;
                        ctx.globalAlpha = l.alpha;
                        ctx.beginPath();
                        ctx.moveTo(-l.length, 0);
                        ctx.lineTo(0, 0);
                        ctx.stroke();
                        ctx.restore();
                    });
                    ctx.globalAlpha = 1; ctx.shadowBlur = 0;

                    // ── Shooting stars ───────────────────────────────────────
                    shooters.forEach(sh => {
                        if (sh.delay > 0) { sh.delay--; return; }
                        sh.life++;
                        if (sh.life > sh.maxLife) {
                            sh.x = -300; sh.y = Math.random() * H * 0.6;
                            sh.vx = Math.random() * 14 + 8; sh.vy = (Math.random() - 0.5) * 4;
                            sh.len = Math.random() * 250 + 150; sh.life = 0;
                            sh.maxLife = Math.random() * 50 + 25; sh.delay = Math.random() * 400 + 100;
                            sh.color = neonColors[Math.floor(Math.random() * neonColors.length)];
                            return;
                        }
                        sh.x += sh.vx; sh.y += sh.vy;
                        const a = Math.sin(Math.PI * sh.life / sh.maxLife);
                        const sg = ctx.createLinearGradient(sh.x, sh.y, sh.x - sh.vx * (sh.len / sh.vx), sh.y - sh.vy * (sh.len / sh.vx));
                        sg.addColorStop(0, sh.color);
                        sg.addColorStop(0.3, sh.color + 'aa');
                        sg.addColorStop(1, 'transparent');
                        ctx.strokeStyle = sg;
                        ctx.lineWidth = 2.5;
                        ctx.shadowBlur = 20; ctx.shadowColor = sh.color;
                        ctx.globalAlpha = a;
                        ctx.beginPath();
                        ctx.moveTo(sh.x, sh.y);
                        ctx.lineTo(sh.x - sh.vx * (sh.len / sh.vx), sh.y - sh.vy * (sh.len / sh.vx));
                        ctx.stroke();
                        ctx.globalAlpha = 1; ctx.shadowBlur = 0;
                    });

                    bgAnimFrame = requestAnimationFrame(drawNebula);
                }
                drawNebula();
            }
            else if (themeId === 'legend_abyss') {
                const raindrops = Array.from({ length: 150 }, () => ({
                    x: Math.random() * W, y: Math.random() * H,
                    w: 4.5, h: Math.random() * 25 + 15,
                    speed: Math.random() * 20 + 20
                }));
                const splashes = [];
                function drawAbyss() {
                    ctx.fillStyle = '#000205'; ctx.fillRect(0, 0, W, H);
                    const cx = W / 2, cy = H / 2;
                    const time = Date.now() * 0.001;

                    // Rain (Max Visibility Blue Rectangles)
                    ctx.fillStyle = 'rgba(0, 180, 255, 1.0)';
                    raindrops.forEach(r => {
                        r.y += r.speed;
                        if (r.y > H) {
                            r.y = -r.h;
                            r.x = Math.random() * W;
                            // Create splash
                            splashes.push({ x: r.x, y: H - 5, r: 2, opacity: 1 });
                        }
                        ctx.fillRect(r.x, r.y, r.w, r.h);
                    });

                    // Splashes
                    ctx.lineWidth = 2;
                    for (let i = splashes.length - 1; i >= 0; i--) {
                        const s = splashes[i];
                        ctx.strokeStyle = `rgba(0, 150, 255, ${s.opacity})`;
                        ctx.beginPath(); ctx.ellipse(s.x, s.y, s.r * 2, s.r, 0, 0, Math.PI * 2); ctx.stroke();
                        s.r += 1.5;
                        s.opacity -= 0.05;
                        if (s.opacity <= 0) splashes.splice(i, 1);
                    }

                    // The House (Even Bigger)
                    ctx.save(); ctx.translate(cx, cy);
                    const size = 320;
                    const pulse = Math.sin(time) * 15;
                    ctx.shadowBlur = 60 + pulse; ctx.shadowColor = '#00ffcc';

                    // Base
                    ctx.fillStyle = '#3d2b1f';
                    ctx.fillRect(-size / 2, 0, size, size / 2);
                    // Roof
                    ctx.fillStyle = '#6e1a1a';
                    ctx.beginPath(); ctx.moveTo(-size / 2 - 30, 0); ctx.lineTo(0, -size / 2); ctx.lineTo(size / 2 + 30, 0); ctx.closePath(); ctx.fill();
                    // Door
                    ctx.fillStyle = '#1a100a';
                    ctx.fillRect(-size / 10, size / 4, size / 5, size / 4);
                    // Windows (Glowing)
                    ctx.fillStyle = '#ffd700';
                    ctx.shadowBlur = 30;
                    ctx.fillRect(-size / 3.5, size / 8, size / 6, size / 6);
                    ctx.fillRect(size / 3.5 - size / 6, size / 8, size / 6, size / 6);

                    ctx.restore();
                    bgAnimFrame = requestAnimationFrame(drawAbyss);
                }
                drawAbyss();
            }
            else if (themeId === 'legend_supernova') {
                const rays = Array.from({ length: 100 }, () => ({ angle: Math.random() * Math.PI * 2, len: Math.random() * W, speed: Math.random() * 0.01 + 0.005 }));
                function drawSupernova() {
                    ctx.fillStyle = 'rgba(10, 0, 20, 0.3)'; ctx.fillRect(0, 0, W, H);
                    const cx = W / 2, cy = H / 2;
                    ctx.save(); ctx.translate(cx, cy);
                    rays.forEach(r => {
                        r.angle += r.speed;
                        const x = Math.cos(r.angle) * r.len;
                        const y = Math.sin(r.angle) * r.len;
                        const g = ctx.createLinearGradient(0, 0, x, y);
                        g.addColorStop(0, '#ffaa00'); g.addColorStop(1, 'transparent');
                        ctx.strokeStyle = g; ctx.lineWidth = 2;
                        ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(x, y); ctx.stroke();
                    });
                    // Accretion disk / lensing effect
                    ctx.shadowBlur = 80; ctx.shadowColor = '#ff5500';
                    ctx.fillStyle = '#000'; ctx.beginPath(); ctx.arc(0, 0, 40, 0, Math.PI * 2); ctx.fill();
                    ctx.strokeStyle = '#fff'; ctx.lineWidth = 5; ctx.stroke();
                    ctx.restore();
                    bgAnimFrame = requestAnimationFrame(drawSupernova);
                }
                drawSupernova();
            }
            else if (themeId === 'legend_prism') {
                function drawPrism() {
                    ctx.fillStyle = '#030303'; ctx.fillRect(0, 0, W, H);
                    const cx = W / 2, cy = H / 2;
                    const time = Date.now() * 0.001;
                    // Draw Prism (Even Bigger & Pulsing)
                    ctx.save(); ctx.translate(cx, cy);
                    ctx.rotate(time * 0.8); // Adjusted rotation
                    const glow = 70 + Math.sin(time * 3) * 50; // Brighter pulsating glow
                    ctx.shadowBlur = glow; ctx.shadowColor = '#fff';
                    ctx.strokeStyle = 'rgba(255,255,255,0.95)'; ctx.lineWidth = 6;
                    ctx.beginPath();
                    ctx.moveTo(0, -200); ctx.lineTo(173, 100); ctx.lineTo(-173, 100); ctx.closePath();
                    ctx.stroke();
                    // Brighter fill
                    ctx.fillStyle = `rgba(255,255,255,${0.15 + Math.sin(time * 3) * 0.1})`; ctx.fill();

                    // Rainbow Rays
                    ctx.shadowBlur = 0;
                    for (let i = 0; i < 7; i++) {
                        ctx.rotate(Math.PI * 2 / 7);
                        const g = ctx.createLinearGradient(0, 0, 800, 0);
                        const colors = ['red', 'orange', 'yellow', 'green', 'blue', 'indigo', 'violet'];
                        g.addColorStop(0, '#fff'); g.addColorStop(0.1, colors[i]); g.addColorStop(1, 'transparent');
                        ctx.fillStyle = g; ctx.fillRect(80, -4, 800, 8);
                    }
                    ctx.restore();
                    bgAnimFrame = requestAnimationFrame(drawPrism);
                }
                drawPrism();
            }
        }

        // =========================================================
        //  THEME CSS INJECTION
        // =========================================================
        function injectThemeCSS(themeId, themeData) {
            const styleId = `theme-style-${themeId}`;
            if (document.getElementById(styleId)) return;

            const bg = themeData.bg || '#0b0b0b';
            const isGradient = bg.includes('gradient') || bg.includes('radial');

            let cssText = `
        [data-theme="${themeId}"] {
            --primary: ${themeData.primary || '#00d4ff'};
            --panel: ${themeData.panel || 'rgba(22, 22, 22, 0.85)'};
            --sidebar: ${themeData.sidebar || 'rgba(17, 17, 17, 0.85)'};
            --text: ${themeData.text || '#f0f0f0'};
            --msg-bg: ${themeData.msg_bg || 'rgba(34, 34, 34, 0.85)'};
            --msg-me: ${themeData.msg_me || 'rgba(0, 75, 90, 0.85)'};
        }
    `;

            if (isGradient && !themeId.startsWith('mythic_')) {
                cssText += `
        [data-theme="${themeId}"] body,
        body[data-theme="${themeId}"] {
            background: ${bg};
            ${themeData.animate_bg ? 'background-size:400% 400%; animation:gradientBG 15s ease infinite;' : ''}
        }
        [data-theme="${themeId}"],
        html[data-theme="${themeId}"] {
            background: ${bg};
            ${themeData.animate_bg ? 'background-size:400% 400%; animation:gradientBG 15s ease infinite;' : ''}
        }
        `;
            } else if (!themeId.startsWith('mythic_')) {
                cssText += `[data-theme="${themeId}"] { --bg: ${bg}; }`;
            } else {
                // Mythic base resets (canvas handles background)
                cssText += `[data-theme="${themeId}"] { --bg: transparent; } body[data-theme="${themeId}"] { background: transparent; }`;
            }

            const style = document.createElement('style');
            style.id = styleId;
            style.textContent = cssText;
            document.head.appendChild(style);
        }

        function setTheme(t) {
            if (ALL_THEMES[t]) {
                injectThemeCSS(t, ALL_THEMES[t]);
                const bg = ALL_THEMES[t].bg || '#0b0b0b';
                if (bg.includes('gradient') || bg.includes('radial')) {
                    document.body.classList.add('gradient-active');
                } else {
                    document.body.classList.remove('gradient-active');
                }
            }
            document.documentElement.setAttribute('data-theme', t);
            myActiveTheme = t;
            if (user) db.ref(`users/${user}/theme`).set(t);
            startBgAnimation(t);
        }

        // =========================================================
        //  BUILD LOOT POOL
        // =========================================================
        function buildLootPool() {
            LOOT_POOL = { common: [], rare: [], epic: [], legendary: [], mythic: [], LEGENDS: [] };
            for (const [id, t] of Object.entries(ALL_THEMES)) {
                if (['free', 'event', 'ceremonial'].includes(t.rarity)) continue;
                if (t.expired) continue;
                if (LOOT_POOL[t.rarity]) LOOT_POOL[t.rarity].push({ type: 'theme', id, name: t.name });
            }
            for (const [id, t] of Object.entries(ALL_TITLES)) {
                if (t.rarity === 'ceremonial' || !t.tradeable) continue;
                if (LOOT_POOL[t.rarity]) LOOT_POOL[t.rarity].push({ type: 'title', id, name: t.name });
            }
        }

        async function seedMythics() {
            // Always ensure gold and ocean exist — they're missing from older DBs
            const alwaysPushThemes = {
                'mythic_gold': { name: "Golden Empire", rarity: "mythic", primary: "#ffd700", bg: "#000", panel: "rgba(20,15,0,0.85)", sidebar: "rgba(15,10,0,0.9)", text: "#fff8dc", msg_bg: "rgba(40,25,0,0.8)", msg_me: "rgba(80,50,0,0.9)", swatch: "linear-gradient(45deg, #7a5c00, #ffd700, #ffe87c)", animate_bg: true, expired: false },
                'mythic_ocean': { name: "Deep Ocean", rarity: "mythic", primary: "#00ffff", bg: "#000", panel: "rgba(0,10,20,0.85)", sidebar: "rgba(0,5,15,0.9)", text: "#ccffff", msg_bg: "rgba(0,20,40,0.8)", msg_me: "rgba(0,40,80,0.9)", swatch: "linear-gradient(90deg, #003366, #00ffff)", animate_bg: true, expired: false }
            };
            const alwaysPushTitles = {
                'mythic_goldking': { name: "Gold King", rarity: "mythic", tradeable: true }
            };
            try {
                await db.ref('config/themes').update(alwaysPushThemes);
                await db.ref('config/titles').update(alwaysPushTitles);
                Object.assign(ALL_THEMES, alwaysPushThemes);
                Object.assign(ALL_TITLES, alwaysPushTitles);
            } catch (e) { console.warn('seedMythics always-push failed:', e.message); }

            const mythicSeeded = await db.ref('system/mythics_seeded').once('value');
