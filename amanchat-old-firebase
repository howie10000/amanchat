        function generateMinesGrid(bombs) {
            const grid = new Array(25).fill('gem');
            const bombPositions = [];

            // Randomly place bombs
            while (bombPositions.length < bombs) {
                const pos = Math.floor(Math.random() * 25);
                if (!bombPositions.includes(pos)) {
                    bombPositions.push(pos);
                    grid[pos] = 'bomb';
                }
            }

            return grid;
        }

        function renderMinesGrid() {
            const gridEl = document.getElementById('mines-grid');
            gridEl.innerHTML = '';

            for (let i = 0; i < 25; i++) {
                const cell = document.createElement('div');
                cell.className = 'mines-cell';
                cell.style.width = '60px';
                cell.style.height = '60px';
                cell.style.background = 'rgba(0,0,0,0.5)';
                cell.style.border = '2px solid #444';
                cell.style.borderRadius = '8px';
                cell.style.cursor = 'pointer';
                cell.style.display = 'flex';
                cell.style.alignItems = 'center';
                cell.style.justifyContent = 'center';
                cell.style.fontSize = '2em';
                cell.style.transition = 'all 0.3s';

                if (minesGameState.revealed.includes(i)) {
                    cell.style.cursor = 'default';
                    cell.onclick = null;
                    cell.onmouseover = null;
                    cell.onmouseout = null;
                    if (minesGameState.grid[i] === 'bomb') {
                        cell.style.background = 'rgba(255,0,0,0.3)';
                        cell.style.borderColor = '#ff0000';
                        cell.innerText = '💣';
                    } else {
                        cell.style.background = 'rgba(0,255,85,0.3)';
                        cell.style.borderColor = '#00ff55';
                        cell.innerText = '💎';
                    }
                } else if (minesGameState.gameOver) {
                    // Game over - show all cells with distinction for unclicked
                    cell.style.cursor = 'default';
                    cell.onclick = null;
                    cell.onmouseover = null;
                    cell.onmouseout = null;
                    cell.style.background = 'rgba(100,100,100,0.2)';
                    cell.style.border = '2px dashed #666';
                    if (minesGameState.grid[i] === 'bomb') {
                        cell.innerText = '💣';
                        cell.style.opacity = '0.6';
                    } else {
                        cell.innerText = '💎';
                        cell.style.opacity = '0.6';
                    }
                } else {
                    cell.onclick = () => revealMinesCell(i);
                    cell.onmouseover = () => { cell.style.borderColor = 'var(--primary)'; };
                    cell.onmouseout = () => { cell.style.borderColor = '#444'; };
                }

                gridEl.appendChild(cell);
            }
        }

        async function revealMinesCell(index) {
            if (minesGameState.gameOver || minesGameState.revealed.includes(index)) return;

            // Prevent clicking when all gems have been found
            const totalGems = 25 - minesGameState.bombs;
            if (minesGameState.gemsFound >= totalGems) return;

            // Prevent multiple rapid clicks
            if (minesGameState.processing) return;
            minesGameState.processing = true;

            minesGameState.revealed.push(index);

            // Update just this cell instead of re-rendering entire grid
            updateSingleCell(index);

            if (minesGameState.grid[index] === 'bomb') {
                // Hit bomb - lose everything
                minesGameState.gameOver = true;
                document.getElementById('mines-status').innerText = '💣 BOOM! You lost everything!';
                document.getElementById('mines-status').style.color = '#ff5555';
                document.getElementById('mines-cashout-btn').disabled = true;

                // Reveal all bombs
                renderMinesGrid();

                // Show play again button
                setTimeout(() => {
                    document.getElementById('mines-game-area').classList.add('hidden');
                    document.getElementById('mines-bet-area').classList.remove('hidden');
                    document.getElementById('mines-cashout-btn').disabled = false;
                    minesGameState.processing = false;
                }, 2000);
            } else {
                // Found gem
                minesGameState.gemsFound++;
                updateMinesDisplay();

                // Check if all gems found - just show board, don't auto-cashout
                const totalGems = 25 - minesGameState.bombs;
                if (minesGameState.gemsFound === totalGems) {
                    document.getElementById('mines-status').innerText = '🎉 All gems found! Cash out now!';
                    document.getElementById('mines-status').style.color = '#55ff55';
                    renderMinesGrid();
                }

                minesGameState.processing = false;
            }
        }

        function updateSingleCell(index) {
            const gridEl = document.getElementById('mines-grid');
            const cell = gridEl.children[index];
            if (!cell) return;

            cell.style.cursor = 'default';
            cell.onclick = null;
            cell.onmouseover = null;
            cell.onmouseout = null;

            if (minesGameState.grid[index] === 'bomb') {
                cell.style.background = 'rgba(255,0,0,0.3)';
                cell.style.borderColor = '#ff0000';
                cell.innerText = '💣';
            } else {
                cell.style.background = 'rgba(0,255,85,0.3)';
                cell.style.borderColor = '#00ff55';
                cell.innerText = '💎';
            }
        }

        function updateMinesDisplay() {
            const mults = MINES_MULTIPLIERS[minesGameState.bombs];
            const maxIndex = mults.length - 1;
            const currentIndex = minesGameState.gemsFound > 0 ? Math.min(minesGameState.gemsFound - 1, maxIndex) : 0;
            const currentMult = minesGameState.gemsFound > 0 ? mults[currentIndex] : 1;
            const potentialWin = Math.floor(minesGameState.bet * currentMult);

            document.getElementById('mines-current-multiplier').innerText = currentMult.toFixed(2) + 'x';
            document.getElementById('mines-potential-win').innerText = potentialWin;
        }

        async function cashoutMines() {
            if (!minesGameState || minesGameState.gameOver || minesGameState.gemsFound === 0) return;
            if (minesGameState.processing) return;

            const mults = MINES_MULTIPLIERS[minesGameState.bombs];
            const maxIndex = mults.length - 1;
            const currentIndex = Math.min(minesGameState.gemsFound - 1, maxIndex);
            const currentMult = mults[currentIndex];
            const winAmount = Math.floor(minesGameState.bet * currentMult);

            minesGameState.gameOver = true;
            minesGameState.processing = false;

            await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(winAmount));

            document.getElementById('mines-status').innerText = `💰 Cashed out! Won ${winAmount} points (${currentMult.toFixed(2)}x)`;
            document.getElementById('mines-status').style.color = '#55ff55';
            document.getElementById('mines-cashout-btn').disabled = true;

            // Show full board
            renderMinesGrid();

            setTimeout(() => {
                document.getElementById('mines-game-area').classList.add('hidden');
                document.getElementById('mines-bet-area').classList.remove('hidden');
                document.getElementById('mines-cashout-btn').disabled = false;
                minesGameState = null;
            }, 2000);
        }

