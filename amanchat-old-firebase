        async function playVoidReveal(item) {
            const overlay = document.getElementById('mythic-reveal-overlay');
            const W = window.innerWidth;
            const H = window.innerHeight;

            // Phase 1: Black hole with asteroids circling (2.5s)
            let voidHTML = '<div style="position:absolute;inset:0;background:radial-gradient(ellipse at center,#1a0a2e 0%,#000 100%);"></div>';

            // Stars in background
            for (let i = 0; i < 50; i++) {
