        <!-- Password Change Modal -->
        <div id="modal-change-pass" class="modal hidden">
            <div class="modal-card" style="max-width:380px;">
                <h3 style="color:var(--primary); margin-top:0;">🔑 Change Password</h3>
                <p style="color:#aaa; font-size:0.85em; margin-bottom:14px;">Enter your current password to verify.</p>
                <input type="password" id="cpw-current" placeholder="Current password"
