        async function buyLootbox(id, cost) {
            if (myPoints < cost) return alert("Not enough points!");
            await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-cost));
            await db.ref(`users/${user}/inventory/lootboxes/${id}`).set(firebase.database.ServerValue.increment(1));
            alert("Added to inventory!");
        }

        function openLootboxModal(idx, fromInventory = false) {
            if (!fromInventory && myPoints < LOOTBOXES[idx].cost) return alert(`Not enough points! Need ${LOOTBOXES[idx].cost}.`);
            pendingLootboxIndex = idx; pendingLootResult = null;
            openingFromInventory = fromInventory;
            document.getElementById('lb-open-title').innerText = `Opening ${LOOTBOXES[idx].name}...`;
            document.getElementById('lb-open-box').innerText = LOOTBOXES[idx].icon;
            document.getElementById('lb-open-box').style.filter = '';
            document.getElementById('lb-sparkle-container').innerHTML = '';
            document.getElementById('lb-opening-phase').classList.remove('hidden');
            document.getElementById('lb-result-phase').classList.add('hidden');
            document.getElementById('lootbox-open-modal').classList.remove('hidden');
        }

        function shakeLootbox() {
            const box = document.getElementById('lb-open-box');
            box.classList.remove('shaking'); void box.offsetWidth; box.classList.add('shaking');
            document.getElementById('lb-tap-btn').disabled = true;
            setTimeout(() => { box.style.filter = 'blur(5px) brightness(3)'; setTimeout(() => revealLootResult(), 400); }, 800);
        }

        async function revealLootResult() {
            const lb = LOOTBOXES[pendingLootboxIndex];
            if (openingFromInventory) {
                await db.ref(`users/${user}/inventory/lootboxes/${lb.id}`).set(firebase.database.ServerValue.increment(-1));
            } else {
                await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(-lb.cost));
            }

            const r = Math.random(); let rarity;

            if (r < (lb.rates.mythic || 0)) rarity = 'mythic';
            else if (r < (lb.rates.mythic || 0) + (lb.rates.LEGENDS || 0)) rarity = 'LEGENDS';
            else if (r < (lb.rates.mythic || 0) + (lb.rates.LEGENDS || 0) + (lb.rates.legendary || 0)) rarity = 'legendary';
            else if (r < (lb.rates.mythic || 0) + (lb.rates.LEGENDS || 0) + (lb.rates.legendary || 0) + (lb.rates.epic || 0)) rarity = 'epic';
            else if (r < (lb.rates.mythic || 0) + (lb.rates.LEGENDS || 0) + (lb.rates.legendary || 0) + (lb.rates.epic || 0) + (lb.rates.rare || 0)) rarity = 'rare';
            else rarity = 'common';

            const pool = LOOT_POOL[rarity];
            if (!pool || pool.length === 0) { alert(`No items in ${rarity} pool yet!`); closeM('lootbox-open-modal'); return; }

            const item = pool[Math.floor(Math.random() * pool.length)];
            pendingLootResult = item;
            let isDupe = false;

            if (item.type === 'theme') {
                const existing = (myInventory.themes && myInventory.themes[item.id]) || 0;
                isDupe = existing > 0;
                await db.ref(`users/${user}/inventory/themes/${item.id}`).set(firebase.database.ServerValue.increment(1));
            } else {
                const existing = (myInventory.titles && myInventory.titles[item.id]) || 0;
                isDupe = existing > 0;
                await db.ref(`users/${user}/inventory/titles/${item.id}`).set(firebase.database.ServerValue.increment(1));
            }

            // Check if mythic or legend and has custom reveal animation
            if (rarity === 'LEGENDS') {
                await playLegendReveal(item);
                return;
            }
            if (rarity === 'mythic' && item.type === 'theme' && (item.id === 'mythic_ocean' || item.id === 'mythic_inferno' || item.id === 'mythic_matrix' || item.id === 'mythic_void' || item.id === 'mythic_nebula' || item.id === 'mythic_gold')) {
                await playMythicReveal(item.id, item);
                return;
            }

            // Normal reveal for non-mythic or mythics without custom animation
            showNormalResult(item, rarity, isDupe);
        }

        function showNormalResult(item, rarity, isDupe) {
            const icons = { common: '⬜', rare: '🔷', epic: '🟣', legendary: '🌟', mythic: '🔮' };
            document.getElementById('lb-opening-phase').classList.add('hidden');
            document.getElementById('lb-result-phase').classList.remove('hidden');
