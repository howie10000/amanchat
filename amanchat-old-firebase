        function renderInvThemes(themes) {
            const grid = document.getElementById('inv-themes-grid'); grid.innerHTML = '';
            const RARITY_ORDER = { LEGENDS: 0, mythic: 1, legendary: 2, epic: 3, rare: 4, ceremonial: 5, event: 6, free: 7, common: 8 };

            // Ensure basic themes exist in ALL_THEMES
            if (!ALL_THEMES['dark']) ALL_THEMES['dark'] = { name: "Dark", rarity: "free", primary: "#00d4ff", bg: "#0b0b0b", panel: "rgba(22, 22, 22, 0.85)", sidebar: "rgba(17, 17, 17, 0.85)", text: "#f0f0f0", msg_bg: "rgba(34, 34, 34, 0.85)", msg_me: "rgba(0, 75, 90, 0.85)", swatch: "#111" };
            if (!ALL_THEMES['light']) ALL_THEMES['light'] = { name: "Light", rarity: "free", primary: "#007bff", bg: "#f8f9fa", panel: "rgba(255,255,255,0.9)", sidebar: "rgba(240,240,240,0.9)", text: "#333", msg_bg: "rgba(230,230,230,0.9)", msg_me: "rgba(0,123,255,0.2)", swatch: "#eee" };

            // Build unique list from ALL_THEMES filtered by ownership
            const ownedIds = new Set(Object.keys(themes).filter(id => themes[id] > 0));
            ownedIds.add('dark'); ownedIds.add('light'); // Free themes

            const entries = Array.from(ownedIds)
                .filter(id => ALL_THEMES[id])
                .sort((a, b) => {
                    const ra = RARITY_ORDER[ALL_THEMES[a].rarity] ?? 9;
                    const rb = RARITY_ORDER[ALL_THEMES[b].rarity] ?? 9;
                    return ra !== rb ? ra - rb : ALL_THEMES[a].name.localeCompare(ALL_THEMES[b].name);
                });

            entries.forEach(id => {
                const td = ALL_THEMES[id];
                const isActive = myActiveTheme === id;
                const count = themes[id] || 1;
                const sw = getThemeSwatch(id, td);
                const isLegend = td.rarity === 'LEGENDS';
                
                const div = document.createElement('div');
                div.className = `inv-item ic-${td.rarity} ${isLegend ? 'premium-legend-card' : ''}`;
                div.style.border = `2px solid ${isActive ? 'var(--primary)' : 'rgba(255,255,255,0.1)'}`;
                
                div.innerHTML = `
                    <div class="theme-swatch" style="background:${sw}; ${isLegend ? 'box-shadow: 0 0 15px var(--primary);' : ''}"></div>
                    ${count > 1 ? `<div class="inv-badge">${count}</div>` : ''}
                    <div style="font-size:0.85em; font-weight:bold; margin-bottom:4px; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${td.name}</div>
                    <div class="rarity-badge ${RARITY_BADGE[td.rarity] || 'rb-common'}" style="margin-bottom:8px;">${td.rarity}</div>
                    ${isActive ? `<button class="btn" style="width:100%; padding:5px; background:rgba(0,0,0,0.5); font-size:0.75em;" disabled>Equipped</button>`
                                : `<button class="btn primary" style="width:100%; padding:5px; font-size:0.75em;" onclick="setTheme('${id}'); loadInventory();">Equip</button>`}
                `;
                grid.appendChild(div);
            });

            if (grid.children.length === 0) grid.innerHTML = '<p style="color:#555;">No themes in inventory. Open lootboxes!</p>';
        }

        function renderInvTitles(titles, ceremonials = {}) {
            const grid = document.getElementById('inv-titles-grid'); grid.innerHTML = '';
            const RARITY_ORDER = { LEGENDS: 0, mythic: 1, legendary: 2, epic: 3, rare: 4, ceremonial: 5, event: 6, free: 7, common: 8 };
            
            // Ensure basic ceremonials are in ALL_TITLES for rendering if missing
            if (!ALL_TITLES['admin_t']) ALL_TITLES['admin_t'] = { name: "ADMIN", rarity: "ceremonial" };
            if (!ALL_TITLES['og']) ALL_TITLES['og'] = { name: "OG", rarity: "ceremonial" };

            // Combine all owned IDs to prevent duplicates
            const ownedIds = new Set([
                ...Object.keys(titles).filter(id => titles[id] > 0),
                ...Object.keys(ceremonials).filter(id => ceremonials[id] === true)
            ]);

            const entries = Array.from(ownedIds)
                .filter(id => ALL_TITLES[id])
                .sort((a, b) => {
                    const ra = RARITY_ORDER[ALL_TITLES[a].rarity] ?? 9;
                    const rb = RARITY_ORDER[ALL_TITLES[b].rarity] ?? 9;
                    return ra !== rb ? ra - rb : ALL_TITLES[a].name.localeCompare(ALL_TITLES[b].name);
                });
            
            entries.forEach(id => {
                const td = ALL_TITLES[id];
                const isActive = myActiveTitle === id;
                const count = titles[id] || 1;
                const isCeremonial = ceremonials[id] === true;
                const isLegend = td.rarity === 'LEGENDS';
                
                const div = document.createElement('div');
                div.className = `inv-item ic-${td.rarity} ${isLegend ? 'premium-legend-card' : ''}`;
                if (isCeremonial) div.style.border = '2px solid rgba(255,102,102,0.4)';
                else div.style.border = `2px solid ${isActive ? 'var(--primary)' : 'rgba(255,255,255,0.1)'}`;
                
                div.innerHTML = `
                    ${count > 1 ? `<div class="inv-badge">${count}</div>` : ''}
                    <div style="font-size:1.5em; margin-bottom:4px;">${isCeremonial ? '🏆' : '🏷️'}</div>
                    <div style="font-size:0.8em; font-weight:bold; margin-bottom:4px; text-shadow: 0 1px 2px rgba(0,0,0,0.8);" class="${isCeremonial ? 'rcr' : (RARITY_CLASS[td.rarity] || 'rc')}">${td.name}</div>
                    <div class="rarity-badge ${isCeremonial ? 'rb-ceremonial' : (RARITY_BADGE[td.rarity] || 'rb-common')}" style="margin-bottom:8px;">${isCeremonial ? 'Ceremonial' : td.rarity}</div>
                    ${isActive ? `<button class="btn" style="width:100%; padding:5px; background:rgba(0,0,0,0.5); font-size:0.75em;" disabled>Active</button>`
                                : `<button class="btn primary" style="width:100%; padding:5px; font-size:0.75em; ${isCeremonial ? 'background:rgba(255,102,102,0.2); color:#ff9999; border:1px solid #ff6666;' : ''}" onclick="setActiveTitle('${id}'); loadInventory();">Equip</button>`}
                `;
                grid.appendChild(div);
            });

            if (grid.children.length === 0) { grid.innerHTML = '<p style="color:#555; grid-column:span 6;">No titles yet. Open lootboxes!</p>'; }
        }



