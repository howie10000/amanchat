                    <input type="color" id="msg-draw-color" value="#000000"
                        style="padding:0; width:40px; height:40px; cursor:pointer;">
                    <button class="btn" style="background:#444; color:white; flex:1;"
                        onclick="clearMsgDraw()">Clear</button>
                </div>
                <button class="btn primary" style="width:100%; margin-bottom:10px;" onclick="sendDrawMsg()">Send
                    Drawing</button>
                <button class="btn" style="width:100%; background:none; color:#ddd;"
                    onclick="closeM('modal-draw-msg')">Cancel</button>
            </div>
