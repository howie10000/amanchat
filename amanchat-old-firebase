        function aviaLoop() {
            if (!aviaActive) return;

            aviaCtx.clearRect(0, 0, 800, 400);

            // Draw BG
            aviaCtx.fillStyle = 'rgba(255,255,255,0.05)';
            for (let i = 0; i < 20; i++) {
                aviaCtx.fillRect((Date.now() / 20 + i * 100) % 900 - 50, i * 30, 2, 2);
            }

            // Physics - UP/DOWN is always full speed
            aviaPlane.vy += 0.22;
            aviaPlane.y += aviaPlane.vy;

            if (aviaPlane.y < 0) { aviaPlane.y = 0; aviaPlane.vy = 0; }
            if (aviaPlane.y > 400) { aviaCrash(); return; }

            // Check if we trigger full speed
            if (aviaMult >= 1.5) aviaIsSpeedingUp = true;

            // Multiplier increment - slow until speeding up
            let mSpeed = aviaIsSpeedingUp ? 0.0005 : 0.0002;
            aviaMult += mSpeed;
            document.getElementById('avia-multiplier').innerText = aviaMult.toFixed(2) + 'x';

            // Spawn regular entities (with distance buffer for hazards)
            if (Math.random() < 0.04) {
                const lastEntity = aviaEntities[aviaEntities.length - 1];
                const spawnThreshold = aviaMult >= 1.50 ? 723 : 700; // Exact 15% closer spawn (Gap reduced from 150 to 127.5)
                const canSpawn = !lastEntity || lastEntity.x < spawnThreshold; // Ensure gap

                if (canSpawn) {
                let r = Math.random();
                let type;
                if (r < 0.75) type = 'hazard'; // significantly increased X spawn
                else if (r < 0.88) type = 'green';
                else type = 'red';

                    aviaEntities.push({
                        x: 850,
                        y: Math.random() * 320 + 20,
                        type: type,
                        val: Math.random() * 0.2, // max 0.2
                        seed: Math.random() * 100
                    });
                }
            }

            // Spawn carrier
            if (aviaMult >= 1.75 && Math.floor(aviaMult) > aviaLastCarrierMult) {
                aviaLastCarrierMult = Math.floor(aviaMult);
                aviaEntities.push({
                    x: 850,
                    y: 380, // bottom
                    type: 'carrier',
                    width: 120, // Easier landing
                    height: 25
                });
            }

            // Update and Draw entities
            aviaEntities.forEach((e, i) => {
                // Smooth acceleration from 3.5 to 6.0 based on multiplier
                let moveSpeed = 3.5 + Math.min(Math.max(aviaMult - 1.0, 0) / 0.5, 1) * 2.5;
                e.x -= moveSpeed;

                // Wavy motion for hazards
                if (e.type === 'hazard') e.y += Math.sin(Date.now() / 200 + e.seed) * 2;

                aviaCtx.beginPath();
                if (e.type === 'carrier') {
                    aviaCtx.fillStyle = '#444';
                    aviaCtx.fillRect(e.x - e.width / 2, e.y - e.height / 2, e.width, e.height);
                    aviaCtx.fillStyle = '#fff';
                    aviaCtx.font = 'bold 12px Arial';
                    aviaCtx.textAlign = 'center';
                    aviaCtx.fillText('LAND', e.x, e.y + 4);
                    // Optional: Draw it a bit like X's and +'s combined
                    aviaCtx.strokeStyle = '#00ff55';
                    aviaCtx.lineWidth = 2;
                    aviaCtx.strokeRect(e.x - e.width / 2, e.y - e.height / 2, e.width, e.height);
                } else if (e.type === 'green') {
                    aviaCtx.shadowBlur = 15;
                    aviaCtx.shadowColor = '#00ff55';
                    aviaCtx.fillStyle = '#00ff55';
                    aviaCtx.arc(e.x, e.y, 12, 0, Math.PI * 2);
                    aviaCtx.fill();
                    aviaCtx.fillStyle = '#000';
                    aviaCtx.font = 'bold 10px Arial';
                    aviaCtx.textAlign = 'center';
                    aviaCtx.fillText('+' + e.val.toFixed(2), e.x, e.y + 4);
                    aviaCtx.shadowBlur = 0;
                } else if (e.type === 'red') {
                    aviaCtx.shadowBlur = 15;
                    aviaCtx.shadowColor = '#ff3333';
                    aviaCtx.fillStyle = '#ff3333';
                    aviaCtx.beginPath();
                    aviaCtx.arc(e.x, e.y, 12, 0, Math.PI * 2);
                    aviaCtx.fill();
                    aviaCtx.fillStyle = '#fff';
                    aviaCtx.font = 'bold 10px Arial';
                    aviaCtx.textAlign = 'center';
                    aviaCtx.fillText('-' + e.val.toFixed(2), e.x, e.y + 4);
                    aviaCtx.shadowBlur = 0;
                } else {
                    // Hazard shape (X)
                    aviaCtx.shadowBlur = 15;
                    aviaCtx.shadowColor = '#ff3e3e';
                    aviaCtx.moveTo(e.x - 15, e.y - 15);
                    aviaCtx.lineTo(e.x + 15, e.y + 15);
                    aviaCtx.moveTo(e.x + 15, e.y - 15);
                    aviaCtx.lineTo(e.x - 15, e.y + 15);
                    aviaCtx.strokeStyle = '#ff3e3e';
                    aviaCtx.lineWidth = 4;
                    aviaCtx.stroke();
                    aviaCtx.shadowBlur = 0;
                }

                // Collision
                if (e.type === 'carrier') {
                    const dx = Math.abs(aviaPlane.x - e.x);
                    const dy = Math.abs(aviaPlane.y - e.y);
                    // generous landing box
                    if (dx < e.width / 2 && dy < e.height / 2 + 20) {
                        // Cash out
                        cashoutAvia(true); // full cashout
                    }
                } else {
                    const dx = e.x - aviaPlane.x;
                    const dy = e.y - aviaPlane.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 30) {
                        if (e.type === 'green') {
                            aviaMult += e.val;
                            aviaEntities.splice(i, 1);
                            // Visual feedback
                            aviaCtx.fillStyle = '#fff';
                            aviaCtx.beginPath();
                            aviaCtx.arc(aviaPlane.x, aviaPlane.y, 40, 0, Math.PI * 2);
                            aviaCtx.fill();
                        } else if (e.type === 'red') {
                            aviaMult -= e.val;
                            if (aviaMult < 1.0) aviaMult = 1.0;
                            aviaEntities.splice(i, 1);
                            // Visual feedback
                            aviaCtx.fillStyle = '#ff0000';
                            aviaCtx.beginPath();
                            aviaCtx.arc(aviaPlane.x, aviaPlane.y, 40, 0, Math.PI * 2);
                            aviaCtx.fill();
                        } else {
                            aviaCrash();
                        }
                    }
                }
            });

            aviaEntities = aviaEntities.filter(e => e.x > -100);

            // Draw Plane
            aviaCtx.save();
            aviaCtx.translate(aviaPlane.x, aviaPlane.y);
            aviaCtx.rotate(Math.min(Math.max(aviaPlane.vy * 0.05, -0.5), 0.5));
            aviaCtx.font = '40px Arial';
            aviaCtx.textAlign = 'center';
            aviaCtx.textBaseline = 'middle';
            aviaCtx.fillText('✈️', 0, 0);

            // Boost effect
            if (aviaPlane.vy < 0) {
                aviaCtx.fillStyle = 'rgba(255,200,0,0.5)';
                aviaCtx.beginPath();
                aviaCtx.moveTo(-30, 0);
                aviaCtx.lineTo(-60, 10);
                aviaCtx.lineTo(-60, -10);
                aviaCtx.fill();
            }
            aviaCtx.restore();

            aviaFrame = requestAnimationFrame(aviaLoop);
        }

        function aviaCrash() {
            aviaActive = false;
            cancelAnimationFrame(aviaFrame);
            document.getElementById('avia-cashout').style.display = 'none';
            const status = document.getElementById('avia-status');
            status.innerText = "💥 CRASHED!";
            status.style.color = '#ff3e3e';
            status.style.textShadow = "0 0 20px #ff0000";
        }

        async function cashoutAvia(isFull = false) {
            if (!aviaActive) return;
            aviaActive = false;
            cancelAnimationFrame(aviaFrame);
            document.getElementById('avia-cashout').style.display = 'none';

            let finalMult = isFull ? aviaMult : (aviaMult / 3);
            if (!isFull) {
                document.getElementById('avia-multiplier').innerText = finalMult.toFixed(2) + 'x';
            }

            const win = Math.floor(aviaBetVal * finalMult);
            const status = document.getElementById('avia-status');
            status.innerHTML = `💰 +${win.toLocaleString()}! <br><span style="font-size:0.5em; color:#aaa;">${isFull ? '(CARRIER LANDING)' : '(1/3 EARLY CASH)'}</span>`;
            status.style.color = '#00ff55';
            status.style.textShadow = "0 0 20px #00ff00";

            await db.ref(`users/${user}/points`).set(firebase.database.ServerValue.increment(win));
        }

        window.addEventListener('keydown', e => {
            if (e.key.toLowerCase() === 'e' && aviaActive) cashoutAvia(false);
        });

        window.addEventListener('click', e => {
            const disableFX = document.getElementById('opt-disable-click-fx')?.checked;
            if (disableFX) return;

            if (!myActiveTheme || !ALL_THEMES[myActiveTheme]) return;
            const theme = ALL_THEMES[myActiveTheme];
            
            // Only LEGENDS tier themes get click effects (Mythics removed as requested)
            if (theme.rarity !== 'LEGENDS' || !theme.special_fx) return;

            const fx = document.createElement('div');
            fx.className = 'click-fx';
            fx.style.left = e.clientX + 'px';
            fx.style.top = e.clientY + 'px';

            if (theme.special_fx === 'starburst') {
                fx.style.background = 'radial-gradient(circle, #ffaa00, transparent)';
                fx.style.boxShadow = '0 0 30px #ffaa00, 0 0 60px #ffaa00';
                for (let i = 0; i < 12; i++) {
                    const spark = document.createElement('div');
                    spark.innerText = '⭐';
                    spark.style.position = 'absolute';
                    spark.style.left = '50%';
                    spark.style.top = '50%';
                    spark.style.fontSize = (Math.random() * 10 + 10) + 'px';
                    const ang = (i / 12) * Math.PI * 2;
                    const dist = 50 + Math.random() * 30;
                    spark.animate([
                        { transform: 'translate(-50%, -50%) translate(0,0) scale(1)', opacity: 1 },
                        { transform: `translate(-50%, -50%) translate(${Math.cos(ang) * dist}px, ${Math.sin(ang) * dist}px) scale(0)`, opacity: 0 }
                    ], { duration: 600, easing: 'ease-out' });
                    fx.appendChild(spark);
                }
            } else if (theme.special_fx === 'ripple') {
                fx.style.border = '4px solid #00ffcc';
                fx.style.boxShadow = '0 0 30px #00ffcc, inset 0 0 20px #00ffcc';
                fx.animate([
                    { width: '0px', height: '0px', opacity: 1 },
                    { width: '200px', height: '200px', opacity: 0 }
                ], { duration: 800, easing: 'ease-out' });
            } else if (theme.special_fx === 'rainbow_click') {
                fx.style.background = 'conic-gradient(from 0deg, red, orange, yellow, green, blue, indigo, violet, red)';
                fx.style.boxShadow = '0 0 25px white';
                fx.style.opacity = '0.8';
                fx.animate([
                    { transform: 'translate(-50%, -50%) scale(0) rotate(0deg)', opacity: 1 },
                    { transform: 'translate(-50%, -50%) scale(2) rotate(360deg)', opacity: 0 }
                ], { duration: 700, easing: 'ease-out' });
            } else if (theme.special_fx === 'abyss_void') {
                fx.style.background = 'black';
                fx.style.boxShadow = '0 0 40px #6600ff, 0 0 80px #330066';
                fx.style.border = '2px solid #6600ff';
                fx.animate([
                    { transform: 'translate(-50%, -50%) scale(0)', opacity: 1 },
                    { transform: 'translate(-50%, -50%) scale(2.5)', opacity: 0 }
                ], { duration: 1000, easing: 'ease-in' });
                for (let i = 0; i < 6; i++) {
                    const p = document.createElement('div');
                    p.style.position = 'absolute';
                    p.style.width = '10px'; p.style.height = '10px';
                    p.style.background = '#6600ff'; p.style.borderRadius = '50%';
                    p.style.left = '50%'; p.style.top = '50%';
                    const ang = Math.random() * Math.PI * 2;
                    p.animate([
                        { transform: `translate(-50%, -50%) translate(${Math.cos(ang) * 100}px, ${Math.sin(ang) * 100}px) scale(1)`, opacity: 0 },
                        { transform: 'translate(-50%, -50%) translate(0,0) scale(0)', opacity: 1 }
                    ], { duration: 800, easing: 'ease-in' });
                    fx.appendChild(p);
                }
            } else if (theme.special_fx === 'prism_shards') {
                fx.style.background = 'white';
                fx.style.boxShadow = '0 0 30px white';
                for (let i = 0; i < 15; i++) {
                    const shard = document.createElement('div');
                    shard.style.position = 'absolute';
                    shard.style.width = '8px'; shard.style.height = '8px';
                    shard.style.background = `hsl(${Math.random() * 360}, 100%, 70%)`;
                    shard.style.left = '50%'; shard.style.top = '50%';
                    const ang = Math.random() * Math.PI * 2;
                    const dist = 60 + Math.random() * 40;
                    shard.animate([
                        { transform: 'translate(-50%, -50%) translate(0,0) rotate(0deg) scale(1)', opacity: 1 },
                        { transform: `translate(-50%, -50%) translate(${Math.cos(ang) * dist}px, ${Math.sin(ang) * dist}px) rotate(${Math.random() * 720}deg) scale(0)`, opacity: 0 }
                    ], { duration: 900, easing: 'ease-out' });
                    fx.appendChild(shard);
                }
            }

            document.body.appendChild(fx);
            setTimeout(() => fx.remove(), 600);
        });
    </script>
</body>

