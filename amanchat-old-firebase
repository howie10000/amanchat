                style="background:rgba(0,255,0,0.05); border:1px solid #00ff00; padding:20px; max-width:600px; width:100%; color:#00ff00; font-size:0.85em; text-align:left; max-height:300px; overflow:auto; white-space:pre-wrap;"></pre>
