                document.getElementById('poker-table').classList.add('hidden');
                document.getElementById('poker-round-end').classList.remove('hidden');
                document.getElementById('poker-winner-msg').textContent = '🔄 Starting new round...';
            } else if (['preflop', 'flop', 'turn', 'river'].includes(phase)) {
