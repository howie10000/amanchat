        // ── Offline detection — end game and refund pot to remaining players ──────────
        function pokerStartOfflineWatch() {
            if (pokerOfflineWatcher) clearInterval(pokerOfflineWatcher);
            pokerOfflineWatcher = setInterval(async () => {
                if (!pokerCode || !pokerRef || !pokerState) return;
                if (!pokerIsHost) return;
                const g = pokerState;
                if (!['preflop', 'flop', 'turn', 'river', 'showdown'].includes(g.phase)) return;
                const now = Date.now();
                const players = g.players || {};
                const order = g.order || [];
                const OFFLINE_MS = 20000;
                const offlinePlayers = order.filter(p => {
                    const pd = players[p] || {};
                    return !pd.folded && pd.lastSeen && (now - pd.lastSeen) > OFFLINE_MS;
                });
                if (offlinePlayers.length === 0) return;

                // Refund entire pot equally to remaining (online) players
                const remaining = order.filter(p => !offlinePlayers.includes(p));
                const pot = g.pot || 0;
                // Also include any in-hand bets that went into the pot
                const totalPot = pot + order.reduce((sum, p) => sum + ((players[p] || {}).bet || 0), 0);

                const updates = {};
                if (remaining.length > 0) {
                    const perPlayer = Math.floor(totalPot / remaining.length);
                    remaining.forEach(p => {
                        updates[`players/${p}/chips`] = ((players[p] || {}).chips || 0) + perPlayer;
                        updates[`players/${p}/bet`] = 0;
                    });
                }
                // Zero out offline players' bets (chips already lost to them)
                offlinePlayers.forEach(p => {
                    updates[`players/${p}`] = null; // remove them
                });
                updates['pot'] = 0;
                updates['phase'] = 'waiting';
                updates['round'] = g.round;

                const names = offlinePlayers.join(', ');
                alert(`${names} went offline! Game ended — pot refunded equally to remaining players.`);
                await pokerRef.update(updates);
            }, 6000);
        }

