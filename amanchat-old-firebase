            <div class="modal-card">
                <h3 style="color:red;">Report User</h3>
                <p style="font-size:0.8em; color:#aaa;" id="report-target-txt"></p>
                <textarea id="report-reason" placeholder="Reason for reporting..."
                    style="height:80px; margin-bottom:15px; width:90%;"></textarea>
                <button class="btn primary" style="width:100%; margin-bottom:10px;" onclick="submitReport()">Submit
                    Report</button>
                <button class="btn" style="width:100%; background:none; color:#ddd;"
                    onclick="closeM('modal-report')">Cancel</button>
            </div>
        </div>

