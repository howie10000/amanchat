            ${myP.chips > 0 ? `<button class="btn" onclick="pokerAllIn()" style="background:rgba(180,0,180,0.5);">All In (${(myP.chips || 0).toLocaleString()})</button>` : ''}
        `;
                statusEl.textContent = "⬆️ It's your turn!";
